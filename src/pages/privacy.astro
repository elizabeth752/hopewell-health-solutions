---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";

const canonical = "https://www.hopewellhealthsolutions.com/privacy";
const updated = "June 20, 2026";

const collected = [
  { label: "Information you give us", body: "Personally identifiable information such as your name, e-mail address, home or work address, and telephone number — typically when you contact us or submit a form." },
  { label: "Anonymous demographic information", body: "Information that is not unique to you, such as your ZIP code, age, gender, preferences, and interests." },
  { label: "Information collected automatically", body: "Technical information about your device, including your IP address, browser type, domain names, access times, and referring website addresses. We use this to operate and maintain the quality of the site and to compile general usage statistics." },
];
---

<Base title="Privacy Policy | Hopewell Health Solutions" description="How Hopewell Health Solutions collects, uses, and protects information submitted through this website — and how it differs from the protected health information covered by our HIPAA Notice of Privacy Practices." canonical={canonical}>
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-3xl px-5 pt-8 pb-14">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <span class="text-ink">Privacy Policy</span></nav>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Your privacy</p>
      <h1 class="mt-3 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Privacy Policy</h1>
      <div class="mt-5 h-px w-16 bg-gold"></div>
      <p class="mt-5 text-muted text-sm">Last updated: {updated}</p>
    </div>
  </section>

  <!-- BODY -->
  <section class="bg-white">
    <div class="mx-auto max-w-3xl px-5 py-16 space-y-10 text-ink leading-relaxed text-[17px]">

      <p>Hopewell Health Solutions (“we,” “us,” or “our”) is committed to protecting your privacy. This Privacy Policy applies to this website and governs the data we collect and how we use it. By using this website, you consent to the data practices described here.</p>

      <!-- BH-critical: website privacy vs. HIPAA PHI -->
      <div class="rounded-2xl bg-azul-light/40 border border-azul/30 p-6 space-y-3">
        <h2 class="font-display text-xl sm:text-2xl text-ink">This policy covers the website — not your health records</h2>
        <p class="text-[16px]">This Privacy Policy applies to information collected through our website. It is <strong>separate</strong> from the protected health information (PHI) you share as a patient during care, which is governed by our <a href="/hipaa-notice/" class="text-azul font-semibold underline">HIPAA Notice of Privacy Practices</a> and protected under federal law, including 42 CFR Part 2 for substance use records.</p>
        <p class="text-[16px]">Please <strong>do not include health details or other sensitive personal information</strong> in website forms, e-mails, or messages. If you are an existing or prospective patient, contact us directly so we can protect your information appropriately.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-display text-2xl sm:text-3xl text-ink">Information we collect</h2>
        <p>This website may collect the following types of information:</p>
        <ul class="space-y-4 pl-1">
          {collected.map((c) => (
            <li class="flex gap-3">
              <span class="mt-2.5 h-1.5 w-1.5 shrink-0 rounded-full bg-azul"></span>
              <span><strong>{c.label}.</strong> {c.body}</span>
            </li>
          ))}
        </ul>
        <p>Please keep in mind that if you voluntarily disclose personal information in a public space — such as a review or message board — that information may be collected and used by others.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-display text-2xl sm:text-3xl text-ink">How we use your information</h2>
        <p>We use the information we collect to operate this website and deliver the services you request. We may also use your information to tell you about other services we offer, or to contact you through surveys to learn your opinion of current or potential services.</p>
        <p><strong>We do not sell, rent, or lease our contact lists to third parties.</strong> We may share information with trusted partners who help us operate the site or communicate with you — for example, to perform statistical analysis, send e-mail or postal mail, or provide support. These partners are prohibited from using your information for anything other than providing those services and are required to keep it confidential.</p>
        <p>We do not use or disclose sensitive personal information — such as race, religion, or political affiliation — without your explicit consent. We will disclose personal information without notice only if required to do so by law.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-display text-2xl sm:text-3xl text-ink">Cookies</h2>
        <p>This website uses “cookies” to help personalize your online experience. A cookie is a small text file placed on your device by a web page server. Cookies cannot run programs or deliver viruses to your computer, are uniquely assigned to you, and can only be read by a web server in the domain that issued them. You can adjust your browser settings to decline cookies, though some parts of the site may not function as intended if you do.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-display text-2xl sm:text-3xl text-ink">How we protect your information</h2>
        <p>We secure your personal information from unauthorized access, use, or disclosure, and store it in a controlled environment. When sensitive information is transmitted online, it is protected through encryption, such as the Secure Sockets Layer (SSL) protocol. No method of transmission over the Internet is completely secure, however, and we cannot guarantee absolute security.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-display text-2xl sm:text-3xl text-ink">Links to third-party sites</h2>
        <p>This website may link to other websites that are not under our control. We are not responsible for the privacy practices or content of those sites. We encourage you to review the privacy statement of any website you visit so you understand how it collects and uses your information.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-display text-2xl sm:text-3xl text-ink">Children’s privacy</h2>
        <p>This website is intended for adults. We do not knowingly collect personal information from children under 13 through this site. If you believe a child has provided us information through this website, please contact us so we can remove it.</p>
      </div>

      <div class="space-y-3">
        <h2 class="font-display text-2xl sm:text-3xl text-ink">Changes to this policy</h2>
        <p>We may update this Privacy Policy from time to time to reflect changes in our practices or for other operational, legal, or regulatory reasons. We encourage you to review this page periodically. Your continued use of the website after changes are posted constitutes your acceptance of the updated policy.</p>
      </div>

      <div class="space-y-3 border-t border-line pt-8">
        <h2 class="font-display text-2xl sm:text-3xl text-ink">Contact us</h2>
        <p>Questions about this Privacy Policy? Contact us by phone at <a href="tel:8609460447" class="text-azul font-semibold">(860) 946-0447</a> or by mail at 1216 Farmington Ave., Suite 301, West Hartford, CT 06107.</p>
      </div>

    </div>
  </section>

  <Footer />
</Base>
