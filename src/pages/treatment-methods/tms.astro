---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";

const heroUsps = [
  { icon: "shield", t: "FDA-cleared, drug-free & non-invasive" },
  { icon: "brain", t: "NeuroStar® Advanced TMS for depression & OCD" },
  { icon: "calendar", t: "18–45 minute sessions · no downtime · resume your day" },
  { icon: "sparkles", t: "For treatment-resistant depression — a safer alternative to ECT" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const uses = [
  { icon: "cloud", t: "Treatment-Resistant Major Depression", d: "Nearly half of people with clinical depression are labeled “non-responsive” at some point — not improving on antidepressants or talk therapy alone. TMS is a safer alternative to ECT, with fewer side effects and higher success rates." },
  { icon: "refresh", t: "Treatment-Resistant OCD", d: "NeuroStar TMS is FDA-cleared to treat OCD — a series of short outpatient sessions that stimulate neural activity in the prefrontal cortex, with high success and few to no side effects." },
];
const steps = [
  ["Mapping", "You stay awake and alert while we perform a motor-threshold test to find your ideal magnetic field strength — a gentle pulse causes a small movement in your thumb, which lets us tailor the treatment to you."],
  ["Treatment", "Your first session runs 18–45 minutes. Many patients describe the sensation as light tapping on the scalp; if anything feels uncomfortable, we adjust it for you."],
  ["After treatment", "There’s no downtime — you can drive yourself home and resume work, family, or whatever your day holds, right away."],
];
const expect = [
  ["Treatment frequency", "5 days a week for 30–36 sessions"],
  ["Duration", "6–9 weeks"],
  ["Session length", "18–45 minutes per session"],
];
const rightFor = [
  { t: "You have depression and haven’t found relief with medication or therapy", icon: "cloud" },
  { t: "You want a non-medicated, non-invasive treatment option", icon: "shield" },
  { t: "You want to avoid the common side effects of medications", icon: "swap" },
  { t: "You’re ready for a treatment plan with multiple sessions", icon: "calendar" },
  { t: "You want a personalized approach with no downtime", icon: "sparkles" },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Julie Stevens", t: "2 months ago", q: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { n: "Cynthia Askew", t: "6 months ago", q: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
  { n: "Joana Yoo", t: "10 months ago", q: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "stacey miller", t: "3 months ago", q: "They put me on the schedule as a new patient within the same week of calling, which never happens, and made sure my insurance was accepted. The provider and staff were very professional and kind." },
  { n: "Jake Sted", t: "2 months ago", q: "The therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day. Hopewell made a huge difference in my life." },
];
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["Glastonbury", "33 Pratt St, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.0462929427076!2d-72.6158734!3d41.7195199!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f7540001%3A0x207d1c58279c2917!2sKristine%20Schlichting!5e0!3m2!1sen!2sus!4v1781754351066!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const faqs = [
  ["What is TMS?", "Transcranial Magnetic Stimulation is a safe, outpatient treatment that uses targeted magnetic pulses (similar to an MRI) to stimulate the brain areas that regulate mood. In depression those areas are often underactive — TMS gently “awakens” those connections to help restore healthy function. We use NeuroStar® Advanced TMS."],
  ["Does it hurt?", "No. You stay awake and alert; most people describe the feeling as light tapping on the scalp. If anything is uncomfortable, we adjust it."],
  ["How many sessions will I need?", "A typical course is 5 days a week for 30–36 sessions over about 6–9 weeks, with each session lasting 18–45 minutes."],
  ["Is there downtime?", "None — no anesthesia or sedation. You can drive yourself home and resume your normal activities immediately."],
  ["What does TMS treat?", "NeuroStar TMS is FDA-cleared for treatment-resistant major depression and OCD."],
  ["Will my insurance cover it?", "We accept most major PPO plans (we don’t accept Medicaid / HUSKY) and will verify your benefits for free."],
];
---

<Base title="TMS Therapy for Depression & OCD in CT | Hopewell Health Solutions" description="NeuroStar® Advanced TMS at Hopewell Health Solutions, Glastonbury & West Hartford CT — FDA-cleared, drug-free relief for treatment-resistant depression & OCD. No downtime. Most insurance accepted.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/treatment-methods/" class="hover:text-azul">Treatments</a> / <span class="text-ink">TMS</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">TMS Therapy · NeuroStar® Advanced TMS · Glastonbury, CT</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">TMS Therapy for Depression &amp; OCD in Connecticut</h1>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <p class="mt-5 text-ink leading-relaxed text-[17px] max-w-xl">A safe, non-invasive, FDA-cleared treatment for people with depression and OCD who haven’t found relief with medication or talk therapy — a cutting-edge way to regain control of your mental health.</p>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8609460447" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 946-0447</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Katrin Moskowitz, DNP, PMHNP-BC</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="See if TMS is right for you" sub="Free, confidential. We’ll verify your benefits and answer your questions." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/Guy%20facing%20the%20horizon.webp" alt="Relief from treatment-resistant depression with TMS in Connecticut" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">When other treatments haven’t worked</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What is TMS?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">TMS is part of our suite of state-of-the-art treatments — a breakthrough technology for mental health conditions that don’t respond to conventional treatment. Transcranial Magnetic Stimulation is a safe, painless, non-invasive outpatient treatment that uses magnetic pulses to stimulate the brain areas affected by depression and OCD, reducing long-term symptoms. It begins with a psychiatric evaluation and brain mapping to target the right area precisely.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">Antidepressants work indirectly through the body. <strong>NeuroStar® Advanced TMS targets the root cause — your brain.</strong> When synapses in the mood-regulating regions become underactive, connections are disrupted and depression sets in. TMS stimulates those inactive synapses, “awakening” the brain to restore its natural function.</p>
      </div>
    </div>
  </section>

  <!-- USES -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">What TMS treats</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">A breakthrough for treatment-resistant conditions</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-2 gap-5">
        {uses.map((u) => (
          <div class="rounded-2xl bg-white border border-line p-7">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={u.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl text-ink leading-tight">{u.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{u.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- EMPATHY CTA BAND -->
  <section class="relative">
    <img src="/Assets/couple%20hugging.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-ink/80"></div>
    <div class="relative mx-auto max-w-3xl px-5 py-20 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-white/70">There is another way</p>
      <h2 class="mt-3 font-display text-3xl sm:text-4xl text-white leading-snug">Medication after medication — and still no relief?</h2>
      <p class="mt-4 text-white/85 text-lg">Treatment-resistant depression is more common than you think — and it isn’t the end of the road. TMS offers a drug-free path forward, with no downtime.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">See if TMS is right for you</a>
        <a href="tel:8609460447" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 946-0447</a>
      </div>
    </div>
  </section>

  <!-- PROCESS -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A simple, comfortable process</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">The TMS treatment process</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-5">
        {steps.map(([t, d], i) => (
          <div class="rounded-2xl bg-crema border border-line p-7">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-azul text-white font-display text-lg">{i + 1}</span>
            <h3 class="mt-4 font-display text-xl text-ink">{t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- STATS BAND -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-5xl px-5 py-20">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.18em] text-gold-light">Proven results</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-white">Real, measurable relief</h2>
      </div>
      <div class="mt-12 grid sm:grid-cols-2 gap-6">
        <div class="rounded-2xl border border-white/15 bg-white/[0.06] p-10 text-center">
          <span class="inline-grid h-12 w-12 place-items-center rounded-full bg-white/10 text-gold-light"><Icon name="heart" class="h-6 w-6" /></span>
          <p class="mt-5 font-display text-6xl sm:text-7xl text-gold-light leading-none">83%</p>
          <div class="mx-auto mt-4 h-px w-10 bg-gold"></div>
          <p class="mt-4 text-white/85 leading-relaxed">of patients who completed TMS experienced relief from depression</p>
        </div>
        <div class="rounded-2xl border border-white/15 bg-white/[0.06] p-10 text-center">
          <span class="inline-grid h-12 w-12 place-items-center rounded-full bg-white/10 text-gold-light"><Icon name="sparkles" class="h-6 w-6" /></span>
          <p class="mt-5 font-display text-6xl sm:text-7xl text-gold-light leading-none">62%</p>
          <div class="mx-auto mt-4 h-px w-10 bg-gold"></div>
          <p class="mt-4 text-white/85 leading-relaxed">achieved full remission — complete relief from depression</p>
        </div>
      </div>
      <div class="mt-10 flex flex-wrap items-center justify-center gap-3">
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-semibold"><Icon name="shield" class="h-4 w-4 text-gold-light" />FDA-cleared</span>
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-semibold"><Icon name="refresh" class="h-4 w-4 text-gold-light" />No downtime</span>
        <span class="inline-flex items-center gap-2 rounded-full bg-white/10 px-4 py-2 text-sm font-semibold"><Icon name="brain" class="h-4 w-4 text-gold-light" />Drug-free &amp; non-invasive</span>
      </div>
      <p class="mt-8 text-center text-xs text-white/55">Source: NeuroStar® published clinical data.</p>
    </div>
  </section>

  <!-- WHAT TO EXPECT (full-width image) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">What to expect</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Your TMS schedule</h2>
        <p class="mt-3 text-muted">A full course of NeuroStar® Advanced TMS is delivered in short, consistent sessions — right here at our Glastonbury office.</p>
      </div>
      <img src="/Assets/TMS/neurostar-tms.webp" alt="NeuroStar Advanced TMS at Hopewell Health Solutions — treatment frequency, duration & session length" loading="lazy" class="mt-10 w-full rounded-2xl border border-line shadow-sm" />
      <div class="mt-6 grid sm:grid-cols-3 gap-4">
        {expect.map(([t, d]) => (
          <div class="flex items-center gap-3 rounded-xl bg-white border border-line p-5">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name="calendar" class="h-5 w-5" /></span>
            <div><span class="block font-semibold text-ink leading-tight">{t}</span><span class="block text-sm text-muted">{d}</span></div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- IS TMS RIGHT FOR YOU -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/guy%20thinking%20worried.webp" alt="Someone considering whether TMS is right for them" loading="lazy" class="rounded-2xl w-full h-72 lg:h-[28rem] object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Make the right choice</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">Is TMS treatment right for you?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">TMS may be a great fit if any of these resonate:</p>
        <ul class="mt-5 space-y-3">
          {rightFor.map((r) => (
            <li class="flex items-start gap-3">
              <span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={r.icon} class="h-4 w-4" /></span>
              <span class="text-ink leading-snug pt-1">{r.t}</span>
            </li>
          ))}
        </ul>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Patients rate Hopewell Health Solutions “the best in the area” · As featured on Eyewitness News 3</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
