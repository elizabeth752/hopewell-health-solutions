---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";

const heroUsps = [
  { icon: "brain", t: "Clarify a diagnosis through brain–behavior testing" },
  { icon: "users", t: "Children, adolescents & adults — pediatric neuropsych specialty" },
  { icon: "clipboard", t: "Comprehensive, customized reports with clear recommendations" },
  { icon: "shield", t: "Led by a licensed psychologist with advanced neuropsych training" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const domains = [
  { t: "Cognitive functioning", icon: "brain" },
  { t: "Attention", icon: "bolt" },
  { t: "Executive functioning", icon: "clipboard" },
  { t: "Learning", icon: "sparkles" },
  { t: "Visual-motor skills", icon: "swap" },
  { t: "Social skills", icon: "users" },
  { t: "Emotional functioning", icon: "heart" },
  { t: "Academic achievement", icon: "star" },
];
const considerations = ["Learning disabilities (including dyslexia)", "Autism Spectrum Disorders", "ADHD", "Anxiety", "Depression"];
const steps = [
  ["Initial consultation", "Parents meet with a pediatric neuropsychologist to discuss concerns. We take a thorough developmental, psychological, and learning history — and you’ll have the chance to share your child’s strengths and ask questions about the process."],
  ["Testing sessions", "Expect 4–6 hours of testing over 1–2 days, one-on-one with our neuropsychologist. Most activities are interactive and children don’t mind them. Depending on age, your child may complete rating scales — and with consent, parents and teachers complete questionnaires too."],
  ["Feedback session", "About 60 minutes reviewing results together (with your child, depending on age and maturity). We discuss strengths and weaknesses, share any diagnoses, and offer recommendations — with ample time for your questions."],
  ["Comprehensive report", "You receive a comprehensive neuropsychological report — background, test results, a summary of the evaluation, and tailored recommendations for home, school, and the community."],
];
const psychAreas = ["ADHD", "Autism", "Depression", "Anxiety", "Mood disorders", "Learning disability", "Personality disorders", "Personality testing", "Memory & executive functioning"];
const evals = [
  { t: "Child & Adolescent", d: "A comprehensive evaluation that diagnoses and — most importantly — builds an individualized treatment plan with home, therapeutic, and school-based solutions. We work with the school’s special-education staff to implement it.", body: ["Attention Deficit Disorder", "Learning Disorders (including Non-Verbal)", "Anxiety & Depression", "Behavioral Disorders", "Personality Disorders", "Asperger’s / High-Functioning Autism"] },
  { t: "Adult", d: "Assessment that pinpoints the specific areas to target in treatment, giving you and your providers a clear, data-backed direction.", body: ["Attention Deficit Disorder", "Learning Disorders", "Personality Disorders", "Depression", "Anxiety"] },
];
const reactions = [
  { n: "A.S.", age: "age 27", q: "After all these years of failing and frustration, the testing indicated what type of ADHD I had — and through treatment and medication, I finally passed my boards." },
  { n: "S.R.", age: "age 52", q: "The testing at HHS allowed me to finally understand why my son was struggling in school and how to help him." },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["Glastonbury", "33 Pratt St, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.0462929427076!2d-72.6158734!3d41.7195199!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f7540001%3A0x207d1c58279c2917!2sKristine%20Schlichting!5e0!3m2!1sen!2sus!4v1781754351066!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const faqs = [
  ["What ages do you test?", "Our pediatric neuropsychology evaluations focus on ages 8–18, and we also offer evaluations for adults and young adults, plus psychoeducational evaluations including IEEs (Independent Educational Evaluations)."],
  ["How long does testing take?", "Plan on 4–6 hours of testing over 1–2 days, one-on-one with our neuropsychologist, followed by a ~60-minute feedback session once results are scored."],
  ["What conditions can testing clarify?", "Learning disabilities (including dyslexia), Autism Spectrum Disorders, ADHD, anxiety, depression, mood and personality concerns, and memory or executive-functioning deficits."],
  ["Will you work with my child’s school?", "Yes. When appropriate we can conduct a school observation and, if requested, attend a PPT meeting to share findings and recommendations with the school team."],
  ["Why might I get testing before medication?", "Testing provides objective data for an accurate assessment — a baseline that helps target treatment and, when relevant, informs psychiatric medication decisions."],
];
---

<Base title="Neuropsychological & Psychological Testing in CT | Hopewell Health Solutions" description="Neuropsychological & psychological testing at Hopewell Health Solutions, Glastonbury CT — evaluations for ADHD, autism, learning disabilities, anxiety & more. Children, teens & adults. Led by a pediatric neuropsychologist.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/treatment-methods/" class="hover:text-azul">Treatments</a> / <span class="text-ink">Neuropsychological Testing</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Neuropsychological &amp; Psychological Testing · Glastonbury, CT</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Neuropsychological &amp; Psychological Testing in Connecticut</h1>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8609460447" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 946-0447</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Laura Miller, PhD</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="Request a testing consultation" sub="Free, confidential. We’ll help you start the evaluation process." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/teen%20smiling.webp" alt="Neuropsychological evaluation at Hopewell Health Solutions, Glastonbury CT" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Understanding brain–behavior relationships</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What is a neuropsychological evaluation?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">A neuropsychological evaluation is conducted by a licensed psychologist with advanced training in neuropsychology, to better understand how the brain and behavior relate. Evaluations help clarify diagnoses, identify areas of strength and areas for growth, and deliver targeted recommendations for home, school, and the community.</p>
      </div>
    </div>
  </section>

  <!-- DOMAINS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A complete picture</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">What the evaluation examines</h2>
      </div>
      <div class="mt-10 grid grid-cols-2 lg:grid-cols-4 gap-4">
        {domains.map((d) => (
          <div class="flex items-center gap-3 rounded-xl bg-white border border-line p-4">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={d.icon} class="h-5 w-5" /></span>
            <span class="text-sm font-semibold text-ink leading-tight">{d.t}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WOULD THIS HELP (text left / image right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="lg:order-2"><img src="/Assets/tweens-1729660767703.webp" alt="A child who may benefit from a neuropsychological evaluation" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" /></div>
      <div class="lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">When testing helps</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">Would this be helpful for my child?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">An evaluation is often conducted when there are questions about learning, development, behavior, mood, or social functioning. It can help answer diagnostic questions around:</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {considerations.map((c) => <span class="rounded-full bg-azul-light px-3 py-1 text-sm font-semibold text-azul">{c}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- STEPS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A simplified process</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">What’s involved in an evaluation</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 gap-5">
        {steps.map(([t, d], i) => (
          <div class="rounded-2xl bg-white border border-line p-7">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-azul text-white font-display text-lg">{i + 1}</span>
            <h3 class="mt-4 font-display text-xl text-ink leading-tight">{t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{d}</p>
          </div>
        ))}
      </div>
      <div class="mt-6 rounded-2xl bg-white border border-azul/30 p-7 text-center">
        <h3 class="font-display text-xl text-ink">Continued consultation with families, educators &amp; providers</h3>
        <p class="mt-2 text-sm text-muted max-w-2xl mx-auto">When appropriate we can conduct a school observation, and — if requested — attend a PPT meeting to share findings and recommendations directly with your child’s school team.</p>
      </div>
    </div>
  </section>

  <!-- PSYCHOLOGICAL TESTING (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/Comprehensive%20Tailored%20Care.webp" alt="Comprehensive, customized psychological testing reports" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Comprehensive, customized reports</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">Psychological testing</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Think of testing like getting bloodwork for a doctor’s visit — it provides a baseline of behavior, a target for treatment, and a way to monitor progress. Using the Q-interactive digital platform, we deliver customized reports with clear visuals (graphs and tables) and tailored recommendations. Testing can also be important before considering psychiatric medication, providing data for an accurate assessment.</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {psychAreas.map((a) => <span class="rounded-full bg-crema border border-line px-3 py-1 text-sm text-ink">{a}</span>)}
        </div>
        <a href="tel:8609460447" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-azul hover:text-azul-dark transition">Request our testing brochure <Icon name="arrow" class="h-4 w-4" /></a>
      </div>
    </div>
  </section>

  <!-- EVALUATIONS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Tailored to every stage</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Our evaluations</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-2 gap-5">
        {evals.map((e) => (
          <div class="rounded-2xl bg-white border border-line p-7">
            <h3 class="font-display text-2xl text-ink">{e.t}</h3>
            <p class="mt-3 text-ink leading-relaxed text-[15px]">{e.d}</p>
            <div class="mt-4 grid sm:grid-cols-2 gap-x-6 gap-y-1.5">
              {e.body.map((b) => <p class="flex items-start gap-2 text-sm text-muted"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-azul"></span><span class="leading-snug">{b}</span></p>)}
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- DR. MILLER -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16 grid md:grid-cols-[280px_1fr] gap-8 lg:gap-12 items-center">
      <img src="/Assets/Team%20Members/laura-miller-phd.webp" alt="Laura Miller, PhD — Licensed Psychologist" loading="lazy" class="w-full max-w-xs mx-auto md:max-w-none h-80 md:h-96 rounded-2xl object-cover object-top shadow-sm" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Meet your evaluator</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Laura Miller, PhD</h2>
        <p class="mt-2 text-sm font-semibold uppercase tracking-wide text-azul">Licensed Psychologist · Advanced Training in Pediatric Neuropsychology</p>
        <div class="mt-4 h-px w-16 bg-gold"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Dr. Miller offers comprehensive neuropsychological evaluations for children, adolescents, and young adults, as well as psychoeducational evaluations — including Independent Educational Evaluations (IEEs). She works closely with families and schools to turn results into a clear, actionable plan.</p>
      </div>
    </div>
  </section>

  <!-- PATIENTS' REACTIONS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">In their words</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Patients’ reactions to testing</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-2 gap-6">
        {reactions.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <span class="text-yellow-400 text-lg">★★★★★</span>
            <blockquote class="mt-4 text-ink leading-relaxed text-[17px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0)}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.age}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Most major PPO plans accepted</h2>
        <p class="mt-3 text-muted max-w-xl">We’re in-network with most major PPO plans (we don’t accept Medicaid / HUSKY). Our team verifies your benefits at no cost — and will let you know what testing coverage looks like before you commit.</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <!-- LOCATIONS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care across Connecticut</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Our locations</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {locations.map(([city, addr, map]) => (
          <div class="overflow-hidden rounded-2xl bg-white border border-line">
            <iframe src={map} title={`Map — Hopewell Health Solutions, ${city}`} class="h-40 w-full border-0 grayscale-[0.2]" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
            <div class="flex gap-3 p-5">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-azul-light text-azul"><Icon name="pin" class="h-5 w-5" /></span>
              <div><h3 class="font-display text-lg text-ink leading-tight">{city}</h3><p class="mt-1 text-sm text-muted">{addr}</p></div>
            </div>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-muted">Reach us at <a href="tel:8609460447" class="text-azul font-semibold">(860) 946-0447</a> · <a href="mailto:hhs4help@gmail.com" class="text-azul font-semibold">hhs4help@gmail.com</a></p>
    </div>
  </section>

  <!-- FAQ -->
