---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";

const heroUsps = [
  { icon: "users", t: "Personalized evaluation for children, teens & adults" },
  { icon: "clipboard", t: "A detailed interview with a Licensed PA/NP" },
  { icon: "brain", t: "Rating scales + a remote computerized assessment" },
  { icon: "compass", t: "Clear, personalized treatment recommendations" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const combine = [
  { t: "A detailed clinical interview", d: "A one-on-one interview with a Licensed PA/NP to understand your history and how symptoms show up in daily life.", icon: "clipboard" },
  { t: "Validated rating scales", d: "Standardized rating scales that capture how symptoms present across different settings.", icon: "star" },
  { t: "Remote computerized assessment", d: "An objective, computerized measure of attention you complete securely from home.", icon: "brain" },
];
const whoFor = [
  { icon: "sparkles", t: "Children", d: "Clarity around focus, behavior, and learning — with recommendations for home and school." },
  { icon: "compass", t: "Teens", d: "Understand what’s behind the struggles and build a plan that fits this stage of life." },
  { icon: "users", t: "Adults", d: "Answers after years of questions — and a clear, data-backed path forward." },
];
const steps = [
  ["In-office appointment with your provider", "Your evaluation begins with an in-office appointment with your provider to review your history and concerns."],
  ["Computerized assessment from home", "You’ll receive a secure link by email and can complete the computerized portion from the comfort of your home. The computerized portion is $99, paid by the patient."],
  ["Results & next steps", "One of our team members will call you to schedule a follow-up with your provider to review your results and discuss next steps."],
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Donald Krusinski", t: "a year ago", q: "I'm under Tracy Sibley's care, and she is a kind and helpful person. She is so patient, understanding, and always very supportive. She is helping me through a difficult journey — I know I will be alright because of her excellent care!" },
  { n: "Joana Yoo", t: "10 months ago", q: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "Lauren Irace", t: "8 months ago", q: "I am very grateful for the care I am receiving at Hopewell Health Solutions. Everyone I have interacted with is extremely professional, friendly, and easy to talk to. I also appreciate the flexibility and willingness to accommodate additional support when needed. I highly recommend this practice to anyone seeking support." },
  { n: "Cynthia Askew", t: "6 months ago", q: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
  { n: "Jake Sted", t: "2 months ago", q: "The therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day. Hopewell made a huge difference in my life." },
];
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["Glastonbury", "33 Pratt St, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.0462929427076!2d-72.6158734!3d41.7195199!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f7540001%3A0x207d1c58279c2917!2sKristine%20Schlichting!5e0!3m2!1sen!2sus!4v1781754351066!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const faqs = [
  ["What ages do you evaluate?", "Our ADHD evaluations are designed for children, teens, and adults."],
  ["What’s the first step?", "An in-office appointment with your provider to review your history and concerns."],
  ["Where does the computerized portion take place?", "You’ll receive a secure link by email and can complete it from the comfort of your home."],
  ["How much does the computerized portion cost?", "The computerized portion is $99, paid by the patient."],
  ["What happens after the test?", "One of our team members will call you to schedule a follow-up with your provider to review your results and discuss next steps."],
  ["How is this different from a checklist?", "Our evaluations go beyond a simple checklist — combining a detailed clinical interview, rating scales, and a computerized assessment to understand how symptoms affect daily life and distinguish ADHD from other conditions with similar signs."],
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(([q, a]) => ({ "@type": "Question", name: q, acceptedAnswer: { "@type": "Answer", text: a } })),
};
---

<Base title="ADHD Testing & Evaluation in CT | Hopewell Health Solutions" description="ADHD testing at Hopewell Health Solutions in Glastonbury, Westbrook & West Hartford, CT — personalized evaluations for children, teens & adults. Clinical interview, rating scales & a computerized assessment. Clear, tailored recommendations.">
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/treatment-methods/" class="hover:text-azul">Treatments</a> / <span class="text-ink">ADHD Testing</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">ADHD Testing · Glastonbury, Westbrook &amp; West Hartford, CT · Children, teens &amp; adults</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">ADHD Testing &amp; Evaluation in Connecticut</h1>
          <p class="mt-3 font-display text-xl text-azul italic">Get clarity — and a clear path forward.</p>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8607351448" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 735-1448</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Katrin Moskowitz, DNP, PMHNP-BC</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="Schedule your ADHD evaluation" sub="Free, confidential. We’ll help you book your first appointment." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/tweens-1729660767703.webp" alt="ADHD assessment for children, teens and adults at Hopewell Health Solutions, Connecticut" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Beyond a simple checklist</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">ADHD assessment &amp; treatment</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">At Hopewell Health Solutions, we know that getting the right ADHD diagnosis is the first step toward effective treatment. Our evaluations are designed for children, teens, and adults — and go beyond a simple checklist.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">This thorough process helps us understand how symptoms affect daily life and distinguish ADHD from other conditions with similar signs. The result? Clear, personalized treatment recommendations for you or your loved one.</p>
      </div>
    </div>
  </section>

  <!-- WHAT WE COMBINE -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A complete picture</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">What our evaluation combines</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-3 gap-5">
        {combine.map((c) => (
          <div class="rounded-2xl bg-white border border-line p-7">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={c.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl text-ink leading-snug">{c.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{c.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">At every age</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Who ADHD testing is for</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-3 gap-5">
        {whoFor.map((w) => (
          <div class="rounded-2xl bg-crema border border-line p-7">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={w.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl text-ink">{w.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{w.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUOTE BAND -->
  <section class="relative">
    <img src="/Assets/full%20team%20happy.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-ink/80"></div>
    <div class="relative mx-auto max-w-3xl px-5 py-20 text-center">
      <p class="font-display text-2xl sm:text-3xl text-white italic leading-snug">“Getting the right ADHD diagnosis is the first step toward effective treatment.”</p>
    </div>
  </section>

  <!-- HOW IT WORKS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Simple &amp; clear</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">How it works</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-3 gap-5">
        {steps.map(([t, d], i) => (
          <div class="rounded-2xl bg-white border border-line p-7">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-azul text-white font-display text-lg">{i + 1}</span>
            <h3 class="mt-4 font-display text-lg text-ink leading-tight">{t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{d}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-sm text-muted">The computerized portion is a $99 cost to the patient.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-azul px-7 py-3.5 font-semibold text-white hover:bg-azul-dark transition">Schedule your ADHD evaluation</a>
        <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg border border-azul px-7 py-3.5 font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
      </div>
    </div>
  </section>

  <!-- DR. CURTIS -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16 grid md:grid-cols-[280px_1fr] gap-8 lg:gap-12 items-center">
      <img src="/Assets/Team%20Members/shawn-curtis-psy-d.webp" alt="Shawn Curtis, Psy.D. — Licensed Clinical Psychologist" loading="lazy" class="w-full max-w-xs mx-auto md:max-w-none h-80 md:h-96 rounded-2xl object-cover object-top shadow-sm" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Meet your evaluator</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Shawn Curtis, Psy.D.</h2>
        <p class="mt-2 text-sm font-semibold uppercase tracking-wide text-azul">Licensed Clinical Psychologist · Psychological Testing &amp; Assessment</p>
        <div class="mt-4 h-px w-16 bg-gold"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Dr. Curtis provides thorough psychological testing and assessment for children, adolescents, and adults — including ADHD evaluations, diagnostic clarification, and neurocognitive screening. Every evaluation ends with a clear written report, personalized recommendations, and a feedback session to walk through what it means for you.</p>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Clients describe feeling genuinely heard · As featured on Eyewitness News 3</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Most major PPO plans accepted</h2>
        <p class="mt-3 text-muted max-w-xl">We’re in-network with most major PPO plans (we don’t accept Medicaid / HUSKY). Our team verifies your benefits at no cost — and will let you know what your evaluation coverage looks like before you commit. (The computerized portion is a $99 cost to the patient.)</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <!-- LOCATIONS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care across Connecticut</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Our locations</h2>
        <p class="mt-3 text-muted">In person at six Connecticut offices — plus virtual visits statewide.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {locations.map(([city, addr, map]) => (
          <div class="overflow-hidden rounded-2xl bg-white border border-line">
            <iframe src={map} title={`Map — Hopewell Health Solutions, ${city}`} class="h-40 w-full border-0 grayscale-[0.2]" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
            <div class="flex gap-3 p-5">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-azul-light text-azul"><Icon name="pin" class="h-5 w-5" /></span>
              <div><h3 class="font-display text-lg text-ink leading-tight">{city}</h3><p class="mt-1 text-sm text-muted">{addr}</p></div>
            </div>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-muted">Reach us at <a href="tel:8607351448" class="text-azul font-semibold">(860) 735-1448</a> · <a href="mailto:hhs4help@gmail.com" class="text-azul font-semibold">hhs4help@gmail.com</a></p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-crema">
    <div class="mx-auto max-w-3xl px-5 py-16">
      <h2 class="font-display text-3xl text-ink text-center">ADHD testing — common questions</h2>
      <div class="mt-8 space-y-3">
        {faqs.map(([q, a]) => (
          <details class="group rounded-xl bg-white border border-azul/30 p-5 open:border-azul open:bg-azul-light/30 hover:border-azul transition">
            <summary class="flex justify-between items-center cursor-pointer font-display text-lg text-ink list-none">{q}<span class="text-azul text-xl group-open:rotate-45 transition">+</span></summary>
            <p class="mt-3 text-ink leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ServicesGrid bg="white" />

