---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";

const T = "/Assets/therapeutic-treatments/";
const heroUsps = [
  { icon: "sparkles", t: "An array of evidence-based & holistic therapies" },
  { icon: "users", t: "For clients aged 4 and older" },
  { icon: "swap", t: "Tailored to you — never one-size-fits-all" },
  { icon: "cloud", t: "In person & via telehealth across Connecticut" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const treatments = [
  { t: "Dialectical Behavior Therapy (DBT)", img: T + "Talk%20therapy.webp", d: "A type of talk therapy that uses a cognitive-behavioral approach, emphasizing the psychosocial aspects of treatment.", note: "Includes SPACE training with Dr. Schwartz." },
  { t: "Cognitive Behavioral Therapy (CBT)", icon: "brain", d: "A psycho-social intervention that improves mental health by challenging and changing unhelpful cognitive distortions and behaviors, improving emotional regulation, and developing personal coping strategies to solve current problems." },
  { t: "Solutions-Focused Therapy", img: T + "solution%20focused.webp", d: "A goal-directed, collaborative approach to therapeutic change, conducted through direct observation of clients’ responses to a series of precisely constructed questions." },
  { t: "Video Self-Modeling", icon: "refresh", d: "A form of observational learning in which individuals watch themselves performing a behavior successfully on video, then imitate the targeted behavior.", note: "Examples include video self-monitoring for behavior and for restrictive eating." },
  { t: "Pet-Assisted Therapy", img: T + "dog.webp", d: "Animal-assisted therapy works alongside traditional therapy. Animals — primarily dogs — provide calm, comfort, and safety, helping build self-worth and trust, stabilize emotions, and improve communication, self-regulation, and socialization." },
  { t: "Accelerated Resolution Therapy (ART)", icon: "bolt", d: "A briefer version of EMDR created to help people who have experienced trauma. The protocol brings up original traumatic experiences and changes the way that information is ultimately stored.", link: "/media/", linkText: "Watch helpful videos" },
  { t: "Walk-Talk Therapy", img: T + "walk.webp", d: "Therapy that takes place outside, walking, instead of sitting in an office — a more relaxed environment, with added mental and physical health benefits." },
  { t: "Outdoor Nature-Assisted Therapy", icon: "sun", d: "An intervention to treat, hasten recovery, and rehabilitate, with the core principle that therapy involves plants, natural materials, and/or the outdoor environment." },
  { t: "Play Therapy", icon: "sparkles", d: "Primarily used to help children ages 3–12 explore their lives and express repressed thoughts and emotions through play, in a safe playroom — learning to express themselves in healthier ways, build empathy, and solve problems positively." },
  { t: "Telehealth", img: T + "telehealth.webp", d: "Online therapy (telemental health): a therapist or counselor provides counseling and support over the internet via video conferencing, online chat, email, or phone." },
  { t: "Meditation", img: T + "meditaiton.webp", d: "A practice that uses a technique — such as mindfulness, or focusing the mind on a particular object, thought, or activity — to train attention and awareness and achieve a mentally clear, emotionally calm, and stable state." },
  { t: "Mindfulness", icon: "cloud", d: "The psychological process of purposely bringing your attention to experiences in the present moment without judgment, developed through meditation and other training.", note: "See our recommended mindfulness apps below." },
  { t: "Yoga Therapy", icon: "sun", d: "The specific application of yogic tools — postures and exercises, breath work, meditation techniques, and more — to address an individual’s physical, mental, and emotional needs." },
  { t: "Exposure Therapy", icon: "shield", d: "A behavior-therapy technique to treat anxiety disorders by exposing the patient to the anxiety source or its context (without intending any danger), helping them overcome their anxiety or distress." },
  { t: "Biofeedback", icon: "bolt", d: "The process of gaining greater awareness of the body’s physiological functions using instruments, with the goal of learning to manipulate the body’s systems at will." },
  { t: "Systematic Desensitization", icon: "refresh", d: "A behavioral therapy based on classical conditioning that removes the fear response of a phobia and substitutes a relaxation response, gradually, through counter-conditioning." },
  { t: "Couples Therapy — Gottman Method", img: T + "couples%20gott.webp", d: "An approach to couples therapy that includes a thorough assessment of the relationship and integrates research-based interventions grounded in the Sound Relationship House Theory." },
  { t: "Trauma-Informed Individual Therapy", img: T + "trauma%20informed.webp", d: "A trauma-informed approach with awareness of the widespread impact of trauma on life experience and relationships — recognizing trauma’s role in a person’s outlook, emotions, and behavior." },
  { t: "Trauma-Informed Group Therapy (TFTG)", icon: "users", d: "Trauma Focus Group Therapy emphasizes two cognitive-behavioral methods — prolonged exposure and cognitive restructuring — to process each member’s trauma. Each member has the opportunity to recount their story as others listen." },
];
const apps = [
  ["Buddhify", T + "budify.webp"],
  ["Calm", T + "calm.webp"],
  ["Insight Timer", T + "insight.webp"],
  ["Headspace", T + "headspace.webp"],
];
---

<Base title="HHS Therapeutic Treatments in CT | Hopewell Health Solutions" description="An array of therapeutic treatments at Hopewell Health Solutions, Glastonbury & West Hartford CT — DBT, CBT, EMDR/ART, pet & nature therapy, play therapy, telehealth, mindfulness & more, for ages 4+.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/treatment-methods/" class="hover:text-azul">Treatments</a> / <span class="text-ink">HHS Therapeutic Treatments</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">HHS Therapeutic Treatments · Glastonbury, CT · Ages 4+</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">HHS Therapeutic Treatments</h1>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <p class="mt-5 text-ink leading-relaxed text-[17px] max-w-xl">Nearly 20% of adults receive treatment for mental health conditions — and many children and teens do, too. We offer a wide array of evidence-based and holistic therapies for clients aged 4 and older, matched to what each person needs.</p>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8609460447" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 946-0447</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Kristine Schlichting, PhD</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="Find the right therapy" sub="Free, confidential. We’ll match you to the approach that fits." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- TREATMENTS GRID -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Our toolbox</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Therapies we offer</h2>
        <p class="mt-3 text-muted">From proven clinical methods to whole-person, holistic approaches — your clinician draws on the right tools for you.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {treatments.map((t) => (
          <div class="flex flex-col overflow-hidden rounded-2xl bg-white border border-line shadow-sm">
            {t.img
              ? <img src={t.img} alt={t.t} loading="lazy" class="h-40 w-full object-cover" />
              : <div class="grid h-40 place-items-center bg-azul-light"><Icon name={t.icon} class="h-12 w-12 text-azul" /></div>}
            <div class="flex flex-1 flex-col p-6">
              <h3 class="font-display text-lg text-ink leading-snug">{t.t}</h3>
              <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{t.d}</p>
              {t.note && <p class="mt-3 text-xs font-semibold text-azul">{t.note}</p>}
              {t.link && <a href={t.link} class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-azul hover:text-azul-dark transition">{t.linkText} <Icon name="arrow" class="h-4 w-4" /></a>}
            </div>
          </div>
        ))}
      </div>

      <!-- Mindfulness apps -->
      <div class="mt-8 rounded-2xl bg-crema border border-line p-7 text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">For mindfulness practice</p>
        <h3 class="mt-2 font-display text-2xl text-ink">Apps we recommend</h3>
        <div class="mt-6 flex flex-wrap items-center justify-center gap-x-10 gap-y-5">
          {apps.map(([name, img]) => (
            <div class="flex flex-col items-center gap-2">
              <img src={img} alt={name} loading="lazy" class="h-12 w-12 rounded-xl object-contain" />
              <span class="text-sm font-semibold text-ink">{name}</span>
            </div>
          ))}
        </div>
      </div>
    </div>
  </section>

  <ServicesGrid bg="crema" />

  <!-- CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">Find the right therapy for you</h2>
      <p class="mt-4 text-white/85 text-lg">Not sure where to start? Our team will help match you — or your child — to the approach that fits best. Reach out to Hopewell Health Solutions today, confidentially and with no pressure.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">Verify Your Insurance</a>
        <a href="tel:8609460447" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 946-0447</a>
        <a href="mailto:hhs4help@gmail.com" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition">Email Us</a>
      </div>
      <p class="mt-6 text-xs text-white/60">Not a substitute for emergency care. If you’re in crisis, call or text 988, or call 911.</p>
    </div>
  </section>

  <Footer />
</Base>
