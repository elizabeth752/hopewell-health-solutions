---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";

const heroUsps = [
  { icon: "shield", t: "FDA-approved esketamine nasal spray" },
  { icon: "bolt", t: "Relief in as little as 24 hours" },
  { icon: "heart", t: "Given in-office under medical supervision" },
  { icon: "brain", t: "For treatment-resistant depression & depression with suicidal thoughts" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const whoFor = [
  "You have major depression that hasn’t responded to two or more antidepressants",
  "You’re experiencing depression with suicidal thoughts",
  "You want a treatment with a different mechanism than daily pills",
  "You can attend supervised in-office sessions with a ride home",
];
const L = "/Assets/Media%20Appearances/";
const press = [
  { outlet: "Hartford Courant", logo: L + "hartford.webp", date: "Feb 2023", title: "Hopewell opens first privately owned IOP mental health clinic in Glastonbury", href: "https://www.courant.com/2023/02/24/hopewell-solutions-opens-first-privately-owned-iop-mental-health-clinic-in-glastonbury/" },
  { outlet: "Hartford Business Journal", logo: L + "hbj-logo-v3.png", date: "Honoree", title: "Kristine Schlichting — recognized leader in behavioral health", href: "https://hartfordbusiness.com/honoree/kristine-schlichting/" },
  { outlet: "FOX61", logo: L + "fox61.png", date: "2023", title: "Glastonbury psychologist is helping teen girls and new moms find support", href: "https://www.fox61.com/article/news/local/outreach/awareness-months/glastonbury-psychologist-is-helping-teen-girls-and-new-moms-find-support/520-84d3fd3f-1cec-40bc-9d4c-65f7b6a4d2e9" },
  { outlet: "WFSB · Kara’s Cures", logo: L + "wfsb.avif", date: "Feb 2023", title: "Teen mental health crisis", href: "https://www.wfsb.com/video/2023/02/27/karas-cures-teen-mental-health-crisis/" },
  { outlet: "WFSB · Kara’s Cures", logo: L + "wfsb.avif", date: "Feb 2023", title: "How to help improve your teen’s mental health", href: "https://www.wfsb.com/video/2023/02/27/karas-cures-how-help-improve-your-teens-mental-health/" },
  { outlet: "IssueWire", logo: L + "issuewire.webp", date: "Feature", title: "Dr. Bido Aguessy: holistic approaches in psychology & spiritual care at Hopewell", href: "https://www.issuewire.com/dr-bido-aguessy-pioneering-holistic-approaches-in-psychology-and-spiritual-care-at-hopewell-health-solutions-1809193551604743" },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Cynthia Askew", t: "6 months ago", q: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
];
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["Glastonbury", "33 Pratt St, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.0462929427076!2d-72.6158734!3d41.7195199!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f7540001%3A0x207d1c58279c2917!2sKristine%20Schlichting!5e0!3m2!1sen!2sus!4v1781754351066!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const faqs = [
  ["Is Spravato the same as ketamine?", "Spravato is esketamine — a component of ketamine — FDA-approved as a nasal spray specifically for treatment-resistant depression."],
  ["How fast does it work?", "Some people notice improvement in as little as 24 hours, with continued benefit over a treatment course."],
  ["Do I need a ride home?", "Yes — because of short-term effects you can’t drive after a session, but you can resume normal activities the next day."],
  ["Is it supervised?", "Always — Spravato is administered in our office and you’re monitored for about two hours afterward, in a certified setting (a federal safety requirement)."],
  ["Will my insurance cover it?", "Most major plans cover Spravato for treatment-resistant depression. We’ll verify your benefits for free."],
];
---

<Base title="Spravato® for Depression in CT | Hopewell Health Solutions" description="Spravato® (esketamine) at Hopewell Health Solutions, Glastonbury, Westbrook & West Hartford CT — FDA-approved for treatment-resistant depression, given in-office under supervision. Relief in as little as 24 hours.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/treatment-methods/" class="hover:text-azul">Treatments</a> / <span class="text-ink">Spravato®</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Spravato® · Esketamine Nasal Spray · Glastonbury, CT</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Spravato® (Esketamine) for Treatment-Resistant Depression</h1>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <p class="mt-5 text-ink leading-relaxed text-[17px] max-w-xl">When depression hasn’t lifted despite antidepressants, Spravato® offers a different mechanism — and, for many, faster relief.</p>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8607351448" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 735-1448</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Katrin Moskowitz, DNP, PMHNP-BC</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="Ask about Spravato" sub="Free, confidential. We’ll check your eligibility and benefits." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/Guy%20facing%20the%20horizon.webp" alt="Relief from treatment-resistant depression with Spravato in Connecticut" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A genuinely different option</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What is Spravato?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Spravato® is a prescription nasal spray containing esketamine, FDA-approved for treatment-resistant depression — depression that hasn’t responded to traditional medications — and for depressive symptoms with suicidal ideation. Treatment-resistant depression affects roughly <strong>30% of people</strong> with major depressive disorder.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">Unlike a daily pill that circulates through your whole body, esketamine acts on the brain’s <strong>glutamate system</strong>, helping to rapidly restore the connections involved in mood — which is why some people feel improvement far sooner than with standard antidepressants.</p>
      </div>
    </div>
  </section>

  <!-- WHAT TO EXPECT & SAFETY (text left / image right) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="lg:order-2"><img src="/Assets/Comprehensive%20Tailored%20Care.webp" alt="Spravato administered in-office under medical supervision at Hopewell Health Solutions" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" /></div>
      <div class="lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Cared for, every step</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What a visit is like — and why it’s safe</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">You self-administer the nasal spray in our office under medical supervision, then we monitor you for about two hours to make sure you’re safe and comfortable. Because of short-term effects, you’ll need a ride home — but by the next morning you can typically resume everyday activities.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">Esketamine can cause short-term effects like dizziness or dissociation, so it’s only given in a certified, monitored setting (a federal safety requirement). That supervision is exactly why it’s safe — you’re watched closely throughout and cleared before you leave.</p>
      </div>
    </div>
  </section>

  <!-- WHO IT'S FOR + VS TMS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="grid lg:grid-cols-2 gap-10 lg:gap-14">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Who it’s for</p>
          <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Is Spravato right for you?</h2>
          <div class="mt-4 h-px w-16 bg-azul/40"></div>
          <ul class="mt-5 space-y-3">
            {whoFor.map((w) => (
              <li class="flex items-start gap-3"><span class="grid h-8 w-8 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name="shield" class="h-4 w-4" /></span><span class="text-ink leading-snug pt-1">{w}</span></li>
            ))}
          </ul>
        </div>
        <div class="rounded-2xl bg-crema border border-azul/30 p-7 self-start">
          <div class="flex items-center gap-3"><span class="grid h-11 w-11 place-items-center rounded-xl bg-azul-light text-azul"><Icon name="swap" class="h-6 w-6" /></span><h3 class="font-display text-2xl text-ink">Spravato vs. TMS</h3></div>
          <p class="mt-4 text-ink leading-relaxed">Both treat treatment-resistant depression. Spravato is <strong>medication-based and supervised in-office</strong>; <a href="/treatment-methods/tms/" class="text-azul font-semibold">TMS</a> is <strong>drug-free with no downtime</strong>. Many people consider both — we’ll help you weigh which fits your situation.</p>
          <p class="mt-4 text-sm text-muted">Spravato works best alongside therapy and medication management — coordinated with the rest of your care, including our <a href="/programs/intensive-outpatient-program/" class="text-azul font-semibold">IOP/PHP</a> if you need more support.</p>
          <a href="/treatment-methods/tms/" class="mt-4 inline-flex items-center gap-1.5 text-sm font-semibold text-azul hover:text-azul-dark transition">Compare with TMS <Icon name="arrow" class="h-4 w-4" /></a>
        </div>
      </div>
    </div>
  </section>

  <!-- PRESS & FEATURES -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Read</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Press &amp; features</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {press.map((p) => (
          <a href={p.href} target="_blank" rel="noopener" class="group flex flex-col rounded-2xl bg-white border border-line p-6 shadow-sm hover:border-azul hover:shadow-lg transition">
            <div class="flex items-center justify-between gap-3 min-h-[2rem]">
              <img src={p.logo} alt={p.outlet} loading="lazy" class="h-7 w-auto max-w-[60%] object-contain" />
              <span class="text-xs text-muted shrink-0">{p.date}</span>
            </div>
            <p class="mt-4 font-display text-lg text-ink leading-snug flex-1 group-hover:text-azul transition">{p.title}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul">Read the feature <Icon name="arrow" class="h-4 w-4" /></span>
          </a>
        ))}
      </div>
      <div class="mt-8 text-center">
        <a href="/media/" class="inline-flex items-center gap-1.5 text-sm font-semibold text-azul hover:text-azul-dark transition">See all press &amp; interviews <Icon name="arrow" class="h-4 w-4" /></a>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Patients rate Hopewell Health Solutions “the best in the area”</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Most major plans cover Spravato</h2>
        <p class="mt-3 text-muted max-w-xl">Many insurance plans now cover Spravato for treatment-resistant depression. We’ll verify your benefits for free and walk you through eligibility and scheduling (we don’t accept Medicaid / HUSKY).</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <!-- LOCATIONS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care across Connecticut</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Our locations</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {locations.map(([city, addr, map]) => (
          <div class="overflow-hidden rounded-2xl bg-white border border-line">
            <iframe src={map} title={`Map — Hopewell Health Solutions, ${city}`} class="h-40 w-full border-0 grayscale-[0.2]" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
            <div class="flex gap-3 p-5">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-azul-light text-azul"><Icon name="pin" class="h-5 w-5" /></span>
              <div><h3 class="font-display text-lg text-ink leading-tight">{city}</h3><p class="mt-1 text-sm text-muted">{addr}</p></div>
            </div>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-muted">Reach us at <a href="tel:8607351448" class="text-azul font-semibold">(860) 735-1448</a> · <a href="mailto:hhs4help@gmail.com" class="text-azul font-semibold">hhs4help@gmail.com</a></p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-crema">
    <div class="mx-auto max-w-3xl px-5 py-16">
      <h2 class="font-display text-3xl text-ink text-center">Spravato — common questions</h2>
      <div class="mt-8 space-y-3">
        {faqs.map(([q, a]) => (
          <details class="group rounded-xl bg-white border border-azul/30 p-5 open:border-azul open:bg-azul-light/30 hover:border-azul transition">
            <summary class="flex justify-between items-center cursor-pointer font-display text-lg text-ink list-none">{q}<span class="text-azul text-xl group-open:rotate-45 transition">+</span></summary>
            <p class="mt-3 text-ink leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <ServicesGrid bg="white" />

  <!-- CTA -->
  <section class="bg-azul text-white">
