---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";

const heroUsps = [
  { icon: "swap", t: "Care for alcohol, opioids, stimulants & prescription misuse" },
  { icon: "calendar", t: "3–5 sessions a week · 6–8 weeks · live at home, keep working" },
  { icon: "brain", t: "CBT & DBT + relapse-prevention & life-skills training" },
  { icon: "shield", t: "Joint Commission accredited · dual-diagnosis ready" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const substances = ["Alcohol", "Prescription medications", "Opioids", "Stimulants", "Other illicit substances"];
const components = [
  { icon: "heart", t: "Individual therapy", d: "Address personal challenges and triggers one-on-one." },
  { icon: "users", t: "Group therapy", d: "Build a support network and foster accountability." },
  { icon: "brain", t: "CBT & DBT", d: "Develop coping strategies and emotional-regulation skills." },
  { icon: "shield", t: "Relapse-prevention education", d: "Real tools for sustaining long-term sobriety." },
  { icon: "compass", t: "Life-skills training", d: "Improve stress management, communication, and goal-setting." },
];
const candidates = [
  "Transitioning from inpatient rehab and needing continued support",
  "Recovering from a relapse and needing structured treatment",
  "Needing intensive therapy while maintaining work or family responsibilities",
  "Ready to build coping skills and a strong support system for lasting sobriety",
];
const benefits = [
  { icon: "swap", tone: "azul", t: "Flexibility with structure", d: "Intensive treatment while you maintain daily responsibilities — staying connected with family and work." },
  { icon: "users", tone: "gold", t: "Peer support & connection", d: "Group therapy builds community, with encouragement and shared experience to help sustain recovery." },
  { icon: "shield", tone: "sage", t: "Skills for long-term sobriety", d: "Relapse-prevention techniques, stress management, and healthier coping to navigate life without substances." },
];
const toneMap = { azul: "bg-azul-light text-azul", gold: "bg-gold-light text-gold", sage: "bg-sage-light text-sage" };
const modalities = [
  { t: "Cognitive Behavioral Therapy (CBT)", icon: "brain" },
  { t: "Dialectical Behavior Therapy (DBT)", icon: "swap" },
  { t: "Individual therapy", icon: "heart" },
  { t: "Group therapy", icon: "users" },
  { t: "Relapse-prevention education", icon: "shield" },
  { t: "Life-skills training", icon: "compass" },
];
const outcomes = ["Regain control of your life", "Lasting recovery & sobriety", "Healthier coping mechanisms", "A strong, sober support system"];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Julie Stevens", t: "2 months ago", q: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { n: "Jake Sted", t: "2 months ago", q: "Hopewell’s IOP program made a huge difference in my life. The groups were engaging, and the therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day." },
  { n: "stacey miller", t: "3 months ago", q: "They put me on the schedule as a new patient within the same week of calling, which never happens, and made sure my insurance was accepted. The provider and staff were very professional and kind." },
  { n: "Cynthia Askew", t: "6 months ago", q: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
  { n: "Joana Yoo", t: "10 months ago", q: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
];
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["Glastonbury", "33 Pratt St, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.0462929427076!2d-72.6158734!3d41.7195199!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f7540001%3A0x207d1c58279c2917!2sKristine%20Schlichting!5e0!3m2!1sen!2sus!4v1781754351066!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const faqs = [
  ["What is an Addiction IOP?", "A structured yet flexible program for substance use disorders — a higher level of care than weekly outpatient therapy, but without an overnight stay. You receive intensive support several times a week while living at home and keeping up with work, school, and family."],
  ["How often will I attend, and for how long?", "Typically three to five sessions a week, each lasting a few hours. The program generally spans six to eight weeks, adjusted to your needs."],
  ["Is IOP right for me, or do I need inpatient?", "IOP is ideal if you’re ready to commit to recovery but don’t need 24/7 supervision. If you’re experiencing severe withdrawal, need medical detox, or require round-the-clock care, an inpatient program may fit better — our specialists assess to recommend the right level."],
  ["What substances do you treat?", "Alcohol, prescription medications, opioids, stimulants, and other illicit substances — including co-occurring mental health conditions."],
  ["Will my insurance cover it?", "We accept most major PPO plans, including Tricare (we don’t accept Medicaid / HUSKY). We’ll verify your benefits for free."],
];
---

<Base title="Addiction IOP in CT | Hopewell Health Solutions" description="Addiction Intensive Outpatient Program (IOP) at Hopewell Health Solutions, Glastonbury CT — structured, flexible care for alcohol, opioids, stimulants & prescription misuse. CBT/DBT, relapse prevention, 6–8 weeks.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/programs/intensive-outpatient-program/" class="hover:text-azul">IOP</a> / <span class="text-ink">Addiction</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Addiction IOP · Glastonbury, CT · Live at home</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Addiction Intensive Outpatient Program (IOP) in Connecticut</h1>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews · “best IOP in the area”</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8609460447" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 946-0447</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Katrin Moskowitz, DNP, PMHNP-BC</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="Take the first step" sub="Confidential. Free insurance check — we’ll help you find the right level of care." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/Guy%20facing%20the%20horizon.webp" alt="A person in addiction recovery through Hopewell's IOP in Glastonbury, CT" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Structured support, real independence</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What is the Addiction IOP?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">The Addiction IOP is a structured yet flexible treatment program for those struggling with substance use disorders. It offers a higher level of care than traditional outpatient therapy while letting you live at home and continue your daily life.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">Unlike inpatient rehab, IOP delivers structured care multiple times a week while you maintain work, school, and family — providing intensive support while building independence and accountability. We support recovery from:</p>
        <div class="mt-4 flex flex-wrap gap-2">
          {substances.map((s) => <span class="rounded-full bg-azul-light px-3 py-1 text-sm font-semibold text-azul">{s}</span>)}
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS (text left / image right) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="lg:order-2"><img src="/Assets/AdobeStock_404268940.webp" alt="Group therapy in Hopewell's Addiction IOP" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" /></div>
      <div class="lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Therapy, education & relapse prevention</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">How the program works</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">A structured schedule integrates therapy, education, and relapse-prevention strategies for long-term recovery. Each week blends:</p>
        <ul class="mt-4 space-y-2.5">
          {components.map((c) => <li class="flex gap-3 text-ink"><span class="mt-0.5 text-azul shrink-0"><Icon name={c.icon} class="h-5 w-5" /></span><span class="leading-snug"><strong>{c.t}</strong> — {c.d}</span></li>)}
        </ul>
        <p class="mt-5 text-sm text-muted">Most participants attend <strong>3–5 times a week</strong>, a few hours per session, generally for <strong>6–8 weeks</strong>.</p>
      </div>
    </div>
  </section>

  <!-- WHO IS A GOOD CANDIDATE -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Find the right level of care</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Is the Addiction IOP right for you?</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">IOP is ideal if you’re ready to commit to recovery but don’t need 24/7 supervision. It’s especially helpful if you’re:</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 gap-4">
        {candidates.map((c) => (
          <div class="flex items-start gap-3 rounded-xl bg-crema border border-line p-5">
            <span class="text-azul mt-0.5 shrink-0"><Icon name="shield" class="h-5 w-5" /></span>
            <span class="text-ink leading-snug font-semibold">{c}</span>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-muted max-w-2xl mx-auto">If you’re experiencing severe withdrawal, need medical detox, or require round-the-clock supervision, an inpatient or residential program may fit better. Our specialists conduct a thorough assessment to recommend the most appropriate level of care.</p>
    </div>
  </section>

  <!-- BENEFITS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Why it works</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">The benefits of an Addiction IOP</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-3 gap-5">
        {benefits.map((b) => (
          <div class="rounded-2xl border border-line bg-white p-7">
            <span class={`grid h-12 w-12 place-items-center rounded-xl ${toneMap[b.tone]}`}><Icon name={b.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug">{b.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{b.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MODALITIES + OUTCOMES -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <h2 class="font-display text-3xl text-ink">Modalities used</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <div class="mt-6 grid grid-cols-2 gap-3">
          {modalities.map((m) => (
            <div class="flex items-center gap-3 rounded-xl bg-crema border border-line p-3.5">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={m.icon} class="h-5 w-5" /></span>
              <span class="text-sm font-semibold text-ink leading-tight">{m.t}</span>
            </div>
          ))}
        </div>
        <p class="mt-5 text-sm text-muted">Plus <a href="/treatment-methods/medication-assisted-treatment/" class="text-azul font-semibold">Medication-Assisted Treatment (MAT)</a> &amp; <a href="/programs/adult-mental-health-iop/" class="text-azul font-semibold">co-occurring care</a> when needed.</p>
      </div>
      <div>
        <h2 class="font-display text-4xl sm:text-5xl text-ink leading-[1.1]">What you can expect</h2>
        <div class="mt-5 h-px w-16 bg-gold"></div>
        <ul class="mt-7 space-y-4">
          {outcomes.map((o) => <li class="flex gap-3 text-ink text-lg"><span class="text-azul mt-1"><Icon name="shield" class="h-5 w-5" /></span>{o}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- QUOTE BAND -->
  <section class="relative">
    <img src="/Assets/team%20together%202.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-ink/80"></div>
    <div class="relative mx-auto max-w-3xl px-5 py-20 text-center">
      <p class="font-display text-2xl sm:text-3xl text-white leading-snug">Recovery is possible — and you don’t have to do it alone. There is hope to heal.</p>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Our IOP patients rate Hopewell Health Solutions “the best in the area”</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Most major PPO plans accepted</h2>
        <p class="mt-3 text-muted max-w-xl">We’re in-network with most major PPO plans, including Tricare (we don’t accept Medicaid / HUSKY). Our admissions team verifies your benefits at no cost — before you commit to anything.</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <!-- LOCATIONS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care across Connecticut</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Our locations</h2>
        <p class="mt-3 text-muted">The Addiction IOP is held at 300 Hebron Ave, Glastonbury · plus virtual visits statewide.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {locations.map(([city, addr, map]) => (
          <div class="overflow-hidden rounded-2xl bg-white border border-line">
            <iframe src={map} title={`Map — Hopewell Health Solutions, ${city}`} class="h-40 w-full border-0 grayscale-[0.2]" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
            <div class="flex gap-3 p-5">
