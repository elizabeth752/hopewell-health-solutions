---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";

const heroUsps = [
  "Men & women 18+ — most major insurance accepted",
  "8–12 week, DBT-based curriculum — day or evening tracks",
  "Co-occurring mental health + substance use care, with MAT",
  "Experiential therapies — art, movement & animal-assisted",
  "FMLA / CT Paid Leave assistance · in-person & virtual",
];
// Credibility = trust signals (accreditations, reviews, press, tenure) — NOT USPs.
const credibility = [
  { icon: "star", t: "4.8 · 368 Google reviews", star: true },
  { icon: "shield", t: "Joint Commission accredited" },
  { icon: "compass", t: "Serving CT since 2013" },
  { icon: "heart", t: "In-network with most plans" },
  { icon: "sparkles", t: "Featured on Eyewitness News 3" },
];
const rightFit = ["Anxiety or depression", "Trauma or PTSD", "Emotional dysregulation or mood instability", "Co-occurring substance use concerns", "Difficulty functioning in daily life despite outpatient support"];
const weekIncludes = ["Evidence-based group therapy grounded in DBT & CBT", "Experiential therapies — art, movement-based & animal-assisted", "Individual therapy for personalized treatment", "Optional medication management & psychiatric support", "Optional family therapy & psychoeducation"];
const sudSupport = ["Psychoeducation on addiction & the brain", "Relapse prevention & recovery planning", "DBT & CBT skill-building to replace maladaptive behaviors", "Dual-diagnosis support (co-occurring mental health & substance use)", "Medication-Assisted Treatment (MAT) services"];
// The 4 defined USPs (consistent site-wide).
const unique = [
  { icon: "brain", t: "TMS for treatment-resistant depression", d: "FDA-cleared, drug-free brain stimulation — for when medication and therapy haven’t been enough." },
  { icon: "dna", t: "GeneSight® genetic testing", d: "A simple cheek swab matches medications to your DNA, so we skip the trial-and-error." },
  { icon: "users", t: "47 specialists you’ll actually meet", d: "Psychologists, psychiatric NPs & trauma experts — matched to you by name, not an algorithm." },
  { icon: "sparkles", t: "Specialized programs hospitals don’t offer", d: "Women’s, Men’s, Teen, Tween & First Responder IOP — care built for who you are." },
];
const outcomes = ["Reduced symptoms of anxiety, depression & emotional overwhelm", "Stronger coping strategies and emotional resilience", "Healthier communication and boundaries in relationships", "Greater self-awareness and increased confidence", "Decreased reliance on substances or harmful behaviors"];
const modalities = ["Dialectical Behavioral Therapy (DBT)", "Cognitive Behavioral Therapy (CBT)", "Art Therapy", "Yoga Therapy", "Mindfulness", "EMDR", "Somatic Therapy", "Trauma-Informed Care"];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  ["I learned coping strategies on the first day of IOP, and it exceeded my expectations. I really love the staff and enjoy the groups — they’re all very caring and always there for me when I need more. I am forever thankful to the Hopewell IOP team!", "Adult IOP Patient"],
  ["I have found the people are extremely kind and supportive. I would definitely recommend them if you need help.", "IOP Patient"],
  ["I look forward to my sessions! They are so helpful, and I feel as if my voice is valued and heard.", "IOP Patient"],
];
const faqs = [
  ["How long is the Adult IOP?", "Most participants attend 8–12 weeks — four days a week (Monday–Thursday), three hours a day, with regular progress evaluations."],
  ["What’s the difference between IOP and PHP?", "PHP is more intensive (about six hours a day); IOP is part-time, so you can keep working, going to school, and caring for your family."],
  ["Can I keep working or going to school?", "Yes — choose a morning (9 AM–12 PM) or evening (5 PM–8 PM) track. Many participants also qualify for FMLA or CT Paid Leave."],
  ["Do you treat substance use too?", "Yes — it’s a co-occurring program. We treat mental health and substance use together, including Medication-Assisted Treatment (MAT)."],
  ["Will my insurance cover it?", "We accept most major insurance plans. We’ll verify your benefits for free, in minutes."],
];
---

<Base title="Adult IOP in Glastonbury, CT | Hopewell Health Solutions" description="Adult Intensive Outpatient Program (IOP) in Glastonbury, CT — DBT-based, co-occurring care for anxiety, depression, trauma & substance use. Day & evening tracks. Most insurance accepted.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/#programs" class="hover:text-azul">Programs</a> / <span class="text-ink">Adult IOP</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Adult Co-Occurring IOP · Glastonbury &amp; West Hartford, CT</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Adult Intensive Outpatient Program (IOP)</h1>
          <div class="mt-5 h-px w-16 bg-azul/40"></div>
          <ul class="mt-6 space-y-2.5">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="mt-1 text-azul"><Icon name="shield" class="h-5 w-5" /></span><span class="leading-snug">{u}</span></li>
            ))}
          </ul>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="#verify" class="rounded-lg bg-azul px-7 py-3.5 font-semibold text-white hover:bg-azul-dark transition">Verify Your Insurance →</a>
            <a href="tel:8609460447" class="inline-flex items-center gap-2 rounded-lg border border-azul px-7 py-3.5 font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-4 w-4" />(860) 946-0447</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Katrin Moskowitz, DNP, PMHNP-BC</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm /></div>
      </div>
    </div>
  </section>

  <!-- CREDIBILITY STRIP -->
  <section class="bg-white border-y border-line">
    <div class="mx-auto max-w-6xl px-5 py-5 flex flex-wrap items-center justify-center gap-x-8 gap-y-3 text-sm text-ink">
      {credibility.map((c) => (
        <span class="inline-flex items-center gap-2">
          {c.star ? <span class="text-yellow-400">★★★★★</span> : <span class="text-azul"><Icon name={c.icon} class="h-4 w-4" /></span>}
          {c.t}
        </span>
      ))}
    </div>
  </section>

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/AdobeStock_403830351.webp" alt="Adult IOP group therapy in Glastonbury, CT" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A whole-person approach to adult mental health</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What is an Adult Intensive Outpatient Program (IOP)?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">An Adult Intensive Outpatient Program (IOP) is a structured treatment plan for adults experiencing mental health challenges who need more support than weekly therapy provides. It offers a higher level of care while you continue your daily life — work, school, and family.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">Unlike inpatient programs, an Adult IOP doesn’t require a hospital stay. At Hopewell Health Solutions, our IOP supports adults struggling with depression, anxiety, trauma, mood disorders, and co-occurring substance use — and is ideal for those stepping down from inpatient care or seeking more than traditional outpatient therapy.</p>
      </div>
    </div>
  </section>

  <!-- RIGHT FOR YOU (text left / image right) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="lg:order-2"><img src="/Assets/Guy%20facing%20the%20horizon.webp" alt="Adult considering IOP treatment in Connecticut" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" /></div>
      <div class="lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">The space &amp; support you’ve been looking for</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">Is this program right for you?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Our Adult IOP is designed for individuals 18+ experiencing moderate-to-severe symptoms of:</p>
        <ul class="mt-4 space-y-2.5">
          {rightFit.map((r) => <li class="flex gap-3 text-ink"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-azul"></span><span class="leading-snug">{r}</span></li>)}
        </ul>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">If you’re ready to take a more active role in your healing but don’t require inpatient care, this program may be the right fit.</p>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/full%20team%20happy.webp" alt="The Hopewell Health Solutions IOP team in Glastonbury, CT" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Flexible, compassionate, comprehensive</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">How does the program work?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Our IOP runs four days per week, three hours per day — a balance of intensive clinical care and flexibility for your work, school, or family life. Choose a <strong>morning (9 AM–12 PM)</strong> or <strong>evening (5 PM–8 PM)</strong> track, Monday–Thursday, at 300 Hebron Ave, Glastonbury. Most participants engage for 8–12 weeks, with regular progress evaluations. Each week includes:</p>
        <ul class="mt-4 space-y-2.5">
          {weekIncludes.map((w) => <li class="flex gap-3 text-ink"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-azul"></span><span class="leading-snug">{w}</span></li>)}
        </ul>
        <p class="mt-5 text-sm text-muted">Most major insurances accepted · Many participants qualify for FMLA or CT Paid Leave.</p>
      </div>
    </div>
  </section>

  <!-- SUBSTANCE USE + MAT (text left / image right) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-start">
      <div class="lg:order-2"><img src="/Assets/AdobeStock_542909901.webp" alt="Co-occurring mental health and substance use care" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" /></div>
      <div class="lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Struggling with unhealthy coping?</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">Supporting both mental health &amp; substance-use recovery</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">While our focus is mental health, we recognize how closely substance use and emotional pain are linked. For clients struggling with unhealthy coping mechanisms, we offer:</p>
        <ul class="mt-4 space-y-2.5">
          {sudSupport.map((s) => <li class="flex gap-3 text-ink"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-azul"></span><span class="leading-snug">{s}</span></li>)}
        </ul>
        <div class="mt-6 rounded-xl bg-white border border-line p-5">
          <h3 class="font-display text-xl text-ink">What is MAT?</h3>
          <p class="mt-2 text-ink leading-relaxed text-[15px]">Medication-Assisted Treatment combines FDA-approved medications with counseling and behavioral therapy to reduce cravings and withdrawal and support long-term recovery. Under the compassionate care of <strong>Katherine Salvador, APRN</strong>, MAT is personalized — never one-size-fits-all — with a trauma-informed, judgment-free approach.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- QUOTE BAND (white text over image) -->
  <section class="relative">
    <img src="/Assets/team%20together%202.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-ink/80"></div>
    <div class="relative mx-auto max-w-3xl px-5 py-20 text-center">
      <p class="font-display text-2xl sm:text-3xl text-white leading-snug">Caring for your mental health is an act of strength, not weakness. You’ve carried a lot — you don’t have to carry it alone.</p>
    </div>
  </section>

  <!-- WHAT MAKES US UNIQUE (light USP cards — readable) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Why families choose Hopewell</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">What makes our program unique?</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {unique.map((u) => (
          <div class="rounded-2xl border border-line bg-crema p-6">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={u.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug">{u.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{u.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT YOU CAN EXPECT + MODALITIES -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-12">
      <div>
        <h2 class="font-display text-3xl text-ink">What you can expect</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <ul class="mt-5 space-y-3">
          {outcomes.map((o) => <li class="flex gap-3 text-ink text-[17px]"><span class="text-azul mt-0.5"><Icon name="shield" class="h-5 w-5" /></span>{o}</li>)}
        </ul>
      </div>
      <div>
        <h2 class="font-display text-3xl text-ink">Modalities used in our IOP</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <div class="mt-5 flex flex-wrap gap-2.5">
          {modalities.map((m) => <a href="#" class="rounded-full bg-white border border-line px-4 py-2 text-sm font-semibold text-ink hover:border-azul hover:text-azul transition">{m}</a>)}
        </div>
        <p class="mt-5 text-sm text-muted">Plus <a href="/programs/medication-management/" class="text-azul font-semibold">medication management</a> and additional therapeutic treatments.</p>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="flex items-center justify-center gap-3"><img src="/Assets/Google-Review-Symbol.webp" alt="Google" class="h-7 w-7 object-contain" /><span class="font-display text-3xl text-ink">4.8</span><span class="text-yellow-400 text-xl">★★★★★</span></div>
        <p class="mt-2 text-muted">Our IOP patients rate us “the best IOP in the area” · As featured on Eyewitness News 3</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-5">
        {reviews.map(([q, who]) => (
          <figure class="rounded-2xl border border-line bg-crema p-6">
            <div class="text-yellow-400">★★★★★</div>
            <blockquote class="mt-3 text-ink leading-relaxed text-[15px]">“{q}”</blockquote>
            <figcaption class="mt-4 text-sm text-muted border-t border-line pt-3">— {who}</figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE (with logos) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-ink">Comprehensive coverage options</h2>
      <p class="mt-3 text-muted max-w-2xl mx-auto">We accept most insurance providers. Not sure about your plan? We’ll verify your benefits — free, in minutes.</p>
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
        {insurers.map(([name, img]) => (
          <div class="rounded-xl bg-white border border-line p-5 flex items-center justify-center h-24"><img src={img} alt={name} loading="lazy" class="max-h-14 max-w-[80%] object-contain" /></div>
        ))}
      </div>
      <a href="#verify" class="mt-10 inline-block rounded-lg bg-azul px-7 py-3.5 font-semibold text-white hover:bg-azul-dark transition">Verify my benefits →</a>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-white">
    <div class="mx-auto max-w-3xl px-5 py-16">
      <h2 class="font-display text-3xl text-ink text-center">Adult IOP — common questions</h2>
      <div class="mt-8 space-y-3">
        {faqs.map(([q, a]) => (
          <details class="group rounded-xl bg-crema border border-line p-5">
            <summary class="flex justify-between items-center cursor-pointer font-display text-lg text-ink list-none">{q}<span class="text-azul text-xl group-open:rotate-45 transition">+</span></summary>
            <p class="mt-3 text-ink leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">Start your healing journey today</h2>
      <p class="mt-4 text-white/85 text-lg">Healing is possible, and you don’t have to do it alone. We’re accepting new clients, accept most major insurance, and offer flexible payment options.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">Verify Your Insurance</a>
        <a href="tel:8609460447" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 946-0447</a>
      </div>
      <p class="mt-6 text-xs text-white/60">Not a substitute for emergency care. If you’re in crisis, call or text 988, or call 911.</p>
    </div>
  </section>

  <Footer />
</Base>
