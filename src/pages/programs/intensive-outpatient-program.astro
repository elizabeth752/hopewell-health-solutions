---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";

const heroUsps = [
  { icon: "users", t: "Tracks for every age — tweens, teens, women & adults" },
  { icon: "calendar", t: "Day & evening options, Mon–Thu — keep work & school intact" },
  { icon: "shield", t: "The only private IOP in Connecticut that’s Joint Commission Accredited" },
  { icon: "brain", t: "8–12 weeks · DBT-based care from a multidisciplinary team" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const L = "/Assets/Media%20Appearances/";
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const tracks = [
  { t: "Tween IOP", age: "Ages 8–12", sched: "Mon–Thu · 5:00–8:00 PM", loc: "1420 Main St, Glastonbury", href: "/programs/tween-iop/", icon: "sparkles" },
  { t: "Teen IOP", age: "Ages 13–17", sched: "Mon–Thu · 5:00–8:00 PM", loc: "1420 Main St, Glastonbury", href: "/programs/teen-iop/", icon: "users" },
  { t: "Women's Wellness IOP", age: "Adults 18+", sched: "Mon–Thu · 9 AM–12 PM or 5–8 PM", loc: "300 Hebron Ave, Glastonbury", href: "/programs/womens-wellness-iop/", icon: "heart" },
  { t: "Adult Co-Occurring IOP", age: "Adults 18+", sched: "Mon–Thu · 9 AM–12 PM or 5–8 PM", loc: "300 Hebron Ave, Glastonbury", href: "/programs/adult-mental-health-iop/", icon: "brain" },
];
const whoBenefit = [
  "Depression & mood disorders",
  "Anxiety & panic disorders",
  "Post-traumatic stress disorder (PTSD)",
  "Self-injury or suicidal thoughts",
  "School refusal or social withdrawal (adolescents)",
  "Trauma & relational difficulties (Women’s)",
  "Emotional dysregulation & life transitions",
  "Substance use & addiction (Adult)",
];
const toneMap = { azul: "bg-azul-light text-azul", gold: "bg-gold-light text-gold", sage: "bg-sage-light text-sage" };
const unique = [
  { icon: "users", tone: "azul", t: "Multidisciplinary team", d: "Board-certified psychiatrists, licensed counselors, psychologists, social workers & expressive therapists — each with 10–30 years of experience." },
  { icon: "clipboard", tone: "gold", t: "Customized care", d: "Individualized treatment plans tailored to each client’s specific needs and goals." },
  { icon: "heart", tone: "sage", t: "Holistic approach", d: "Traditional psychotherapy blended with wellness-based interventions for emotional and physical well-being." },
  { icon: "shield", tone: "azul", t: "Accredited & licensed", d: "State-licensed and the only private IOP in Connecticut that is Joint Commission Accredited." },
];
const outcomes = ["Emotional regulation", "Healthier coping skills", "Self-awareness & empowerment", "Social & relational growth", "Reduced mental health symptoms"];
const modalities = [
  { t: "Dialectical Behavior Therapy (DBT)", icon: "swap" },
  { t: "Cognitive Behavioral Therapy (CBT)", icon: "brain" },
  { t: "Interpersonal Therapy", icon: "users" },
  { t: "Mindfulness", icon: "cloud" },
  { t: "Art Therapy", icon: "sparkles" },
  { t: "Music Therapy", icon: "star" },
  { t: "Yoga Therapy", icon: "sun" },
  { t: "Experiential Activities", icon: "compass" },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Julie Stevens", t: "2 months ago", q: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { n: "Jake Sted", t: "2 months ago", q: "Hopewell’s IOP program made a huge difference in my life. The groups were engaging, and the therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day." },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. I started in their Women’s Wellness IOP and all the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "Joana Yoo", t: "10 months ago", q: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
  { n: "stacey miller", t: "3 months ago", q: "They put me on the schedule as a new patient within the same week of calling, which never happens, and made sure my insurance was accepted. The provider and staff were very professional and kind." },
  { n: "Cynthia Askew", t: "6 months ago", q: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
];
const faqs = [
  ["What is an Intensive Outpatient Program (IOP)?", "An IOP provides structured therapeutic care without an overnight stay — individual and group counseling, skills-based psychotherapy, psychiatric medication management, and experiential therapies — while you maintain your daily routine at home, work, or school."],
  ["What does the program include, and what’s the schedule?", "Our IOPs meet four times a week (Mon–Thu), day or evening depending on the track. Tween & Teen run 5–8 PM; Women’s Wellness and Adult Co-Occurring run 9 AM–12 PM or 5–8 PM. Each runs 8–12 weeks and blends DBT, CBT, interpersonal therapy, mindfulness, and expressive therapies (art, music, yoga). Family involvement is encouraged in the tween and teen programs."],
  ["Who can benefit from an IOP?", "Individuals experiencing depression, anxiety, PTSD, self-injury or suicidal thoughts, school refusal, trauma, emotional dysregulation, or substance use. All programs are inclusive and affirming — we welcome everyone regardless of gender identity, sexual orientation, cultural background, or diagnosis."],
  ["What makes Hopewell Health Solutions’ IOPs unique?", "A multidisciplinary team with 10–30 years of experience, customized treatment plans, a holistic approach — and we are the only private IOP in Connecticut that is Joint Commission Accredited."],
  ["Do you accept insurance for the IOP programs?", "Yes — we accept almost all private insurances, including Tricare, for all of our IOP programs (we don’t accept Medicaid / HUSKY)."],
  ["How do I get started?", "Call us or request a consultation online to schedule an in-person or telehealth evaluation with our intake team. We’ll help determine which IOP track is the right fit for you or your loved one."],
];
---

<Base title="Intensive Outpatient Programs (IOP) in CT | Hopewell Health Solutions" description="Intensive Outpatient Programs (IOP) at Hopewell Health Solutions, Glastonbury CT — tween, teen, women's & adult tracks. DBT-based, day & evening. The only private IOP in CT that's Joint Commission Accredited.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/#programs" class="hover:text-azul">Programs</a> / <span class="text-ink">IOP</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Intensive Outpatient Programs · Glastonbury, CT · Day &amp; evening</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Intensive Outpatient Programs (IOP) in Connecticut</h1>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8609460447" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 946-0447</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Kristine Schlichting, PhD</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/AdobeStock_403830351.webp" alt="Intensive outpatient program group in Glastonbury, CT" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A higher level of care, on your schedule</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What is an Intensive Outpatient Program?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Mental health conditions are common — affecting nearly 23% of adults and 17% of children aged 6–17 in the United States. An Intensive Outpatient Program (IOP) offers structured therapeutic care for those who need more than weekly therapy, without an overnight stay.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">At Hopewell Health Solutions, our IOPs combine individual and group counseling, skills-based psychotherapy, psychiatric medication management, and experiential therapies — so you can keep your routine at home, work, or school while you heal.</p>
      </div>
    </div>
  </section>

  <!-- CHOOSE YOUR TRACK -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Find your fit</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Choose your IOP track</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">Four age-specific tracks, each meeting Monday–Thursday for 8–12 weeks. Not sure which fits? Our intake team will help you decide.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {tracks.map((tr) => (
          <a href={tr.href} class="group flex flex-col rounded-2xl bg-white border border-line p-6 hover:border-azul hover:shadow-lg transition">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={tr.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl text-ink leading-tight group-hover:text-azul transition">{tr.t}</h3>
            <span class="mt-1 inline-block w-fit rounded-full bg-crema px-2.5 py-0.5 text-xs font-semibold text-azul">{tr.age}</span>
            <p class="mt-3 text-sm text-ink flex items-start gap-2"><Icon name="calendar" class="h-4 w-4 mt-0.5 shrink-0 text-azul" />{tr.sched}</p>
            <p class="mt-1.5 text-sm text-muted flex items-start gap-2"><Icon name="pin" class="h-4 w-4 mt-0.5 shrink-0 text-azul" />{tr.loc}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul">Learn more <Icon name="arrow" class="h-4 w-4" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- WHO CAN BENEFIT -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Who it’s for</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Who can benefit from an IOP?</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-4">
        {whoBenefit.map((w) => (
          <div class="rounded-xl bg-crema border border-line p-5 text-ink font-semibold leading-snug">{w}</div>
        ))}
      </div>
      <p class="mt-6 text-center text-muted max-w-2xl mx-auto">We welcome all individuals, regardless of gender identity, sexual orientation, cultural background, or diagnosis. Every program is inclusive and affirming.</p>
    </div>
  </section>

  <!-- WHAT MAKES US UNIQUE -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Setting the standard for IOP care</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">What makes our IOPs unique</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {unique.map((u) => (
          <div class="rounded-2xl border border-line bg-white p-6">
            <span class={`grid h-12 w-12 place-items-center rounded-xl ${toneMap[u.tone]}`}><Icon name={u.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug">{u.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{u.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT TO EXPECT + MODALITIES -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <h2 class="font-display text-3xl text-ink">Modalities used in our IOPs</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <div class="mt-6 grid grid-cols-2 gap-3">
          {modalities.map((m) => (
            <div class="flex items-center gap-3 rounded-xl bg-crema border border-line p-3.5">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={m.icon} class="h-5 w-5" /></span>
              <span class="text-sm font-semibold text-ink leading-tight">{m.t}</span>
            </div>
          ))}
        </div>
      </div>
      <div>
        <h2 class="font-display text-4xl sm:text-5xl text-ink leading-[1.1]">What you can expect</h2>
        <div class="mt-5 h-px w-16 bg-gold"></div>
        <ul class="mt-7 space-y-4">
          {outcomes.map((o) => <li class="flex gap-3 text-ink text-lg"><span class="text-azul mt-1"><Icon name="shield" class="h-5 w-5" /></span>{o}</li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- FEATURED INTERVIEW (credibility variation) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">As seen on Connecticut news</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">Helping children, teens &amp; families</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Connecticut’s news outlets turn to our clinicians for guidance on teen and family mental health. Watch Dr. Kristine Schlichting and our team share how the right support changes lives.</p>
        <a href="/media/" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-azul hover:text-azul-dark transition">See all press &amp; interviews <Icon name="arrow" class="h-4 w-4" /></a>
      </div>
      <div class="aspect-video overflow-hidden rounded-2xl border border-line bg-ink shadow-sm">
        <iframe class="h-full w-full" src="https://www.youtube.com/embed/GJeVqHhooBA" title="Hopewell Health Solutions — helping children, teens & families" loading="lazy" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Our IOP patients rate Hopewell Health Solutions “the best in the area” · As featured on Eyewitness News 3</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Almost all private insurance — including Tricare</h2>
        <p class="mt-3 text-muted max-w-xl">We accept almost all private insurance plans for our IOP programs, including Tricare (we don’t accept Medicaid / HUSKY). Our admissions team verifies your benefits at no cost — before you commit to anything.</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <!-- LOCATIONS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care across Connecticut</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Our locations</h2>
        <p class="mt-3 text-muted">Adult & Women’s tracks at 300 Hebron Ave · Tween & Teen tracks at 1420 Main St, Glastonbury.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {locations.map(([city, addr, map]) => (
          <div class="overflow-hidden rounded-2xl bg-white border border-line">
            <iframe src={map} title={`Map — Hopewell Health Solutions, ${city}`} class="h-40 w-full border-0 grayscale-[0.2]" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
            <div class="flex gap-3 p-5">
              <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-azul-light text-azul"><Icon name="pin" class="h-5 w-5" /></span>
              <div><h3 class="font-display text-lg text-ink leading-tight">{city}</h3><p class="mt-1 text-sm text-muted">{addr}</p></div>
            </div>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-sm text-muted">Reach us at <a href="tel:8609460447" class="text-azul font-semibold">(860) 946-0447</a> · <a href="mailto:hhs4help@gmail.com" class="text-azul font-semibold">hhs4help@gmail.com</a></p>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-crema">
    <div class="mx-auto max-w-3xl px-5 py-16">
      <h2 class="font-display text-3xl text-ink text-center">IOP — common questions</h2>
      <div class="mt-8 space-y-3">
        {faqs.map(([q, a]) => (
          <details class="group rounded-xl bg-white border border-azul/30 p-5 open:border-azul open:bg-azul-light/30 hover:border-azul transition">
            <summary class="flex justify-between items-center cursor-pointer font-display text-lg text-ink list-none">{q}<span class="text-azul text-xl group-open:rotate-45 transition">+</span></summary>
            <p class="mt-3 text-ink leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">Find the right IOP track</h2>
      <p class="mt-4 text-white/85 text-lg">Call us or request a consultation and our intake team will help determine which IOP is the right fit for you or your loved one — in person or by telehealth.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">Verify Your Insurance</a>
        <a href="tel:8609460447" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 946-0447</a>
        <a href="mailto:hhs4help@gmail.com" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition">Email Us</a>
      </div>
      <p class="mt-6 text-xs text-white/60">Not a substitute for emergency care. If you’re in crisis, call or text 988, or call 911.</p>
    </div>
  </section>

  <Footer />
</Base>
