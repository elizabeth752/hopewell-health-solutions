  { icon: "shield", t: "Medication-Assisted Treatment (MAT)", d: "Evidence-based medications reduce cravings and withdrawal symptoms to support recovery from opioid and alcohol dependence." },
  { icon: "brain", t: "Psychiatric Services", d: "Comprehensive mental health evaluations and medication management help identify and treat co-occurring conditions." },
  { icon: "users", t: "Support Groups", d: "Peer-to-peer groups connect you with others on a similar journey — a supportive space to share challenges, celebrate progress, and stay encouraged." },
  { icon: "heart", t: "Healing Beyond Words", d: "Experiential therapies help you explore emotions and process trauma in non-verbal, embodied ways — through movement, creative expression, and connection with therapy animals." },
  { icon: "refresh", t: "Optional Family Involvement", d: "Family sessions and psychoeducation foster understanding and support at home — because healing often means rebuilding relationships." },
  { icon: "compass", t: "A Holistic Care Team", d: "Clinicians, psychiatric providers, and experiential therapists work collaboratively on a plan aligned with your values, goals, and needs." },
];
const interviews = [
  { id: "aff5Xfy9CfE", t: "The Loneliness Crisis in Adults", outlet: "Hopewell Health Solutions" },
  { id: "GJeVqHhooBA", t: "Mommy Monday: Helping Children", outlet: "WFSB Channel 3" },
  { id: "uDy-K1dO0Fw", t: "CT Live!: Trauma in Women", outlet: "NBC Connecticut" },
];
const toneMap = { azul: "bg-azul-light text-azul", gold: "bg-gold-light text-gold", sage: "bg-sage-light text-sage" };
const unique = [
  { icon: "sparkles", tone: "azul", t: "Concierge, customizable care", d: "A targeted program built around the goals you set — you choose the groups that move you forward, never a fixed template." },
  { icon: "shield", tone: "gold", t: "Joint Commission accredited", d: "A multidisciplinary team held to the rigorous safety standards of national accreditation." },
  { icon: "swap", tone: "sage", t: "A true step-down / step-up partner", d: "Move seamlessly between PHP and IOP as your needs change — one team, one continuous plan." },
  { icon: "dna", tone: "azul", t: "GeneSight® & expert med management", d: "Genetic testing matches medications to your DNA, guided by experienced psychiatric providers." },
];
const outcomes = ["Rapid stabilization and a renewed sense of safety", "Stronger coping skills and emotional regulation", "Improved overall quality of life", "Successful community reintegration & long-term recovery"];
const modalities = [
  { t: "Dialectical Behavioral Therapy (DBT)", icon: "swap" },
  { t: "Cognitive Behavioral Therapy (CBT)", icon: "brain" },
  { t: "Art Therapy", icon: "sparkles" },
  { t: "Yoga Therapy", icon: "sun" },
  { t: "Mindfulness", icon: "cloud" },
  { t: "EMDR", icon: "bolt" },
  { t: "Somatic Therapy", icon: "heart" },
  { t: "Trauma-Informed Care", icon: "shield" },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
