const phpDay = [
  ["9:00–10:00 AM", "Check-in / psychoeducation group"],
  ["10:00–11:00 AM", "Psychoeducation group"],
  ["11:00 AM–12:00 PM", "Process group"],
  ["12:00–12:30 PM", "Lunch"],
