const approach = [
  { icon: "users", t: "Group Therapy", d: "Clinician-led sessions offer fresh perspectives, reduce isolation, and help you learn from others in early recovery. Modules include DBT, CBT, mindfulness & grounding, motivational interviewing, distress tolerance, and emotion regulation. You choose the groups aligned with the goals you set with your clinician." },
  { icon: "heart", t: "Individual Therapy", d: "One-on-one sessions with a licensed clinician assess your needs and address challenges in real time, working toward short- and long-term goals. They also include peer recovery coaching — in person and by text — and on-call, non-emergency clinical support by phone, text, or in person whenever you need it." },
  { icon: "clipboard", t: "Skills Training", d: "Our clinicians, psychiatric providers, and experiential therapists collaborate on a plan built around your values, goals, and needs — teaching practical skills in distress tolerance, emotion regulation, communication, and relapse prevention that you can carry into everyday life." },
  { icon: "sparkles", t: "Holistic & Creative Therapy", d: "Expressive, integrative practices — art, movement, mindfulness, and creative expression — engage the whole person: mind, body, and emotions. These groups encourage self-discovery, stress relief, and the kind of healing that words alone can’t always reach." },
