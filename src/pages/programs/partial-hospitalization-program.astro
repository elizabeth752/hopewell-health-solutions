const benefitsFor = [
  "Anyone needing more therapeutic support than once-weekly therapy provides",
  "People leaving residential treatment who want a structured, flexible next step in recovery",
  "Those who need an alternative treatment approach while living in a sober-living home",
];
const whoFor = [
  "Individuals needing stabilization after a crisis",
  "Those transitioning from inpatient hospitalization or residential treatment",
  "Adults struggling with depression, anxiety, trauma, or mood disorders",
  "Individuals at risk of relapse",
  "Those who need more support than weekly therapy can offer",
  "People seeking a structured, therapeutic environment to regain stability",
