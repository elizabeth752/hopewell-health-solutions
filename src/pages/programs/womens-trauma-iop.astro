---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";

const heroUsps = [
  { icon: "heart", t: "A program for women, focused on trauma recovery" },
  { icon: "calendar", t: "Mon–Thu · 5–8 PM · 8 weeks (extendable to your needs)" },
  { icon: "users", t: "Heal within a supportive community of women" },
  { icon: "shield", t: "Most insurance accepted (except HUSKY) · trauma-informed" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const symptoms = [
  { t: "Physical", d: "Fatigue, edginess, and problems with sleep and concentration.", icon: "bolt" },
  { t: "Emotional & psychological", d: "Anxiety, numbness, depression, helplessness, persistent fear, or intense, unpredictable emotions.", icon: "cloud" },
  { t: "Behavioral", d: "Avoiding certain places or people, social withdrawal, or self-destructive behaviors.", icon: "alert" },
  { t: "Cognitive", d: "Difficulty remembering the event, trouble concentrating, and decision-making difficulties.", icon: "brain" },
  { t: "Relational", d: "Conflict in relationships, feeling disconnected, or difficulty trusting others.", icon: "link" },
];
const offer = [
  { t: "Individual & group therapy", d: "Personal and communal spaces to explore and heal from trauma.", icon: "users" },
  { t: "Creative & expressive therapies", d: "Art, music, and movement sessions as dynamic outlets for expression.", icon: "sparkles" },
  { t: "Psychoeducation & coping skills", d: "Tools and knowledge to manage stress and avoid relapse.", icon: "brain" },
  { t: "Optional medication management", d: "Integrated care to support your overall treatment plan.", icon: "pill" },
  { t: "Optional family therapy", d: "Including loved ones to strengthen your support network.", icon: "link" },
  { t: "Substance-use support", d: "Addressing concurrent challenges with substances, too.", icon: "swap" },
];
const why = [
  { icon: "refresh", t: "The right level of care", d: "More support than weekly therapy, without hospitalization — a structured yet flexible environment that effectively manages symptoms and prevents the need for a higher level of care." },
  { icon: "heart", t: "A profound act of self-care", d: "Women so often put everyone else first. Choosing this time for yourself is a transformative step — and we honor and support that decision every step of the way." },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. I started in their Women’s Wellness IOP and all the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "Julie Stevens", t: "2 months ago", q: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { n: "Cynthia Askew", t: "6 months ago", q: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
];
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["Glastonbury", "33 Pratt St, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.0462929427076!2d-72.6158734!3d41.7195199!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f7540001%3A0x207d1c58279c2917!2sKristine%20Schlichting!5e0!3m2!1sen!2sus!4v1781754351066!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const faqs = [
  ["Who is the Women’s Trauma IOP for?", "Women healing from trauma — a single event or a series of experiences — who need more support than weekly therapy but don’t require hospitalization. Open to all who identify as women."],
  ["What’s the schedule?", "Monday–Thursday, 5:00–8:00 PM. The program runs about 8 weeks and can be extended based on your needs and progress."],
  ["What does the program include?", "Individual and group therapy, creative and expressive therapies (art, music, movement), psychoeducation and coping skills, optional medication management, optional family therapy, and support for any concurrent substance use — plus step-down planning."],
  ["How is this different from the Women’s Wellness IOP?", "The Women’s Trauma IOP is focused specifically on healing from trauma. Our broader Women’s Wellness IOP supports burnout, anxiety, stress, life transitions, and self-esteem. Not sure which fits? We’ll help you decide."],
  ["Will my insurance cover it?", "It’s covered by most major insurance plans, except HUSKY. We’ll verify your benefits for free."],
];
---

<Base title="Women's Trauma IOP in CT | Hopewell Health Solutions" description="A Women's Trauma Intensive Outpatient Program at Hopewell Health Solutions, Glastonbury CT — trauma-focused, evening (Mon–Thu 5–8 PM), 8 weeks. Heal in a supportive community of women. Most insurance accepted.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/programs/intensive-outpatient-program/" class="hover:text-azul">IOP</a> / <span class="text-ink">Women's Trauma</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Women's Trauma IOP · Glastonbury, CT · Evenings</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Women's Trauma Intensive Outpatient Program (IOP)</h1>
          <p class="mt-3 font-display text-xl text-azul italic">Rebuild your life, one step at a time.</p>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews · “best IOP in the area”</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8607351448" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 735-1448</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Kristine Schlichting, PhD</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="Begin your healing journey" sub="A trauma program for women, by women. Free, confidential insurance check." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WELCOME (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/women%20looking%20at%20me.webp" alt="A woman in Hopewell's Women's Trauma IOP in Glastonbury, CT" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Welcome</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">A supportive space to heal from trauma</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Our Women’s Trauma IOP — Monday through Thursday, 5:00–8:00 PM — helps women balance life’s responsibilities with their healing journey. It’s a meaningful act of self-care: an opportunity to invest in your well-being while managing daily commitments.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">Over this 8-week program (extendable based on your needs and progress), you’ll be part of a supportive community focused on recovery from trauma — a proactive approach that mediates symptoms effectively and helps prevent the need for hospitalization or a higher level of care.</p>
      </div>
    </div>
  </section>

  <!-- WHAT IS TRAUMA (text left / image right) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="lg:order-2"><img src="/Assets/girl%20thinking%20worried.webp" alt="Understanding trauma and its lasting effects" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" /></div>
      <div class="lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Understanding it is the first step</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What is trauma?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Trauma can come from a single event, or a series of events or circumstances that feel emotionally or physically harmful or life-threatening — with lasting effects on your functioning and your physical, social, emotional, or spiritual well-being.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">Trauma is deeply personal. Different people react to similar events in very different ways — what one person finds traumatic, another may not. There’s no “right” way to respond, and there’s no shame in needing support.</p>
      </div>
    </div>
  </section>

  <!-- SYMPTOMS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Know the signs</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Symptoms of trauma to look for</h2>
        <p class="mt-3 text-muted">The impact of trauma can be profound and long-lasting, and it shows up differently for everyone — commonly across five areas:</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {symptoms.map((s) => (
          <div class="rounded-2xl border border-line bg-crema p-6">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={s.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug">{s.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT WE OFFER -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Comprehensive, tailored care</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">What our program offers</h2>
        <p class="mt-3 text-muted">We believe in the power of community and collaborative healing — with step-down support as you transition to less intensive care.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {offer.map((o) => (
          <div class="rounded-2xl border border-line bg-white p-6">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={o.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug">{o.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{o.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- COMMUNITY QUOTE BAND -->
  <section class="relative">
    <img src="/Assets/team%20together%202.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-ink/80"></div>
    <div class="relative mx-auto max-w-3xl px-5 py-20 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-white/70">The value of community in healing</p>
      <p class="mt-3 font-display text-2xl sm:text-3xl text-white leading-snug">You gain the collective strength of women who understand — and the reassurance that you are not alone on this journey.</p>
    </div>
  </section>

  <!-- WHY / SELF-CARE -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Why now</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">The right care, at the right time</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-2 gap-5">
        {why.map((w) => (
          <div class="rounded-2xl bg-crema border border-line p-7">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={w.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl text-ink">{w.t}</h3>
            <p class="mt-2 text-ink leading-relaxed text-[15px]">{w.d}</p>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-muted">Looking for broader support beyond trauma? Explore our <a href="/programs/womens-wellness-iop/" class="text-azul font-semibold">Women’s Wellness IOP</a>.</p>
    </div>
  </section>

  <!-- FEATURED VIDEO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">As seen on NBC Connecticut</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">Trauma in women</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Connecticut’s news outlets turn to our clinicians to talk about women’s mental health and trauma. Watch our team on CT Live! discuss why so many women carry trauma — and how the right support changes everything.</p>
        <a href="/media/" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-azul hover:text-azul-dark transition">See all press &amp; interviews <Icon name="arrow" class="h-4 w-4" /></a>
      </div>
      <div class="aspect-video overflow-hidden rounded-2xl border border-line bg-ink shadow-sm">
        <iframe class="h-full w-full" src="https://www.youtube.com/embed/uDy-K1dO0Fw" title="CT Live!: Trauma in Women — Hopewell Health Solutions" loading="lazy" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Our IOP patients rate Hopewell Health Solutions “the best in the area”</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Covered by most major plans</h2>
        <p class="mt-3 text-muted max-w-xl">The Women’s Trauma IOP is covered by most major insurance plans, <strong>except HUSKY</strong>. Our team verifies your benefits at no cost — before you commit to anything.</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <!-- LOCATIONS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care across Connecticut</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Our locations</h2>
        <p class="mt-3 text-muted">The Women’s Trauma IOP is held at 300 Hebron Ave, Glastonbury · plus virtual visits statewide.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {locations.map(([city, addr, map]) => (
          <div class="overflow-hidden rounded-2xl bg-white border border-line">
            <iframe src={map} title={`Map — Hopewell Health Solutions, ${city}`} class="h-40 w-full border-0 grayscale-[0.2]" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
            <div class="flex gap-3 p-5">
