---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";

const heroUsps = [
  { icon: "shield", t: "Designed by first responders, for first responders" },
  { icon: "users", t: "For police, fire, EMS, corrections & 9-1-1 dispatch — current or retired" },
  { icon: "calendar", t: "Mon–Thu · 9 AM–12 PM · ~8 weeks · safe & confidential" },
  { icon: "heart", t: "CT may compensate you directly during day treatment · FMLA help" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const groupTopics = [
  ["Trauma processing", "Discussing specific incidents that have had a significant emotional impact."],
  ["Stress management", "Techniques for managing acute and chronic stress in high-pressure situations."],
  ["Work-life balance", "Strategies for protecting your well-being alongside demanding job responsibilities."],
  ["Peer support", "Building resilience through shared stories and mutual support."],
];
const whyMatters = [
  ["Exposure to trauma", "Regular exposure to traumatic events leads to cumulative stress and emotional fatigue."],
  ["Stigma", "Many fear that seeking help will be seen as weakness or could affect their career."],
  ["Support systems", "Access to counseling and peer support is vital for coping and resilience."],
  ["Self-care", "Mindfulness, physical activity, and hobbies help manage stress."],
  ["Education & training", "Learning the signs of distress — in yourself and colleagues — saves careers and lives."],
];
const conditions = [
  ["Burnout", "Emotional exhaustion, depersonalization (a cynical attitude toward the job and the people you serve), and a reduced sense of personal accomplishment."],
  ["Acute stress reactions", "Anger, irritability, sadness, numbness, nightmares, intrusive thoughts — plus physical effects on sleep, appetite, and energy. Usually begins right after a traumatic event and lasts up to a month."],
  ["PTSI — Post-Traumatic Stress Injury", "Nightmares, flashbacks, hypervigilance, chronic pain, headaches, irritability, emotional outbursts, sleep disturbance, and trouble concentrating. Can continue from acute stress or surface six+ months later."],
];
const approach = [
  { icon: "heart", t: "Healing beyond words", d: "Experiential therapies help you explore emotions and process trauma in non-verbal, embodied ways — through movement, creative expression, and connection with therapy animals." },
  { icon: "link", t: "Optional family involvement", d: "Healing often means rebuilding relationships. We offer family sessions and psychoeducation to foster understanding and support at home." },
  { icon: "users", t: "A holistic care team", d: "Clinicians, psychiatric providers, and experiential therapists collaborate on a plan aligned with your values, goals, and needs." },
  { icon: "brain", t: "Foundational DBT & CBT skills", d: "Build essential tools in mindfulness, emotion regulation, distress tolerance, interpersonal effectiveness, and cognitive restructuring." },
];
const toneMap = { azul: "bg-azul-light text-azul", gold: "bg-gold-light text-gold", sage: "bg-sage-light text-sage" };
const modalities = [
  { t: "Group therapy grounded in DBT & CBT", icon: "users" },
  { t: "Individual therapy for personalized support", icon: "heart" },
  { t: "Optional medication management & psychiatric care", icon: "pill" },
  { t: "Psychoeducation", icon: "clipboard" },
];
const ptg = ["Greater appreciation of life", "Improved relationships", "Renewed strength & purpose", "New interests & outlooks", "Reduced anxiety, depression & emotional overwhelm", "Reduced hypervigilance & distressing memories", "Decreased reliance on substances or harmful behaviors"];
const TM = "/Assets/Team%20Members/";
const team = [
  { n: "Tim Hall, LPC-A", role: "Program Lead · Retired Police Officer", photo: null, d: "A retired Bristol Police Officer with 10 years of service — Officer of the Year, Life Saving Awards, Silver Stars, and Distinguished Service. As a Peer Support Specialist he built programs to help fellow officers, then earned his M.S. in Clinical Mental Health Counseling. He now dedicates his career to helping police, fire, dispatch, corrections, and EMS professionals and their families heal." },
  { n: "Victor J.R. Duphily III, LPC", role: "Counselor · Former Officer & Army Veteran", photo: null, d: "M.S. in Clinical Mental Health Counseling from Southern CT State University, with a career dedicated to veterans and first responders coping with service-related trauma — across the New Haven Vet Center, Wheeler Clinic, and CMHA's Veteran Support Program. As a former police officer and U.S. Army veteran, he brings firsthand understanding." },
  { n: "Christopher Patenaude, PA", role: "Medication Management", photo: TM + "chris-patenaude-pa.webp", d: "A board-certified physician assistant specializing in outpatient psychiatry. He provides compassionate, evidence-based care for adults with ADHD, bipolar disorder, and treatment-resistant depression — valuing open communication and collaboration." },
  { n: "Katherine Salvador, PA-C", role: "Medication Management", photo: TM + "katherine-salvador-pa-c.webp", d: "Over nine years of experience in community mental health and addiction treatment, providing evidence-based care for mood, anxiety, and substance use disorders. She integrates medication management with mindfulness and psychotherapy for holistic healing." },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Julie Stevens", t: "2 months ago", q: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { n: "Jake Sted", t: "2 months ago", q: "Hopewell’s IOP program made a huge difference in my life. The groups were engaging, and the therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day." },
  { n: "stacey miller", t: "3 months ago", q: "They put me on the schedule as a new patient within the same week of calling, which never happens, and made sure my insurance was accepted. The provider and staff were very professional and kind." },
  { n: "Cynthia Askew", t: "6 months ago", q: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
  { n: "Joana Yoo", t: "10 months ago", q: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
];
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["Glastonbury", "33 Pratt St, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.0462929427076!2d-72.6158734!3d41.7195199!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f7540001%3A0x207d1c58279c2917!2sKristine%20Schlichting!5e0!3m2!1sen!2sus!4v1781754351066!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const faqs = [
  ["Who is the First Responder IOP for?", "Current or retired first responders 18+ — police officers, firefighters, EMS professionals, corrections officers, and 9-1-1 dispatchers — managing trauma, burnout, acute stress, or PTSI."],
  ["What’s the schedule?", "Monday–Thursday, 9:00 AM–12:00 PM (three hours a day), for about 8 weeks at 300 Hebron Ave, Glastonbury, with ongoing progress evaluations."],
  ["Is it confidential?", "Yes — we provide a safe, confidential space built specifically for first responders, led by clinicians who have served. Seeking support is a mark of strength, not weakness."],
  ["How is it paid for?", "We accept most major insurance, including Tricare. In some cases the State of Connecticut may compensate you directly while you’re in day treatment, and many qualify for FMLA or CT Paid Leave — our team handles the paperwork."],
];
---

<Base title="First Responder IOP in CT | Hopewell Health Solutions" description="A First Responder Intensive Outpatient Program at Hopewell Health Solutions, Glastonbury CT — designed by first responders, for first responders. Trauma, burnout & PTSI care. Mon–Thu, ~8 weeks. Tricare accepted.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/programs/intensive-outpatient-program/" class="hover:text-azul">IOP</a> / <span class="text-ink">First Responder</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">First Responder IOP · Glastonbury, CT · Now enrolling</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">First Responder Intensive Outpatient Program (IOP)</h1>
          <p class="mt-3 font-display text-xl text-azul italic">Designed by first responders, for first responders.</p>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews · “best IOP in the area”</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8609460447" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 946-0447</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Christopher Patenaude, PA</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="Confidential intake" sub="A safe space built for first responders. Free, confidential insurance check." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/AdobeStock_404268940.webp" alt="First responder peer support group at Hopewell Health Solutions, Glastonbury CT" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">By those who serve, for those who serve</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">Specialized care for those who answer the call</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Our First Responder IOP is designed by first responders, for first responders. We understand the unique challenges of those who serve and protect — and we offer specialized care that supports both your mental health and your career longevity.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">In a safe, confidential space, you can process your experiences, learn coping strategies, and grow stronger — personally and professionally. Whether you’re stepping down from inpatient care, need more than weekly therapy, or are navigating work while managing your mental health, <strong>seeking support is a mark of strength.</strong></p>
      </div>
    </div>
  </section>

  <!-- PROGRAM LOGISTICS + GROUP TOPICS (text left / image right) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="lg:order-2"><img src="/Assets/guy%20thinking%20worried.webp" alt="A first responder working through stress and trauma" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" /></div>
      <div class="lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Flexible, compassionate, comprehensive</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">How the program works</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Built for first responders 18+, the program runs <strong>Monday–Thursday, 9:00 AM–12:00 PM</strong> (three hours a day) for about 8 weeks, with ongoing progress evaluations and individualized care updates.</p>
        <p class="mt-5 text-sm font-semibold uppercase tracking-wide text-azul">Common topics in group therapy</p>
        <ul class="mt-3 space-y-2.5">
          {groupTopics.map(([t, d]) => <li class="flex gap-3 text-ink"><span class="mt-1.5 h-1.5 w-1.5 shrink-0 rounded-full bg-azul"></span><span class="leading-snug"><strong>{t}:</strong> {d}</span></li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- WHY IT MATTERS -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">It takes a toll</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Why first responder mental health matters</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">The stress of emergencies, trauma, and high-pressure situations often leads to PTSD, anxiety, and depression. A culture of openness makes all the difference.</p>
      </div>
      <div class="mt-10 space-y-3">
        {whyMatters.map(([t, d], i) => (
          <div class="flex items-start gap-4 rounded-xl bg-crema border border-line p-5">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-full bg-azul text-white font-display">{i + 1}</span>
            <p class="text-ink leading-snug"><strong>{t}.</strong> {d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- IS THIS RIGHT FOR YOU -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Make the right choice</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Is this program right for you?</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">For current or retired <strong>police officers, firefighters, EMS professionals, corrections officers, and 9-1-1 dispatchers.</strong> These experiences can lead to:</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-5">
        {conditions.map(([t, d]) => (
          <div class="rounded-2xl bg-white border border-line p-7">
            <span class="grid h-11 w-11 place-items-center rounded-xl bg-azul-light text-azul"><Icon name="alert" class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl text-ink leading-tight">{t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- MULTIMODAL APPROACH -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">More than just talk therapy</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">A multimodal treatment approach</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">We blend clinical therapy with creative and relational approaches to promote true mind–body healing.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {approach.map((a) => (
          <div class="rounded-2xl border border-line bg-crema p-6">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={a.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug">{a.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{a.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PTG + MODALITIES -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-12 lg:gap-16 items-center">
      <div>
        <h2 class="font-display text-3xl text-ink">Modalities used</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <div class="mt-6 grid grid-cols-1 sm:grid-cols-2 gap-3">
          {modalities.map((m) => (
            <div class="flex items-center gap-3 rounded-xl bg-white border border-line p-3.5">
              <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={m.icon} class="h-5 w-5" /></span>
              <span class="text-sm font-semibold text-ink leading-tight">{m.t}</span>
            </div>
          ))}
        </div>
        <p class="mt-5 text-sm text-muted">Plus <a href="/programs/medication-management/" class="text-azul font-semibold">medication management</a> &amp; experiential therapies.</p>
      </div>
      <div>
        <h2 class="font-display text-4xl sm:text-5xl text-ink leading-[1.1]">Post-traumatic growth</h2>
        <div class="mt-5 h-px w-16 bg-gold"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">With the right support, first responders can move beyond survival toward growth — reclaiming the nervous system and finding:</p>
        <ul class="mt-6 grid sm:grid-cols-2 gap-x-6 gap-y-3">
          {ptg.map((o) => <li class="flex gap-2.5 text-ink"><span class="text-azul mt-1 shrink-0"><Icon name="shield" class="h-4 w-4" /></span><span class="leading-snug">{o}</span></li>)}
        </ul>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Built by people who understand</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Personal, proven, and built from the ground up</h2>
        <p class="mt-3 text-muted">Our program was created by people who understand exactly what you face.</p>
      </div>
      <div class="mt-10 grid md:grid-cols-2 gap-5">
        {team.map((m) => (
          <div class="rounded-2xl bg-crema border border-line p-7 flex gap-4">
            {m.photo
              ? <img src={m.photo} alt={m.n} loading="lazy" class="h-14 w-14 shrink-0 rounded-full object-cover" />
              : <span class="grid h-14 w-14 shrink-0 place-items-center rounded-full bg-azul text-white font-display text-lg">{m.n.charAt(0)}</span>}
            <div>
              <h3 class="font-display text-lg text-ink leading-tight">{m.n}</h3>
              <p class="text-xs font-semibold uppercase tracking-wide text-azul">{m.role}</p>
              <p class="mt-2 text-sm text-muted leading-relaxed">{m.d}</p>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
