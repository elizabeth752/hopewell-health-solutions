---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";

const heroUsps = [
  { icon: "clipboard", t: "Assessment, therapy & medication — often in a single visit" },
  { icon: "calendar", t: "Same-day appointments, in person or virtual across CT" },
  { icon: "users", t: "Ages 4 & up — children, teens & adults (incl. ADHD)" },
  { icon: "dna", t: "GeneSight® testing for precision prescribing" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const L = "/Assets/Media%20Appearances/";
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["Glastonbury", "33 Pratt St, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.0462929427076!2d-72.6158734!3d41.7195199!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f7540001%3A0x207d1c58279c2917!2sKristine%20Schlichting!5e0!3m2!1sen!2sus!4v1781754351066!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const treats = [
  { t: "Anxiety & depression", icon: "cloud" },
  { t: "Bipolar disorder", icon: "swap" },
  { t: "ADHD", icon: "bolt" },
  { t: "OCD", icon: "refresh" },
  { t: "Trauma & PTSD", icon: "shield" },
  { t: "Substance use & addiction", icon: "pill" },
  { t: "Sleep disturbance", icon: "sun" },
  { t: "Life transitions & self-esteem", icon: "compass" },
  { t: "Sex & sexuality", icon: "users" },
];
const moreThanMed = [
  { icon: "brain", t: "TMS", d: "Non-invasive, FDA-cleared therapy for treatment-resistant depression.", href: "/treatment-methods/tms/" },
  { icon: "sparkles", t: "Spravato®", d: "An option for treatment-resistant depression, given under clinical supervision.", href: "/treatment-methods/spravato/" },
  { icon: "shield", t: "Medication-Assisted Treatment", d: "Evidence-based medication support for opioid and alcohol use.", href: "/treatment-methods/medication-assisted-treatment/" },
  { icon: "users", t: "IOP & PHP", d: "Step up to structured day programs when more support is needed.", href: "/programs/adult-mental-health-iop/" },
];
const howItWorks = [
  ["Prescribing", "We start by prescribing the right medication to relieve your symptoms, drawing on deep knowledge of what helps your condition."],
  ["Monitoring", "Most psychiatric medications take time to work, so you’ll have routine check-ins to review your symptoms, overall health, and any side effects."],
  ["Adjusting", "If needed, we adjust the dose or switch medications — different drugs work in different ways — until we reach the results you’re looking for."],
];
const toneMap = { azul: "bg-azul-light text-azul", gold: "bg-gold-light text-gold", sage: "bg-sage-light text-sage" };
const unique = [
  { icon: "clipboard", tone: "azul", t: "One visit, often same-day", d: "Assessment, therapy, and medication together — less runaround, more progress." },
  { icon: "swap", tone: "gold", t: "Your care, your choice", d: "Keep your current therapist, work with one of ours, or go medication-only." },
  { icon: "dna", tone: "sage", t: "Precision with GeneSight®", d: "Genetic testing matches medications to your biology — less trial and error." },
  { icon: "shield", tone: "azul", t: "Accredited, full continuum", d: "Joint Commission accredited, with TMS, Spravato, IOP & PHP if you ever need more." },
];
const press = [
  { outlet: "Hartford Courant", logo: L + "hartford.webp", date: "Feb 2023", title: "Hopewell opens first privately owned IOP mental health clinic in Glastonbury", href: "https://www.courant.com/2023/02/24/hopewell-solutions-opens-first-privately-owned-iop-mental-health-clinic-in-glastonbury/" },
  { outlet: "Hartford Business Journal", logo: L + "hbj-logo-v3.png", date: "Honoree", title: "Kristine Schlichting — recognized leader in behavioral health", href: "https://hartfordbusiness.com/honoree/kristine-schlichting/" },
  { outlet: "FOX61", logo: L + "fox61.png", date: "2023", title: "Glastonbury psychologist is helping teen girls and new moms find support", href: "https://www.fox61.com/article/news/local/outreach/awareness-months/glastonbury-psychologist-is-helping-teen-girls-and-new-moms-find-support/520-84d3fd3f-1cec-40bc-9d4c-65f7b6a4d2e9" },
  { outlet: "NBC Connecticut", logo: L + "nbc-connecticut.png", date: "CT Live!", title: "CT Live!: Trauma in Women — with a Hopewell clinician", href: "/media/" },
];
// Reviews are verbatim from Google Business Profile, with the real reviewer's
// name — never anonymized or relabeled. See feedback-hopewell-reviews-gbp-exact.
const reviews = [
  { n: "Joana Yoo", t: "10 months ago", q: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
  { n: "Cynthia Askew", t: "6 months ago", q: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "Jake Sted", t: "2 months ago", q: "The therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day. Hopewell made a huge difference in my life." },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const faqs = [
  ["Do I have to do therapy to get medication here?", "No — you can keep your current therapist, work with one of ours, or do medication management only. It’s your choice."],
  ["What ages do you treat?", "Ages 4 and up — children, teens, and adults, including ADHD evaluation and support."],
  ["What is GeneSight testing?", "A simple cheek swab that shows how your genetics may affect your response to medications, so we can find the right fit faster."],
  ["Can I get a same-day or virtual appointment?", "Often, yes — we offer same-day appointments and virtual visits across Connecticut."],
  ["Will my insurance cover it?", "Most major PPO plans do. We’ll verify your benefits for free (we don’t accept Medicaid / HUSKY)."],
];
---

<Base title="Medication Management in CT | Hopewell Health Solutions" description="Psychiatric medication management at Hopewell Health Solutions in CT — assessment, therapy & meds in one visit. Ages 4+, GeneSight testing. Most insurance accepted.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/#programs" class="hover:text-azul">Programs</a> / <span class="text-ink">Medication Management</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Medication Management &amp; Psychiatry · Glastonbury, CT · In person &amp; virtual</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Medication Management &amp; Psychiatric Care in Connecticut</h1>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <p class="mt-5 text-ink leading-relaxed text-[17px] max-w-xl">Getting the right medication shouldn’t feel like a guessing game. Psychiatric care at Hopewell Health Solutions is thoughtful, collaborative, and built around you.</p>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews · every provider 5-star rated</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8607351448" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 735-1448</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Katrin Moskowitz, DNP, PMHNP-BC</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/Comprehensive%20Tailored%20Care.webp" alt="Psychiatric medication management at Hopewell Health Solutions, Glastonbury CT" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Psychiatric care, built around you</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What is medication management?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Medication management is ongoing psychiatric care — a thorough evaluation, an accurate diagnosis, a personalized medication plan, and regular follow-ups to fine-tune it as you go. Our providers are specifically trained in psychiatric diagnoses, treatments, and medications.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">It’s essential care for promoting mental health, preventing things from getting worse, and meeting each person where they are. And we don’t put limits on your care — keep your current therapist, work with one of ours, or skip therapy altogether. It’s your call.</p>
      </div>
    </div>
  </section>

  <!-- ONE VISIT (text left / image right) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="lg:order-2"><img src="/Assets/women%20looking%20at%20me.webp" alt="A patient in control of her psychiatric care in Connecticut" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" /></div>
      <div class="lg:order-1">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Less runaround, more progress</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">Assessment, therapy &amp; meds in one visit</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Most practices make you bounce between a prescriber and a therapist. At Hopewell Health Solutions, you can get assessment, talk therapy, and medication in a single visit — and often a same-day appointment.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">We care for ages 4 and up — children, teens, and adults, including kids who need ADHD evaluation and support. Whether you’re starting medication for the first time or your longtime psychiatrist is retiring, we’ll build a plan you’re comfortable with.</p>
        <div class="mt-6 rounded-xl bg-white border border-azul/30 p-5">
          <h3 class="font-display text-xl text-ink">Your care, your choice</h3>
          <div class="mt-3 flex flex-wrap gap-2">
            <span class="rounded-full bg-azul-light px-3 py-1 text-sm font-semibold text-azul">Keep your therapist</span>
            <span class="rounded-full bg-azul-light px-3 py-1 text-sm font-semibold text-azul">Work with ours</span>
            <span class="rounded-full bg-azul-light px-3 py-1 text-sm font-semibold text-azul">Medication-only</span>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- HOW IT WORKS (3-step) -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">How it works</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">What medication management includes</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-5">
        {howItWorks.map(([t, d], i) => (
          <div class="rounded-2xl border border-line bg-crema p-7">
            <span class="grid h-11 w-11 place-items-center rounded-full bg-azul text-white font-display text-lg">{i + 1}</span>
            <h3 class="mt-4 font-display text-xl text-ink">{t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- GENESIGHT (highlight band) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <span class="inline-grid h-14 w-14 place-items-center rounded-2xl bg-azul-light text-azul"><Icon name="dna" class="h-7 w-7" /></span>
      <p class="mt-5 text-xs font-semibold uppercase tracking-[0.15em] text-azul">Precision prescribing</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Find the right fit faster with GeneSight®</h2>
      <p class="mt-5 text-ink leading-relaxed text-[17px]">When it helps, we use GeneSight® pharmacogenomic testing — a simple cheek swab that shows how your body is likely to respond to different medications. Instead of trial-and-error, we use your biology to find the right fit faster.</p>
      <a href="/treatment-methods/genesight-testing/" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-azul hover:text-azul-dark transition">Learn about GeneSight® testing <Icon name="arrow" class="h-4 w-4" /></a>
    </div>
  </section>

  <!-- WHAT WE TREAT -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">What we treat</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Psychiatric care for a wide range of concerns</h2>
      </div>
      <div class="mt-10 grid grid-cols-2 md:grid-cols-3 gap-4">
        {treats.map((c) => (
          <div class="flex items-center gap-3 rounded-xl bg-crema border border-line p-4">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={c.icon} class="h-5 w-5" /></span>
            <span class="text-sm font-semibold text-ink leading-tight">{c.t}</span>
          </div>
        ))}
      </div>
      <p class="mt-6 text-center text-sm text-muted">Explore how we treat <a href="/what-we-treat/anxiety/" class="text-azul font-semibold">anxiety</a>, <a href="/what-we-treat/depression/" class="text-azul font-semibold">depression</a>, <a href="/what-we-treat/adhd/" class="text-azul font-semibold">ADHD</a>, <a href="/what-we-treat/ocd/" class="text-azul font-semibold">OCD</a> &amp; <a href="/what-we-treat/trauma-ptsd/" class="text-azul font-semibold">trauma</a>.</p>
    </div>
  </section>

  <!-- MORE THAN MEDICATION -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center max-w-2xl mx-auto">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">More than medication</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Connected to a full continuum of care</h2>
        <p class="mt-3 text-muted">Medication is one tool, not the whole toolbox. When it’s the right fit, we connect your care to:</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {moreThanMed.map((m) => (
          <a href={m.href} class="group rounded-2xl border border-line bg-white p-6 hover:border-azul hover:shadow-lg transition flex flex-col">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={m.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug group-hover:text-azul transition">{m.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{m.d}</p>
            <span class="mt-3 inline-flex items-center gap-1 text-sm font-semibold text-azul">Learn more <Icon name="arrow" class="h-4 w-4" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- QUOTE BAND -->
  <section class="relative">
    <img src="/Assets/AdobeStock_404268940.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-ink/80"></div>
    <div class="relative mx-auto max-w-3xl px-5 py-20 text-center">
      <p class="font-display text-2xl sm:text-3xl text-white leading-snug">Providers who make sure you “leave with zero questions.”</p>
      <p class="mt-4 text-white/85 text-lg">Every one of our medication-management providers holds a 5-star Google rating.</p>
    </div>
  </section>

  <!-- WHY CHOOSE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Why families choose Hopewell</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Why people choose us for psychiatric care</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {unique.map((u) => (
          <div class="rounded-2xl border border-line bg-crema p-6">
            <span class={`grid h-12 w-12 place-items-center rounded-xl ${toneMap[u.tone]}`}><Icon name={u.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug">{u.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{u.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PRESS & FEATURES (credibility variation) -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">In the news</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Trusted &amp; featured across Connecticut</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {press.map((p) => (
