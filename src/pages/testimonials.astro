---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";

const canonical = "https://www.hopewellhealthsolutions.com/testimonials/";

// Verbatim Google Business Profile reviews (the approved, real set — never fabricated).
const featured = { name: "Lee", meta: "Local Guide · IOP graduate", text: "I truly loved this IOP. I recently graduated and can honestly say it has been pivotal to my healing journey and my life in general. In the beginning I was insanely skeptical about group therapy… but the group setting, the therapists, and the other members made it such a safe, welcoming, and supportive space. I learned tools I’ll carry with me for life, and the group gave me a safe place to start the deep work I couldn’t have done alone. If you’re considering IOP or Hopewell, trust me — you should do it." };
const reviews = [
  { name: "Julie Stevens", meta: "2 months ago", text: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { name: "Jake Sted", meta: "2 months ago", text: "Hopewell’s IOP program made a huge difference in my life. The groups were engaging, and the therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day." },
  { name: "Emily Ross", meta: "8 months ago", text: "This is the best therapy place I have ever been to. I started in their Women’s Wellness IOP and all the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { name: "Joana Yoo", meta: "10 months ago", text: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
  { name: "stacey miller", meta: "3 months ago", text: "They put me on the schedule as a new patient within the same week of calling, which never happens, and made sure my insurance was accepted. The provider and staff were very professional and kind." },
  { name: "Cynthia Askew", meta: "6 months ago", text: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
];

const googleG = '<svg viewBox="0 0 24 24" class="h-5 w-5" aria-hidden="true"><path fill="#4285F4" d="M23.49 12.27c0-.79-.07-1.54-.19-2.27H12v4.51h6.47a5.4 5.4 0 0 1-2.4 3.58v3h3.86c2.26-2.09 3.56-5.17 3.56-8.82z"/><path fill="#34A853" d="M12 24c3.24 0 5.95-1.08 7.93-2.91l-3.86-3c-1.08.72-2.45 1.16-4.07 1.16-3.13 0-5.78-2.11-6.73-4.96H1.29v3.09A11.99 11.99 0 0 0 12 24z"/><path fill="#FBBC05" d="M5.27 14.29a7.2 7.2 0 0 1 0-4.58V6.62H1.29a12 12 0 0 0 0 10.76l3.98-3.09z"/><path fill="#EA4335" d="M12 4.74c1.77 0 3.35.61 4.6 1.8l3.42-3.42C17.95 1.19 15.24 0 12 0 7.31 0 3.26 2.69 1.29 6.62l3.98 3.09C6.22 6.85 8.87 4.74 12 4.74z"/></svg>';
---

<Base title="Testimonials & Reviews | Hopewell Health Solutions" description="Hear from Hopewell Health Solutions clients — real Google reviews and videos about our IOP, therapy, and psychiatry programs in Glastonbury, Westbrook & West Hartford, Connecticut." canonical={canonical}>
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center">
      <nav class="text-xs text-muted mb-5"><a href="/" class="hover:text-azul">Home</a> / <span class="text-ink">Testimonials</span></nav>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">In their words</p>
      <h1 class="mt-3 font-display text-4xl sm:text-5xl text-ink">Testimonials &amp; Reviews</h1>
      <div class="mx-auto mt-5 h-px w-16 bg-gold"></div>
      <p class="mt-5 inline-flex items-center gap-2 text-muted"><Fragment set:html={googleG} /> <span class="text-gold">★★★★★</span> <strong class="text-ink">4.8</strong> · 368 Google reviews</p>
    </div>
  </section>

  <!-- WRITTEN REVIEWS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="flex items-center justify-center gap-2">
        <Fragment set:html={googleG} />
        <h2 class="font-display text-3xl sm:text-4xl text-ink">What our clients say</h2>
      </div>

      <!-- featured -->
      <figure class="mx-auto mt-10 max-w-3xl rounded-3xl bg-white border border-line p-8 text-center">
        <div class="text-gold">★★★★★</div>
        <blockquote class="mt-4 font-display text-xl sm:text-2xl text-ink leading-snug">“{featured.text}”</blockquote>
        <figcaption class="mt-4 text-sm text-muted"><span class="font-semibold text-ink">{featured.name}</span> · {featured.meta}</figcaption>
      </figure>

      <!-- grid -->
      <div class="mt-8 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {reviews.map((r) => (
          <figure class="flex flex-col rounded-2xl bg-white border border-line p-6">
            <div class="text-gold text-sm">★★★★★</div>
            <blockquote class="mt-3 text-ink leading-relaxed text-[15px] flex-1">“{r.text}”</blockquote>
            <figcaption class="mt-4 text-sm text-muted"><span class="font-semibold text-ink">{r.name}</span> · {r.meta}</figcaption>
          </figure>
        ))}
      </div>

      <div class="mt-10 text-center">
        <a href="https://www.google.com/search?q=Hopewell+Health+Solutions+reviews" target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg border border-azul px-6 py-3 text-sm font-semibold text-azul hover:bg-azul-light transition"><Fragment set:html={googleG} />Read all reviews on Google</a>
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">Ready to write your own story?</h2>
      <p class="mt-4 text-white/85 text-lg">Reach out to our Connecticut team today — confidentially, with no pressure.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
        <a href="/admissions/" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition">Get started</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>
