---
import Base from "../layouts/Base.astro";
---

<Base
  title="Hopewell Health Solutions"
  description="Compassionate, evidence-based behavioral health care."
>
  <main class="min-h-screen flex items-center justify-center bg-crema px-6">
    <div class="max-w-2xl text-center">
      <p class="text-azul font-semibold tracking-wide uppercase text-sm">
        Hopewell Health Solutions
      </p>
      <h1 class="mt-4 text-5xl sm:text-6xl text-ink text-balance">
        There is hope to heal.
      </h1>
      <p class="mt-6 text-lg text-muted">
        Connecticut's intensive programs center for mental wellness &amp; psychiatry.
      </p>
      <a
        href="tel:8609460447"
        class="mt-8 inline-block rounded-lg bg-azul px-7 py-3.5 font-semibold text-white transition hover:bg-azul-dark"
      >
        Call (860) 946-0447
      </a>
    </div>
  </main>
</Base>
