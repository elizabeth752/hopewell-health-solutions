---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import LeadForm from "../components/LeadForm.astro";
import MediaStrip from "../components/MediaStrip.astro";

const credibility = [
  "★ 4.8 · 368 Google reviews", "Joint Commission accredited (Gold Seal)", "47 licensed clinicians",
  "6 Connecticut locations", "Serving CT since 2013", "Featured on Eyewitness News 3",
  "In-network with most major plans", "Care for ages 4 & up",
];
const usps = [
  { icon: "brain", t: "TMS for treatment-resistant depression", d: "FDA-cleared, drug-free, no downtime — for when medication and therapy haven’t been enough." },
  { icon: "dna", t: "GeneSight® genetic testing", d: "A simple cheek swab shows which medications fit your DNA — so we skip the trial-and-error." },
  { icon: "users", t: "47 specialists you’ll actually meet", d: "Psychologists, psychiatric NPs & trauma experts — matched to you by name, not an algorithm." },
  { icon: "sparkles", t: "Programs hospitals don’t offer", d: "Women’s, Men’s, Teen, Tween & First Responder IOP — built for who you are." },
];
const programs = [
  { t: "Adult IOP", d: "Structured therapy 3–5 days a week, while you live at home.", href: "/programs/adult-mental-health-iop/", icon: "users", img: "/Assets/AdobeStock_403830351.webp" },
  { t: "Women’s Wellness IOP", d: "Trauma-informed care in a women-only group.", href: "/programs/womens-wellness-iop/", icon: "heart", img: "/Assets/women%20looking%20at%20me.webp" },
  { t: "Teen & Tween IOP", d: "After-school support for ages 8–18, with family involvement.", href: "/programs/teen-iop/", icon: "sparkles", img: "/Assets/teen%20smiling.webp" },
  { t: "Partial Hospitalization (PHP)", d: "Day treatment when weekly therapy isn’t enough.", href: "/programs/partial-hospitalization-program/", icon: "shield", img: "/Assets/AdobeStock_542909901.webp" },
  { t: "Medication Management", d: "Expert psychiatric prescribing, ages 4 and up.", href: "/programs/medication-management/", icon: "pill", img: "/Assets/AdobeStock_404268940.webp" },
  { t: "Outpatient Therapy", d: "Individual, couples & family counseling.", href: "/programs/outpatient-therapy/", icon: "heart", img: "/Assets/couple%20hugging.webp" },
];
const conditions = [
  { t: "Depression", icon: "cloud" }, { t: "Anxiety", icon: "alert" }, { t: "Trauma & PTSD", icon: "heart" },
  { t: "ADHD", icon: "bolt" }, { t: "Bipolar Disorder", icon: "swap" }, { t: "OCD", icon: "refresh" },
  { t: "Substance Use", icon: "pill" }, { t: "Co-occurring Disorders", icon: "link" },
];
const continuum = [
  { t: "Outpatient Therapy", d: "Weekly individual, couples & family sessions", level: 1 },
  { t: "Intensive Outpatient (IOP)", d: "3 hrs/day · 4 days/week · day or evening", level: 2 },
  { t: "Partial Hospitalization (PHP)", d: "6 hrs/day · 5 days/week — highest outpatient level", level: 3 },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const team = [
  ["Kristine A. Schlichting, PhD","Founder & Director","/Assets/Team%20Members/kristine-a-schlichting-phd.webp"],
  ["Katrin Moskowitz, DNP","Psychiatric NP","/Assets/Team%20Members/katrin-moskowitz-dnp-pmhnp-bc-fnp.webp"],
  ["Tracy Sibley, PMHNP-BC","Psychiatric NP","/Assets/Team%20Members/tracy-sibley-pmhnp-bc-aprn.webp"],
  ["Laura Miller, PhD","Neuropsychology","/Assets/Team%20Members/laura-miller-phd.webp"],
  ["Eric Schwartz, PsyD","Psychologist","/Assets/Team%20Members/eric-schwarz-psyd-abpp.webp"],
  ["TJ Aitken, CPSRP","Business Development","/Assets/Team%20Members/tj-aitken-cpsrp.webp"],
];
const featured = { name: "Lee", meta: "Local Guide · IOP graduate", text: "I truly loved this IOP. I recently graduated and can honestly say it has been pivotal to my healing journey and my life in general. In the beginning I was insanely skeptical about group therapy… but the group setting, the therapists, and the other members made it such a safe, welcoming, and supportive space. I learned tools I’ll carry with me for life, and the group gave me a safe place to start the deep work I couldn’t have done alone. If you’re considering IOP or Hopewell, trust me — you should do it." };
const reviews = [
  { name: "Julie Stevens", meta: "2 months ago", text: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { name: "Jake Sted", meta: "2 months ago", text: "Hopewell’s IOP program made a huge difference in my life. The groups were engaging, and the therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day." },
  { name: "Emily Ross", meta: "8 months ago", text: "This is the best therapy place I have ever been to. I started in their Women’s Wellness IOP and all the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { name: "Joana Yoo", meta: "10 months ago", text: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
  { name: "stacey miller", meta: "3 months ago", text: "They put me on the schedule as a new patient within the same week of calling, which never happens, and made sure my insurance was accepted. The provider and staff were very professional and kind." },
  { name: "Cynthia Askew", meta: "6 months ago", text: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
];
const steps = [
  { icon: "phone", t: "Reach out", d: "Call us, or request a confidential callback." },
  { icon: "shield", t: "Verify insurance", d: "We check your benefits for you — free." },
  { icon: "clipboard", t: "Assessment", d: "A clinical assessment to match your needs." },
  { icon: "compass", t: "Begin care", d: "Start at the right level — and adjust as you heal." },
];
const Stars = `<span class="text-yellow-400 tracking-tight">★★★★★</span>`;
---

<Base title="Hopewell Health Solutions | Mental Health & Psychiatry CT" description="Outpatient mental health & psychiatry across Connecticut — IOP, PHP, TMS & medication management. 4.8★, Joint Commission accredited. Verify your insurance.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 lg:py-20 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Mental Health &amp; Psychiatry · In person across Connecticut</p>
        <h1 class="mt-4 font-display text-5xl sm:text-6xl text-ink leading-[1.05]">There is hope to heal.</h1>
        <p class="mt-5 text-lg text-muted max-w-xl leading-relaxed">Connecticut’s most trusted outpatient mental-health team — intensive programs, psychiatry, medication management, and TMS, delivered in person by clinicians who know your name.</p>
        <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink">
          <span><span class="text-yellow-400">★★★★★</span> <strong>4.8</strong> · 368 reviews</span>
          <span class="text-line">|</span><span class="inline-flex items-center gap-1.5"><Icon name="shield" class="h-4 w-4 text-azul" />Joint Commission accredited</span>
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="#verify" class="rounded-lg bg-azul px-7 py-3.5 font-semibold text-white hover:bg-azul-dark transition">Verify Your Insurance →</a>
          <a href="tel:8609460447" class="inline-flex items-center gap-2 rounded-lg border border-azul px-7 py-3.5 font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-4 w-4" />(860) 946-0447</a>
        </div>
      </div>
      <div id="verify" class="scroll-mt-28"><LeadForm /></div>
    </div>
  </section>

  <!-- CREDIBILITY SLIDER -->
  <section class="bg-ink text-white py-4 overflow-hidden">
    <div class="marquee">
      {[...credibility, ...credibility].map((c) => (
        <span class="flex items-center gap-2 px-7 text-sm whitespace-nowrap"><span class="text-azul-light">◆</span>{c}</span>
      ))}
    </div>
  </section>

  <MediaStrip bg="crema" />

  <!-- FOR ME / LOVED ONE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <h2 class="font-display text-3xl sm:text-4xl text-ink text-center">Where would you like to begin?</h2>
      <p class="mt-3 text-center text-muted max-w-2xl mx-auto">One in five U.S. adults lives with a mental health condition. You are not alone — and you don’t have to navigate this alone.</p>
      <div class="mt-8 grid sm:grid-cols-2 gap-5 max-w-4xl mx-auto">
        <div class="rounded-2xl border border-line bg-crema p-7 flex gap-4">
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-azul text-white"><Icon name="heart" class="h-6 w-6" /></span>
          <div><h3 class="font-display text-2xl text-ink">Help for myself</h3><p class="mt-1 text-muted">Taking the first step takes courage. We’ll make the next ones simple.</p><a href="#programs" class="mt-3 inline-block font-semibold text-azul">Find my program →</a></div>
        </div>
        <div class="rounded-2xl border border-line bg-crema p-7 flex gap-4">
          <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-azul text-white"><Icon name="users" class="h-6 w-6" /></span>
          <div><h3 class="font-display text-2xl text-ink">Help for someone I love</h3><p class="mt-1 text-muted">A child, partner, or parent who’s struggling? We’ll help you help them.</p><a href="#verify" class="mt-3 inline-block font-semibold text-azul">Get guidance →</a></div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY (USPs) — standout -->
  <section id="why" class="bg-ink text-white scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.15em] text-azul-light">Why Hopewell</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-white text-center">Care you can’t get just anywhere</h2>
      <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {usps.map((u) => (
          <div class="rounded-2xl bg-white/5 ring-1 ring-white/10 p-7 hover:bg-white/10 transition">
            <span class="grid h-14 w-14 place-items-center rounded-2xl bg-azul text-white"><Icon name={u.icon} class="h-7 w-7" /></span>
            <h3 class="mt-5 font-display text-xl text-white leading-snug">{u.t}</h3>
            <p class="mt-2 text-sm text-white/70 leading-relaxed">{u.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROGRAMS (photo cards) -->
  <section id="programs" class="bg-white scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <h2 class="font-display text-3xl sm:text-4xl text-ink">Find the right level of care</h2>
      <p class="mt-3 text-muted max-w-2xl">A full continuum under one roof — step up or down as you heal.</p>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {programs.map((p) => (
          <a href={p.href} class="group rounded-2xl overflow-hidden border border-line bg-white hover:shadow-xl hover:-translate-y-0.5 transition">
            <div class="relative h-40 overflow-hidden">
              <img src={p.img} alt={p.t} loading="lazy" class="h-full w-full object-cover group-hover:scale-105 transition duration-500" />
              <span class="absolute bottom-3 left-3 grid h-11 w-11 place-items-center rounded-xl bg-azul text-white shadow-lg"><Icon name={p.icon} class="h-6 w-6" /></span>
            </div>
            <div class="p-6">
              <h3 class="font-display text-xl text-ink group-hover:text-azul transition">{p.t}</h3>
              <p class="mt-2 text-sm text-muted">{p.d}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul">Learn more <Icon name="arrow" class="h-4 w-4" /></span>
            </div>
          </a>
        ))}
      </div>

      <!-- CONTINUUM DIAGRAM -->
      <div class="mt-14 rounded-2xl border border-line bg-crema p-8">
        <h3 class="font-display text-2xl text-ink text-center">Your continuum of care</h3>
        <p class="mt-2 text-center text-muted text-sm">Move up or down as you heal — one team, one coordinated plan.</p>
        <div class="mt-8 flex flex-col md:flex-row items-stretch justify-center gap-3 md:gap-0">
          {continuum.map((c, i) => (
            <>
              <div class="flex-1 rounded-2xl bg-white border border-line p-5 text-center relative">
                <div class="mx-auto flex items-end justify-center gap-1 h-8">
                  {[1,2,3].map((b) => <span class={`w-2.5 rounded-t ${b <= c.level ? "bg-azul" : "bg-line"}`} style={`height:${b*8+6}px`}></span>)}
                </div>
                <p class="mt-3 font-display text-lg text-ink leading-tight">{c.t}</p>
                <p class="mt-1 text-xs text-muted">{c.d}</p>
              </div>
              {i < continuum.length - 1 && <div class="hidden md:flex items-center px-2 text-azul"><Icon name="arrow" class="h-6 w-6" /></div>}
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- WHAT WE TREAT (icon cards) -->
  <section id="what-we-treat" class="bg-crema scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <h2 class="font-display text-3xl sm:text-4xl text-ink text-center">Specialized help for what you’re facing</h2>
      <p class="mt-3 text-center text-muted max-w-2xl mx-auto">Dedicated, evidence-based care for the conditions we see most.</p>
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-4">
        {conditions.map((c) => (
          <a href="#" class="group rounded-2xl bg-white border border-line p-6 flex items-center gap-4 hover:border-azul hover:shadow-lg transition">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-azul-light text-azul group-hover:bg-azul group-hover:text-white transition"><Icon name={c.icon} class="h-6 w-6" /></span>
            <span class="font-display text-lg text-ink leading-tight">{c.t}</span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- APPROACH -->
  <section class="bg-white">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center">
      <span class="grid h-14 w-14 mx-auto place-items-center rounded-2xl bg-azul-light text-azul"><Icon name="sparkles" class="h-7 w-7" /></span>
      <h2 class="mt-5 font-display text-3xl sm:text-4xl text-ink">Therapy first. Medication second. Transformation third.</h2>
      <p class="mt-5 text-lg text-muted leading-relaxed">Our board-certified, multidisciplinary team uses proven methods — CBT, DBT, EMDR, ART, the Gottman Method, and more — tailored to you, never a template. We treat the whole person, ages 4 and up, with advanced options like TMS and Spravato® for treatment-resistant depression.</p>
    </div>
  </section>

  <!-- TEAM -->
  <section id="team" class="bg-crema scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <h2 class="font-display text-3xl sm:text-4xl text-ink text-center">Meet the people who’ll walk beside you</h2>
      <p class="mt-3 text-center text-muted max-w-2xl mx-auto">47 licensed clinicians across Connecticut. Real credentials. Real names. Real relationships.</p>
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-5">
        {team.map(([name, role, img]) => (
          <div class="text-center">
            <img src={img} alt={name} loading="lazy" class="w-full aspect-square object-cover object-top rounded-xl border border-line bg-white" />
            <p class="mt-2 font-display text-sm text-ink leading-tight">{name}</p>
            <p class="text-xs text-muted">{role}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-8"><a href="#" class="rounded-lg border border-azul px-6 py-3 font-semibold text-azul hover:bg-azul-light transition">Meet our full team →</a></div>
    </div>
  </section>

  <!-- REVIEWS — killer section -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="flex items-center justify-center gap-3">
          <img src="/Assets/Google-Review-Symbol.webp" alt="Google" class="h-8 w-8 object-contain" />
          <span class="font-display text-4xl text-ink">4.8</span>
          <span class="text-yellow-400 text-2xl">★★★★★</span>
        </div>
        <p class="mt-2 text-muted">367 Google reviews · As featured on Eyewitness News 3</p>
      </div>

      <!-- featured -->
      <figure class="mt-10 rounded-3xl bg-crema border border-line p-8 md:p-10 max-w-4xl mx-auto">
        <div class="text-yellow-400 text-xl">★★★★★</div>
        <blockquote class="mt-4 font-display text-2xl md:text-3xl text-ink leading-snug">“{featured.text}”</blockquote>
        <figcaption class="mt-5 flex items-center gap-3">
          <span class="grid h-11 w-11 place-items-center rounded-full bg-azul text-white font-display text-lg">{featured.name.charAt(0)}</span>
          <span><span class="block font-semibold text-ink">{featured.name}</span><span class="block text-xs text-muted">{featured.meta}</span></span>
        </figcaption>
      </figure>

      <!-- grid -->
      <div class="mt-6 grid md:grid-cols-3 gap-5">
        {reviews.map((r) => (
          <figure class="rounded-2xl border border-line bg-white p-6 shadow-sm">
            <div class="text-yellow-400">★★★★★</div>
            <blockquote class="mt-3 text-ink leading-relaxed text-[15px]">“{r.text}”</blockquote>
            <figcaption class="mt-4 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-9 w-9 place-items-center rounded-full bg-azul-light text-azul font-semibold text-sm">{r.name.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.name}</span><span class="block text-xs text-muted">{r.meta}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE — bigger logos -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-ink">Comprehensive coverage options</h2>
      <p class="mt-3 text-muted max-w-2xl mx-auto">In-network with most major plans. Not sure about yours? We’ll check it for you — free, in minutes.</p>
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-4 gap-5">
        {insurers.map(([name, img]) => (
          <div class="rounded-xl bg-white border border-line p-5 flex items-center justify-center h-24">
            <img src={img} alt={name} loading="lazy" class="max-h-14 max-w-[80%] object-contain" />
          </div>
        ))}
      </div>
      <a href="#verify" class="mt-10 inline-block rounded-lg bg-azul px-7 py-3.5 font-semibold text-white hover:bg-azul-dark transition">Verify my benefits →</a>
    </div>
  </section>

  <!-- GETTING STARTED — flow diagram -->
  <section id="locations" class="bg-white scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <h2 class="font-display text-3xl sm:text-4xl text-ink text-center">Getting started is simple</h2>
      <p class="mt-3 text-center text-muted">Reaching out is the hardest part — we handle the rest.</p>
      <div class="mt-12 grid md:grid-cols-4 gap-y-10 md:gap-0 relative">
        <!-- connector line -->
        <div class="hidden md:block absolute top-7 left-[12.5%] right-[12.5%] h-0.5 bg-line"></div>
        {steps.map((s, i) => (
          <div class="relative text-center px-4">
            <span class="relative z-10 grid h-14 w-14 mx-auto place-items-center rounded-full bg-azul text-white ring-8 ring-white"><Icon name={s.icon} class="h-7 w-7" /></span>
            <div class="mt-1 text-xs font-bold uppercase tracking-wide text-azul">Step {i + 1}</div>
            <h3 class="mt-1 font-display text-lg text-ink">{s.t}</h3>
            <p class="mt-1 text-sm text-muted">{s.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- FINAL CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">You don’t have to do this alone.</h2>
      <p class="mt-4 text-white/85 text-lg">Reach out today and a real person will help you figure out the next step — confidentially, with no pressure.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">Verify Your Insurance</a>
        <a href="tel:8609460447" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 946-0447</a>
      </div>
    </div>
  </section>

  <Footer />

  <style>
    .marquee { display: flex; width: max-content; animation: hh-scroll 38s linear infinite; }
    .marquee:hover { animation-play-state: paused; }
    @keyframes hh-scroll { from { transform: translateX(0); } to { transform: translateX(-50%); } }
    @media (prefers-reduced-motion: reduce) { .marquee { animation: none; } }
  </style>
</Base>
