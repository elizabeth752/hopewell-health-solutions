---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import LeadForm from "../components/LeadForm.astro";
import MediaStrip from "../components/MediaStrip.astro";
import { posts } from "../data/posts.js";
import { providers } from "../data/providers.js";

const C = "/Assets/credibility/";
const trustMarks = [
  ["The Joint Commission — Accredited", C + "joint-commission.webp"],
  ["Better Business Bureau Accredited", C + "bbb.png"],
  ["Psychology Today Verified", C + "psychology-today.png"],
  ["Recovery.com Verified Provider", C + "recovery-verified.png"],
];
const usps = [
  { icon: "sparkles", t: "Programs hospitals don’t offer", d: "Intensive Outpatient (IOP) & Partial Hospitalization (PHP) — for women, teens, tweens, first responders & substance use. Built for who you are." },
  { icon: "users", t: "Real, in-person care", d: "While others go all-virtual, our IOP, PHP, therapy and medication management happen face to face — human to human, with telehealth when you need it." },
  { icon: "dna", t: "GeneSight® genetic testing", d: "A simple cheek swab shows which medications fit your DNA — so we skip the trial-and-error." },
  { icon: "brain", t: "TMS for treatment-resistant depression", d: "FDA-cleared, drug-free, no downtime — for when medication and therapy haven’t been enough." },
];
const programs = [
  { t: "Adult IOP", d: "Structured therapy 3–4 days a week, while you live at home, work, and parent.", href: "/programs/adult-mental-health-iop/", icon: "users", img: "/Assets/AdobeStock_403830351.webp" },
  { t: "Women’s Wellness IOP", d: "Trauma-informed, DBT-based care in a women-only group where it’s safe to be seen.", href: "/programs/womens-wellness-iop/", icon: "heart", img: "/Assets/women%20looking%20at%20me.webp" },
  { t: "Teen & Tween IOP", d: "After-school support for ages 8–18, with the family woven into the work.", href: "/programs/teen-tween-iop/", icon: "sparkles", img: "/Assets/teen%20smiling.webp" },
  { t: "Partial Hospitalization (PHP)", d: "Full-day treatment for when weekly therapy simply isn’t enough.", href: "/programs/partial-hospitalization-program/", icon: "shield", img: "/Assets/AdobeStock_542909901.webp" },
  { t: "Medication Management", d: "Thoughtful psychiatric prescribing for ages 4 and up — never one-size-fits-all.", href: "/programs/medication-management/", icon: "pill", img: "/Assets/AdobeStock_404268940.webp" },
  { t: "Counseling", d: "Individual, couples & family counseling, in person or by telehealth.", href: "/programs/counseling/", icon: "heart", img: "/Assets/couple%20hugging.webp" },
];
const treatments = [
  { t: "TMS Therapy", d: "FDA-cleared magnetic stimulation for treatment-resistant depression & OCD.", href: "/treatment-methods/tms/", icon: "brain" },
  { t: "Spravato®", d: "Esketamine for treatment-resistant depression, monitored in our offices.", href: "/treatment-methods/spravato/", icon: "sparkles" },
  { t: "EMDR", d: "Evidence-based trauma therapy that helps the mind heal what words can’t reach.", href: "/treatment-methods/emdr/", icon: "refresh" },
  { t: "Therapeutic Treatments", d: "ART, the Gottman Method, mindfulness, yoga therapy & more.", href: "/treatment-methods/therapeutic-treatments/", icon: "heart" },
  { t: "Neuropsychological Testing", d: "Comprehensive evaluation for clarity, diagnosis, and a real plan.", href: "/treatment-methods/neuropsychological-testing/", icon: "clipboard" },
  { t: "ADHD Testing", d: "Thorough, compassionate assessment for children, teens & adults.", href: "/treatment-methods/adhd-testing/", icon: "bolt" },
];
const conditions = [
  { t: "Depression", icon: "cloud", href: "/what-we-treat/depression/" },
  { t: "Anxiety", icon: "alert", href: "/what-we-treat/anxiety/" },
  { t: "Trauma & PTSD", icon: "heart", href: "/what-we-treat/trauma-ptsd/" },
  { t: "ADHD", icon: "bolt", href: "/what-we-treat/adhd/" },
  { t: "Bipolar Disorder", icon: "swap", href: "/what-we-treat/bipolar/" },
  { t: "OCD", icon: "refresh", href: "/what-we-treat/ocd/" },
  { t: "Substance Use", icon: "pill", href: "/what-we-treat/substance-use-disorder/" },
  { t: "Co-occurring Disorders", icon: "link", href: "/what-we-treat/co-occurring/" },
];
const continuum = [
  { t: "Outpatient Therapy", d: "Weekly individual, couples & family sessions", level: 1 },
  { t: "Intensive Outpatient (IOP)", d: "3 hrs/day · 4 days/week · day or evening", level: 2 },
  { t: "Partial Hospitalization (PHP)", d: "Full-day care — highest outpatient level", level: 3 },
];
const stats = [
  ["14", "Years serving Central Connecticut", "calendar"],
  ["50+", "Clinicians on our team", "users"],
  ["6", "Connecticut locations", "pin"],
  ["50,000+", "Lives helped", "heart"],
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
// Featured team — prescribers first, then founder & psychologists.
const team = [
  ["Katrin Moskowitz, DNP","Psychiatric NP","/Assets/Team%20Members/katrin-moskowitz-dnp-pmhnp-bc-fnp.webp","/provider/katrin-moskowitz-dnp-pmhnp-bc-fnp/"],
  ["Tracy Sibley, PMHNP-BC","Psychiatric NP","/Assets/Team%20Members/tracy-sibley-pmhnp-bc-aprn.webp","/provider/tracy-sibley-pmhnp-bc-aprn/"],
  ["Christopher Patenaude, PA","Physician Assistant","/Assets/Team%20Members/chris-patenaude-pa.webp","/provider/chris-patenaude-pa/"],
  ["Kristine A. Schlichting, PhD","Founder & Director","/Assets/Team%20Members/kristine-a-schlichting-phd.webp","/provider/kristine-a-schlichting-ph-d/"],
  ["Eric Schwartz, PsyD, ABPP","Psychologist","/Assets/Team%20Members/eric-schwarz-psyd-abpp.webp","/provider/eric-schwartz-psy-d-abpp/"],
  ["Laura Miller, PhD","Neuropsychologist","/Assets/Team%20Members/laura-miller-phd.webp","/provider/laura-miller-ph-d/"],
  ["Ashley Singh, PsyD","Psychologist","/Assets/Team%20Members/ashley-singh-psyd.webp","/provider/ashley-singh-psy-d/"],
];
const locations = [
  ["Glastonbury — Pratt St", "33 Pratt St", "Glastonbury, CT 06033", "/location/glastonbury-ct/"],
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203", "Glastonbury, CT 06033", "/location/glastonbury-ct-2/"],
  ["South Glastonbury", "1420 Main St, Suite 124", "Glastonbury, CT 06073", "/location/glastonbury-ct-3/"],
  ["West Hartford", "1216 Farmington Ave, Suite 301", "West Hartford, CT 06107", "/location/west-hartford-ct/"],
  ["East Hampton", "151 E. High St", "East Hampton, CT 06424", "/location/east-hampton-ct/"],
  ["Westbrook", "70 Essex Road", "Westbrook, CT 06498", "/location/westbrook-ct/"],
];
const reviews = [
  { name: "Julie Stevens", meta: "2 months ago", text: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { name: "Jake Sted", meta: "2 months ago", text: "Hopewell’s IOP program made a huge difference in my life. The groups were engaging, and the therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day." },
  { name: "Emily Ross", meta: "8 months ago", text: "This is the best therapy place I have ever been to. I started in their Women’s Wellness IOP and all the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { name: "Joana Yoo", meta: "10 months ago", text: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
  { name: "stacey miller", meta: "3 months ago", text: "They put me on the schedule as a new patient within the same week of calling, which never happens, and made sure my insurance was accepted. The provider and staff were very professional and kind." },
  { name: "Cynthia Askew", meta: "6 months ago", text: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
];
const steps = [
  { icon: "phone", t: "Reach out", d: "Call us, or request a confidential callback — no commitment." },
  { icon: "shield", t: "Verify insurance", d: "We check your benefits for you — free, in minutes." },
  { icon: "clipboard", t: "Assessment", d: "A clinical assessment to match you to the right care." },
  { icon: "compass", t: "Begin care", d: "Start at the right level — and adjust as you heal." },
];
const byId = (slug) => providers.find((p) => p.slug === slug);
const blogTeasers = [...posts].sort((a, b) => (a.datePublished < b.datePublished ? 1 : -1)).slice(0, 3);

// --- Homepage structured data: MedicalBusiness + aggregateRating + sameAs (rich results + knowledge panel) ---
const SITE = "https://www.hopewellhealthsolutions.com";
const orgSchema = {
  "@context": "https://schema.org",
  "@type": "MedicalBusiness",
  "@id": SITE + "/#organization",
  name: "Hopewell Health Solutions",
  alternateName: "Hopewell Health Solutions, LLC.",
  url: SITE + "/",
  logo: SITE + "/Assets/logo/hopewell-hhs-logo.svg",
  image: SITE + "/Assets/full%20team%20happy.webp",
  description: "Outpatient mental health and psychiatry across Connecticut — IOP, PHP, TMS, Spravato®, medication management and counseling for ages 4 and up.",
  telephone: "+1-860-735-1448",
  email: "hhs4help@gmail.com",
  priceRange: "$$",
  medicalSpecialty: "Psychiatric",
  foundingDate: "2013",
  address: {
    "@type": "PostalAddress",
    streetAddress: "33 Pratt St",
    addressLocality: "Glastonbury",
    addressRegion: "CT",
    postalCode: "06033",
    addressCountry: "US",
  },
  areaServed: [
    "Glastonbury CT", "South Glastonbury CT", "West Hartford CT", "East Hampton CT", "Westbrook CT",
    "Hartford County CT", "Middlesex County CT", "South Windsor", "Wethersfield", "Rocky Hill",
    "Newington", "Berlin", "Colchester", "Old Saybrook", "Clinton",
  ],
  aggregateRating: {
    "@type": "AggregateRating",
    ratingValue: "4.8",
    reviewCount: "368",
    bestRating: "5",
    worstRating: "1",
  },
  sameAs: [
    "https://www.instagram.com/hopewellhealthsolutions/",
    "https://www.facebook.com/hopewellhealth/",
    "https://x.com/hopewellHealthS",
    "https://www.linkedin.com/company/hopewell-health-solutions-llc/",
    "https://www.tiktok.com/@hopewellhs",
    "https://co.pinterest.com/hopewellhs/",
    "https://bsky.app/profile/hopewellhs.bsky.social",
    "https://www.psychologytoday.com/us/treatment-rehab/hopewell-health-solutions-iop-glastonbury-ct/1084012",
    "https://recovery.com/outpatient/hopewell-health-solutions-south-glastonbury/",
    "https://www.bbb.org/us/ct/glastonbury/profile/psychologist/hopewell-health-solutions-llc-0111-87124396",
  ],
};
---

<Base title="Mental Health & Psychiatry in Glastonbury, Westbrook & West Hartford, CT | Hopewell Health Solutions" description="Hopewell Health Solutions — Connecticut’s trusted outpatient mental-health & psychiatry team. IOP, PHP, TMS, Spravato® & medication management across Glastonbury, West Hartford, East Hampton & Westbrook. 4.8★, Joint Commission accredited. Verify your insurance." canonical={SITE + "/"}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(orgSchema)} />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 lg:py-20 grid lg:grid-cols-[3fr_2fr] gap-12 items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Glastonbury · West Hartford · East Hampton · Westbrook, CT</p>
        <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Mental Health &amp; Psychiatry in Connecticut</h1>
        <p class="mt-3 font-display text-2xl sm:text-3xl text-azul leading-tight">There is hope to heal.</p>
        <p class="mt-5 text-lg text-muted max-w-xl leading-relaxed">Connecticut’s most trusted outpatient mental-health team — intensive programs, psychiatry, medication management, TMS and Spravato®, delivered in person by clinicians who know your name. For ages 4 and up, in person or by telehealth.</p>
        <div class="mt-6 flex flex-wrap items-center gap-x-5 gap-y-2 text-sm text-ink">
          <span><span class="text-yellow-400">★★★★★</span> <strong>4.8</strong> · 368 reviews</span>
        </div>
        <div class="mt-8 flex flex-wrap gap-3">
          <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg bg-azul px-7 py-3.5 font-semibold text-white hover:bg-azul-dark transition"><Icon name="phone" class="h-4 w-4" />Call (860) 735-1448</a>
        </div>
        <div class="mt-8 pt-6 border-t border-line">
          <p class="text-[11px] font-semibold uppercase tracking-[0.14em] text-muted">Accredited &amp; verified by</p>
          <div class="mt-3 flex flex-wrap items-center gap-x-7 gap-y-3">
            {trustMarks.map(([alt, src]) => <img src={src} alt={alt} loading="lazy" class="h-9 w-auto max-w-[120px] object-contain" />)}
          </div>
        </div>
      </div>
      <div id="verify" class="scroll-mt-28"><LeadForm /></div>
    </div>
  </section>

  <MediaStrip bg="crema" />

  <!-- FOR ME / LOVED ONE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <h2 class="font-display text-3xl sm:text-4xl text-ink text-center">Where Would You Like to Begin?</h2>
      <p class="mt-3 text-center text-muted max-w-2xl mx-auto">One in five U.S. adults lives with a mental health condition — and untreated, it rarely gets easier on its own. You are not alone, and you don’t have to navigate this alone. Wherever you’re starting from, there’s a clear next step here.</p>
      <div class="mt-8 grid sm:grid-cols-2 gap-6 max-w-4xl mx-auto">
        <div class="rounded-2xl border border-line bg-crema overflow-hidden flex flex-col">
          <img src="/Assets/Guy%20facing%20the%20horizon.webp" alt="Beginning your own healing journey" loading="lazy" class="h-44 w-full object-cover" />
          <div class="p-7 flex gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-azul text-white"><Icon name="heart" class="h-6 w-6" /></span>
            <div><h3 class="font-display text-2xl text-ink">Help for myself</h3><p class="mt-1 text-muted">Taking the first step takes courage. We’ll make the next ones simple.</p><a href="#programs" class="mt-3 inline-block font-semibold text-azul">Find my program →</a></div>
          </div>
        </div>
        <div class="rounded-2xl border border-line bg-crema overflow-hidden flex flex-col">
          <img src="/Assets/couple%20hugging.webp" alt="Supporting a loved one who is struggling" loading="lazy" class="h-44 w-full object-cover" />
          <div class="p-7 flex gap-4">
            <span class="grid h-12 w-12 shrink-0 place-items-center rounded-xl bg-azul text-white"><Icon name="users" class="h-6 w-6" /></span>
            <div><h3 class="font-display text-2xl text-ink">Help for someone I love</h3><p class="mt-1 text-muted">A child, partner, or parent who’s struggling? We’ll help you help them.</p><a href="#verify" class="mt-3 inline-block font-semibold text-azul">Get guidance →</a></div>
          </div>
        </div>
      </div>
    </div>
  </section>

  <!-- WHY (USPs) — standout -->
  <section id="why" class="bg-ink text-white scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.15em] text-azul-light">Why Hopewell</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-white text-center">Care You Can’t Get Just Anywhere</h2>
      <div class="mt-10 grid md:grid-cols-2 lg:grid-cols-4 gap-5">
        {usps.map((u) => (
          <div class="rounded-2xl bg-white p-7 shadow-lg hover:-translate-y-0.5 transition">
            <span class="grid h-14 w-14 place-items-center rounded-2xl bg-azul text-white"><Icon name={u.icon} class="h-7 w-7" /></span>
            <h3 class="mt-5 font-display text-xl text-ink leading-snug">{u.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{u.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- ABOUT / MISSION -->
  <section id="about" class="bg-white scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-12 items-center">
      <div>
        <img src="/Assets/full%20team%20happy.webp" alt="The Hopewell Health Solutions team" loading="lazy" class="w-full aspect-[4/3] object-cover rounded-3xl border border-line" />
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">About Hopewell</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink leading-tight">Our Mission Is to Help You Live Your Best Life</h2>
        <p class="mt-5 text-muted leading-relaxed">Hopewell Health Solutions is a superior mental-health practice rooted in Glastonbury and West Hartford, Connecticut. Our board-certified specialists take an innovative, multidisciplinary approach to care for clients aged 4 and older — in a compassionate, safe environment, whether in person or by telehealth.</p>
        <p class="mt-4 text-muted leading-relaxed">We offer dialectical behavior therapy (DBT), cognitive behavioral therapy (CBT), play therapy, EMDR and accelerated resolution therapy (ART), the Gottman Method for couples, trauma treatments, and mind-body approaches like mindfulness and yoga therapy. When medication is part of the plan, our prescribers build personalized psychiatric plans — never one-size-fits-all — alongside advanced options like TMS and Spravato® for treatment-resistant depression.</p>
        <p class="mt-4 font-display text-xl text-azul">Therapy first. Medication second. Transformation third.</p>
        <div class="mt-7 flex flex-wrap gap-3">
          <a href="/about-us/" class="rounded-lg bg-azul px-6 py-3 font-semibold text-white hover:bg-azul-dark transition">More about us</a>
          <a href="/about-us/team/" class="inline-flex items-center gap-2 rounded-lg border border-azul px-6 py-3 font-semibold text-azul hover:bg-azul-light transition">Meet the team</a>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS BAND -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-12">
        {stats.map(([n, l, icon], i) => (
          <div class={`text-center px-4 ${i > 0 ? "lg:border-l lg:border-white/15" : ""}`}>
            <span class="grid h-12 w-12 mx-auto place-items-center rounded-xl bg-gold-light/15 text-gold-light"><Icon name={icon} class="h-6 w-6" /></span>
            <p class="mt-4 font-display text-5xl sm:text-6xl text-gold-light leading-none">{n}</p>
            <p class="mt-3 text-sm font-semibold text-white/85 leading-snug">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- PROGRAMS (photo cards) -->
  <section id="programs" class="bg-white scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <h2 class="font-display text-3xl sm:text-4xl text-ink">Mental Health Programs for Every Level of Care</h2>
      <p class="mt-3 text-muted max-w-2xl">A full continuum under one roof — from weekly counseling to intensive day programs. You can step up when you need more support, or step down as you heal, without ever switching teams.</p>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {programs.map((p) => (
          <a href={p.href} class="group rounded-2xl overflow-hidden border border-line bg-white hover:shadow-xl hover:-translate-y-0.5 transition">
            <div class="relative h-40 overflow-hidden">
              <img src={p.img} alt={p.t} loading="lazy" class="h-full w-full object-cover group-hover:scale-105 transition duration-500" />
              <span class="absolute bottom-3 left-3 grid h-11 w-11 place-items-center rounded-xl bg-azul text-white shadow-lg"><Icon name={p.icon} class="h-6 w-6" /></span>
            </div>
            <div class="p-6">
              <h3 class="font-display text-xl text-ink group-hover:text-azul transition">{p.t}</h3>
              <p class="mt-2 text-sm text-muted">{p.d}</p>
              <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul">Learn more <Icon name="arrow" class="h-4 w-4" /></span>
            </div>
          </a>
        ))}
      </div>

      <!-- CONTINUUM DIAGRAM -->
      <div class="mt-14 rounded-2xl border border-line bg-crema p-8">
        <h3 class="font-display text-2xl text-ink text-center">Your continuum of care</h3>
        <p class="mt-2 text-center text-muted text-sm">Move up or down as you heal — one team, one coordinated plan.</p>
        <div class="mt-8 flex flex-col md:flex-row items-stretch justify-center gap-3 md:gap-0">
          {continuum.map((c, i) => (
            <>
              <div class="flex-1 rounded-2xl bg-white border border-line p-5 text-center relative">
                <div class="mx-auto flex items-end justify-center gap-1 h-8">
                  {[1,2,3].map((b) => <span class={`w-2.5 rounded-t ${b <= c.level ? "bg-azul" : "bg-line"}`} style={`height:${b*8+6}px`}></span>)}
                </div>
                <p class="mt-3 font-display text-lg text-ink leading-tight">{c.t}</p>
                <p class="mt-1 text-xs text-muted">{c.d}</p>
              </div>
              {i < continuum.length - 1 && <div class="hidden md:flex items-center px-2 text-azul"><Icon name="arrow" class="h-6 w-6" /></div>}
            </>
          ))}
        </div>
      </div>
    </div>
  </section>

  <!-- ADVANCED TREATMENTS -->
  <section id="treatments" class="bg-crema scroll-mt-20">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Advanced & evidence-based</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Advanced Treatments: TMS, Spravato® &amp; EMDR</h2>
      <p class="mt-3 text-muted max-w-2xl">When traditional therapy and medication aren’t enough on their own, we offer the kind of advanced, research-backed options most outpatient practices can’t — all under the same roof, coordinated by the same team.</p>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {treatments.map((t) => (
          <a href={t.href} class="group rounded-2xl bg-white border border-line p-6 hover:border-azul hover:shadow-lg transition flex flex-col">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul group-hover:bg-azul group-hover:text-white transition"><Icon name={t.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl text-ink group-hover:text-azul transition">{t.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{t.d}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul">Learn more <Icon name="arrow" class="h-4 w-4" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

