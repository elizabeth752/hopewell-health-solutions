---
import Base from "../layouts/Base.astro";
import Header from "../components/Header.astro";
import Footer from "../components/Footer.astro";
import Icon from "../components/Icon.astro";
import MediaStrip from "../components/MediaStrip.astro";

const videos = [
  { id: "aff5Xfy9CfE", t: "The Loneliness Crisis in Adults", outlet: "Hopewell Health Solutions" },
  { id: "GJeVqHhooBA", t: "Mommy Monday: Helping Children", outlet: "WFSB Channel 3" },
  { id: "uDy-K1dO0Fw", t: "CT Live!: Trauma in Women", outlet: "NBC Connecticut" },
  { id: "P3cmQMf3WoM", t: "Teen Mental Health Interview", outlet: "WFSB Channel 3" },
];
const L = "/Assets/Media%20Appearances/";
const press = [
  { outlet: "Hartford Courant", logo: L + "hartford.webp", date: "Feb 2023", title: "Hopewell opens first privately owned IOP mental health clinic in Glastonbury", href: "https://www.courant.com/2023/02/24/hopewell-solutions-opens-first-privately-owned-iop-mental-health-clinic-in-glastonbury/" },
  { outlet: "Hartford Business Journal", logo: L + "hbj-logo-v3.png", date: "Honoree", title: "Kristine Schlichting — recognized leader in behavioral health", href: "https://hartfordbusiness.com/honoree/kristine-schlichting/" },
  { outlet: "FOX61", logo: L + "fox61.png", date: "2023", title: "Glastonbury psychologist is helping teen girls and new moms find support", href: "https://www.fox61.com/article/news/local/outreach/awareness-months/glastonbury-psychologist-is-helping-teen-girls-and-new-moms-find-support/520-84d3fd3f-1cec-40bc-9d4c-65f7b6a4d2e9" },
  { outlet: "WFSB · Kara’s Cures", logo: L + "wfsb.avif", date: "Feb 2023", title: "Teen mental health crisis", href: "https://www.wfsb.com/video/2023/02/27/karas-cures-teen-mental-health-crisis/" },
  { outlet: "WFSB · Kara’s Cures", logo: L + "wfsb.avif", date: "Feb 2023", title: "How to help improve your teen’s mental health", href: "https://www.wfsb.com/video/2023/02/27/karas-cures-how-help-improve-your-teens-mental-health/" },
  { outlet: "IssueWire", logo: L + "issuewire.webp", date: "Feature", title: "Dr. Bido Aguessy: holistic approaches in psychology & spiritual care at Hopewell", href: "https://www.issuewire.com/dr-bido-aguessy-pioneering-holistic-approaches-in-psychology-and-spiritual-care-at-hopewell-health-solutions-1809193551604743" },
];
---

<Base title="In the News & Media | Hopewell Health Solutions" description="Hopewell Health Solutions in the news — featured on WFSB Eyewitness News, FOX61, the Hartford Courant & Hartford Business Journal for behavioral health and teen mental health in Connecticut.">
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center">
      <nav class="text-xs text-muted mb-5"><a href="/" class="hover:text-azul">Home</a> / <span class="text-ink">Media</span></nav>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">In the news</p>
      <h1 class="mt-3 font-display text-4xl sm:text-5xl text-ink">Hopewell Health Solutions in the Media</h1>
      <div class="mx-auto mt-5 h-px w-16 bg-gold"></div>
      <p class="mt-5 text-lg text-muted">Connecticut’s news outlets turn to our clinicians for expertise on teen mental health, women’s wellness, and the future of outpatient care. Here’s where you’ve seen us.</p>
    </div>
  </section>

  <MediaStrip showLink={false} />

  <!-- VIDEOS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Watch</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Interviews &amp; TV segments</h2>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {videos.map((v) => (
          <figure>
            <div class="aspect-video overflow-hidden rounded-2xl border border-line bg-ink">
              <iframe class="h-full w-full" src={`https://www.youtube.com/embed/${v.id}`} title={v.t} loading="lazy" frameborder="0" allow="accelerometer; autoplay; clipboard-write; encrypted-media; gyroscope; picture-in-picture; web-share" referrerpolicy="strict-origin-when-cross-origin" allowfullscreen></iframe>
            </div>
            <figcaption class="mt-3"><span class="text-xs font-semibold uppercase tracking-wide text-azul">{v.outlet}</span><p class="font-display text-lg text-ink leading-tight">{v.t}</p></figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- PRESS ARTICLES -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Read</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Press &amp; features</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {press.map((p) => (
          <a href={p.href} target="_blank" rel="noopener" class="group rounded-2xl bg-white border border-line p-6 hover:border-azul hover:shadow-lg transition flex flex-col">
            <div class="flex items-center justify-between gap-3 min-h-[2rem]">
              {p.logo
                ? <img src={p.logo} alt={p.outlet} loading="lazy" class="h-7 w-auto max-w-[60%] object-contain" />
                : <span class="text-xs font-semibold uppercase tracking-wide text-gold">{p.outlet}</span>}
              <span class="text-xs text-muted shrink-0">{p.date}</span>
            </div>
            <p class="mt-4 font-display text-xl text-ink leading-snug flex-1 group-hover:text-azul transition">{p.title}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul">Read the feature <Icon name="arrow" class="h-4 w-4" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">Trusted by Connecticut — and here for you</h2>
      <p class="mt-4 text-white/85 text-lg">The same team the news turns to is ready to help you or your loved one heal.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/#verify" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">Verify Your Insurance</a>
        <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
      </div>
    </div>
  </section>

  <Footer />
</Base>
