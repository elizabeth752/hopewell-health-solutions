---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";
import { locations } from "../../data/locations.js";

export function getStaticPaths() {
  return locations.map((l) => ({ params: { slug: l.slug }, props: { l } }));
}
const { l } = Astro.props;
const others = locations.filter((x) => x.slug !== l.slug);
const fullAddress = `${l.street}, ${l.city}, CT ${l.zip}`;
const directions = `https://www.google.com/maps/search/?api=1&query=${encodeURIComponent("Hopewell Health Solutions " + fullAddress)}`;
const canonical = `https://www.hopewellhealthsolutions.com/location/${l.slug}/`;

const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const heroUsps = [
  { icon: "users", t: "Outpatient therapy, psychiatry & intensive programs" },
  { icon: "calendar", t: "Daytime & evening appointments" },
  { icon: "compass", t: "In person at this office or by secure telehealth" },
  { icon: "shield", t: "Joint Commission accredited · most major PPOs" },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "Jake Sted", t: "2 months ago", q: "The therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day. Hopewell made a huge difference in my life." },
];
const faqs = [
  [`Where is the ${l.name} office?`, `We’re located at ${fullAddress}. You can reach us at (860) 735-1448 or request an appointment online.`],
  ["Do you offer in-person and telehealth appointments?", "Yes — you can be seen in person at this office or by secure video telehealth across Connecticut, with daytime and evening availability."],
  ["What services are offered at this location?", "Outpatient therapy (individual, couples, and family), medication management, and our intensive programs. Specific services and providers vary by office — call us and we’ll match you to the right care and location."],
  ["Do you take my insurance?", "We’re in-network with most major PPO plans (we don’t accept Medicaid / HUSKY). We’ll verify your benefits for free before your first visit."],
  ["How do I book my first appointment?", "Call (860) 735-1448 or request an appointment online. Our team will help you choose the right provider, service, and location."],
];
const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalClinic",
  name: `Hopewell Health Solutions — ${l.name}`,
  url: canonical,
  telephone: "+1-860-735-1448",
  email: "hhs4help@gmail.com",
  address: { "@type": "PostalAddress", streetAddress: l.street, addressLocality: l.city, addressRegion: "CT", postalCode: l.zip, addressCountry: "US" },
  geo: { "@type": "GeoCoordinates", latitude: l.lat, longitude: l.lng },
  parentOrganization: { "@type": "MedicalOrganization", name: "Hopewell Health Solutions" },
  areaServed: l.areas.map((a) => ({ "@type": "City", name: a })),
  medicalSpecialty: ["Psychiatric", "Behavioral"],
};
---

<Base title={`${l.name} | Mental Health & Psychiatry in ${l.city}, CT | Hopewell Health Solutions`} description={`Hopewell Health Solutions ${l.name} — outpatient therapy, psychiatry & intensive programs at ${l.street}, ${l.city}, CT. In person & telehealth, most PPOs accepted. Call (860) 735-1448.`} canonical={canonical}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/locations/" class="hover:text-azul">Locations</a> / <span class="text-ink">{l.name}</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Hopewell Health Solutions · {l.name}, CT</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Mental Health &amp; Psychiatry — {l.name}</h1>
          <p class="mt-3 font-display text-xl text-azul italic">Compassionate, evidence-based care — close to home.</p>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8 flex flex-wrap gap-3">
            <a href="tel:8607351448" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 735-1448</a>
            <a href={directions} target="_blank" rel="noopener" class="inline-flex items-center gap-2.5 rounded-lg bg-azul-bright px-8 py-4 text-lg font-semibold text-white shadow-sm hover:bg-azul transition"><Icon name="pin" class="h-5 w-5" />Get directions</a>
          </div>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading={`Book at our ${l.name} office`} sub="Free, confidential. We’ll verify your benefits and match you to the right provider." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- MAP & GETTING HERE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <div class="overflow-hidden rounded-2xl border border-line">
        <iframe src={l.map} title={`Map — Hopewell Health Solutions, ${l.name}`} class="h-80 lg:h-96 w-full border-0 grayscale-[0.15]" loading="lazy" referrerpolicy="no-referrer-when-downgrade" allowfullscreen></iframe>
      </div>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Visit us</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">The {l.name} office</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">{l.blurb}</p>
        <div class="mt-6 space-y-3 text-ink">
          <p class="flex items-start gap-3"><span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name="pin" class="h-5 w-5" /></span><span class="pt-1.5"><span class="font-semibold">Address:</span> {fullAddress}</span></p>
          <p class="flex items-start gap-3"><span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name="phone" class="h-5 w-5" /></span><span class="pt-1.5"><span class="font-semibold">Phone:</span> <a href="tel:8607351448" class="text-azul font-semibold">(860) 735-1448</a></span></p>
          <p class="flex items-start gap-3"><span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name="calendar" class="h-5 w-5" /></span><span class="pt-1.5"><span class="font-semibold">Hours:</span> By appointment — daytime &amp; evening availability</span></p>
        </div>
        <a href={directions} target="_blank" rel="noopener" class="mt-6 inline-flex items-center gap-1.5 text-sm font-semibold text-azul hover:text-azul-dark transition">Get directions <Icon name="arrow" class="h-4 w-4" /></a>
      </div>
    </div>
    {l.photos && (
      <div class="mx-auto max-w-6xl px-5 pb-16">
        <div class="text-center">
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A look inside</p>
          <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Inside our {l.name} office</h2>
        </div>
        <div class="mt-8 grid grid-cols-2 lg:grid-cols-3 gap-4">
          {l.photos.map(([file, alt]) => (
            <img src={`${l.photoDir}/${file}`} alt={alt} loading="lazy" class="w-full h-56 lg:h-64 object-cover rounded-2xl border border-line" />
          ))}
        </div>
      </div>
    )}
  </section>

  <!-- AREAS SERVED -->
  <section class="bg-crema">
    <div class="mx-auto max-w-5xl px-5 py-16 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care for the community</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Areas we serve from {l.city}</h2>
      <p class="mt-3 text-muted max-w-2xl mx-auto">Clients travel to our {l.city} office from across the surrounding towns — and telehealth is available statewide.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-2">
        {l.areas.map((a) => <span class="rounded-full bg-white border border-line px-4 py-2 text-sm font-semibold text-ink">{a}</span>)}
      </div>
    </div>
  </section>

  <!-- CARE TEAM -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16 grid md:grid-cols-[1fr_auto] gap-8 items-center">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Meet your care team</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Experienced, compassionate clinicians</h2>
        <p class="mt-4 text-ink leading-relaxed text-[17px] max-w-xl">Our psychiatrists, nurse practitioners, psychologists, and licensed therapists work as one team across all of our Connecticut offices. We’ll match you to the provider who best fits your needs and goals.</p>
      </div>
      <a href="/about-us/team/" class="inline-flex items-center gap-2 rounded-lg border border-azul px-7 py-3.5 font-semibold text-azul hover:bg-azul-light transition shrink-0">Meet the team <Icon name="arrow" class="h-4 w-4" /></a>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Clients describe feeling genuinely heard · As featured on Eyewitness News 3</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Most major PPO plans accepted</h2>
        <p class="mt-3 text-muted max-w-xl">We’re in-network with most major PPO plans (we don’t accept Medicaid / HUSKY). Our team verifies your benefits at no cost — before you commit to anything.</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <ServicesGrid bg="crema" eyebrow="Care at this location" heading="Services & programs we offer" />

  <!-- OTHER LOCATIONS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care across Connecticut</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Our other locations</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {others.map((o) => (
          <a href={`/location/${o.slug}/`} class="group flex gap-3 rounded-2xl bg-crema border border-line p-5 hover:border-azul hover:shadow-sm transition">
            <span class="grid h-10 w-10 shrink-0 place-items-center rounded-xl bg-azul-light text-azul"><Icon name="pin" class="h-5 w-5" /></span>
            <div>
              <h3 class="font-display text-lg text-ink leading-tight group-hover:text-azul transition">{o.name}</h3>
              <p class="mt-1 text-sm text-muted">{o.street}, {o.city}, CT {o.zip}</p>
            </div>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- FAQ -->
  <section class="bg-crema">
    <div class="mx-auto max-w-3xl px-5 py-16">
      <h2 class="font-display text-3xl text-ink text-center">{l.city} office — common questions</h2>
      <div class="mt-8 space-y-3">
        {faqs.map(([q, a]) => (
          <details class="group rounded-xl bg-white border border-azul/30 p-5 open:border-azul open:bg-azul-light/30 hover:border-azul transition">
            <summary class="flex justify-between items-center cursor-pointer font-display text-lg text-ink list-none">{q}<span class="text-azul text-xl group-open:rotate-45 transition">+</span></summary>
            <p class="mt-3 text-ink leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">Get started at {l.name}</h2>
      <p class="mt-4 text-white/85 text-lg">Reach out to Hopewell Health Solutions today — confidentially, with no pressure — and we’ll help you book at our {l.name} office or by telehealth.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">Verify Your Insurance</a>
        <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
        <a href={directions} target="_blank" rel="noopener" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="pin" class="h-4 w-4" />Get directions</a>
      </div>
      <p class="mt-6 text-xs text-white/60">Not a substitute for emergency care. If you’re in crisis, call or text 988, or call 911.</p>
    </div>
  </section>

  <Footer />
</Base>
