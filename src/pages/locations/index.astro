---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";
import { locations } from "../../data/locations.js";

const canonical = "https://www.hopewellhealthsolutions.com/locations";
const allAreas = Array.from(new Set(locations.flatMap((l) => l.areas))).sort();
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const heroUsps = [
  { icon: "pin", t: "Six Connecticut offices — Hartford County & the shoreline" },
  { icon: "compass", t: "In person locally or by secure telehealth statewide" },
  { icon: "calendar", t: "Daytime & evening appointments" },
  { icon: "shield", t: "Joint Commission accredited · 4.8★ · most major PPOs" },
];
const why = [
  { icon: "users", t: "One team, every office", d: "The same psychiatrists, nurse practitioners, psychologists, and therapists support you across all six locations — your care travels with you." },
  { icon: "refresh", t: "A full continuum of care", d: "Therapy, medication management, IOP, PHP, TMS, Spravato®, and testing — step up or down without leaving the practice." },
  { icon: "compass", t: "In person or virtual", d: "Choose the office closest to home, or meet by secure video anywhere in Connecticut." },
  { icon: "heart", t: "Compassionate, judgment-free", d: "A warm, welcoming environment for individuals and families of every background and identity." },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Julie Stevens", t: "2 months ago", q: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "Jake Sted", t: "2 months ago", q: "The therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day. Hopewell made a huge difference in my life." },
];
const faqs = [
  ["How many locations does Hopewell Health Solutions have?", "We have six offices across Connecticut: three in Glastonbury (Pratt Street, Downtown / Hebron Avenue, and South Glastonbury / Main Street), plus West Hartford, East Hampton, and Westbrook. We also offer secure telehealth statewide."],
  ["Do you offer telehealth, or do I have to come in person?", "Both. You can be seen in person at any of our offices or by secure video telehealth anywhere in Connecticut. Many clients combine the two — in-person visits when it helps, virtual sessions when life is busy."],
  ["Can I see the same provider at more than one office?", "Our clinical team works as one practice across all locations. We’ll match you to the provider who best fits your needs and help you find the most convenient office or a telehealth option."],
  ["Which services are available at each location?", "Outpatient therapy and medication management are available across our offices, and our intensive programs (IOP/PHP) and specialized treatments (TMS, Spravato®, testing) are offered at select locations. Call us and we’ll direct you to the right office for the care you need."],
  ["What are your hours?", "Appointments are available during the day and in the evening, by appointment. Call (860) 735-1448 for current availability at the office nearest you."],
  ["Do you take my insurance?", "We’re in-network with most major PPO plans (we don’t accept Medicaid / HUSKY). We’ll verify your benefits for free before your first visit."],
];
const schema = {
  "@context": "https://schema.org",
  "@type": "MedicalOrganization",
  name: "Hopewell Health Solutions",
  url: canonical,
  telephone: "+1-860-735-1448",
  location: locations.map((l) => ({
    "@type": "MedicalClinic",
    name: `Hopewell Health Solutions — ${l.name}`,
    url: `https://www.hopewellhealthsolutions.com/location/${l.slug}`,
    address: { "@type": "PostalAddress", streetAddress: l.street, addressLocality: l.city, addressRegion: "CT", postalCode: l.zip, addressCountry: "US" },
    geo: { "@type": "GeoCoordinates", latitude: l.lat, longitude: l.lng },
  })),
};
---

<Base title="Our Connecticut Locations | Hopewell Health Solutions" description="Hopewell Health Solutions has six mental health & psychiatry offices across Connecticut — three in Glastonbury, plus West Hartford, East Hampton & Westbrook — with telehealth statewide. Most PPOs accepted." canonical={canonical}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(schema)} />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <span class="text-ink">Locations</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care across Connecticut · In person &amp; telehealth</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Our Connecticut Locations</h1>
          <p class="mt-3 font-display text-xl text-azul italic">Six offices, one trusted team — and telehealth wherever you are.</p>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8607351448" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 735-1448</a>
          </div>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="Find your nearest office" sub="Free, confidential. We’ll help you choose a location or a telehealth visit." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- OVERVIEW -->
  <section class="bg-white">
    <div class="mx-auto max-w-3xl px-5 py-16">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Mental health &amp; psychiatry, close to home</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Connecticut’s premier therapy &amp; psychiatry practice</h2>
      <div class="mt-4 h-px w-16 bg-azul/40"></div>
      <div class="mt-6 space-y-4 text-ink leading-relaxed text-[17px]">
        <p>Hopewell Health Solutions has grown into one of Connecticut’s most accessible outpatient mental health and psychiatry practices, with <strong>six offices</strong> spanning Hartford County and the shoreline — three in Glastonbury, plus West Hartford, East Hampton, and Westbrook. Wherever you are in the state, compassionate, evidence-based care is close to home — and when getting to an office isn’t practical, secure telehealth brings the same trusted team to you.</p>
        <p>Since 2013, we’ve built our reputation on a simple idea: change is a practice, not a concept. Our clinicians fuse psychology, psychiatry, and whole-person wellness into care that’s active, collaborative, and tailored to each person. Across every location you’ll find the same standard of care — a Joint Commission–accredited practice with a 4.8-star reputation and a team of psychiatrists, board-certified nurse practitioners, psychologists, and licensed therapists who genuinely listen.</p>
        <p>Each office offers the support most people need most often — <a href="/programs/counseling/" class="text-azul font-semibold">individual, couples, and family therapy</a> and <a href="/programs/medication-management/" class="text-azul font-semibold">medication management</a>. Across the practice we also provide our <a href="/programs/intensive-outpatient-program/" class="text-azul font-semibold">Intensive Outpatient Program (IOP)</a> and <a href="/programs/partial-hospitalization-program/" class="text-azul font-semibold">Partial Hospitalization Program (PHP)</a>, plus specialized treatments such as <a href="/treatment-methods/tms/" class="text-azul font-semibold">TMS</a>, <a href="/treatment-methods/spravato/" class="text-azul font-semibold">Spravato®</a>, and <a href="/treatment-methods/neuropsychological-testing/" class="text-azul font-semibold">neuropsychological and ADHD testing</a>. Because all of it lives under one roof, you can step up or down between levels of care — or add a service — without ever having to start over with a new practice.</p>
        <p>We treat the full range of mental health and behavioral concerns: depression, anxiety, trauma and PTSD, ADHD, OCD, bipolar disorder, and co-occurring substance use. We welcome individuals of every age, background, and identity, and we work hard to make starting easy — most major PPO insurance plans are accepted (we don’t accept Medicaid / HUSKY), and our team verifies your benefits for free before your first visit. Choose the office nearest you below, or call <a href="tel:8607351448" class="text-azul font-semibold">(860) 735-1448</a> and we’ll help you find the right location, provider, and level of care.</p>
      </div>
    </div>
  </section>

  <!-- LOCATIONS GRID -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Find your office</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">All six Connecticut locations</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {locations.map((l) => (
          <div class="flex flex-col overflow-hidden rounded-2xl bg-white border border-line shadow-sm">
            {l.photos
              ? <img src={`${l.photoDir}/exterior.webp`} alt={`Hopewell Health Solutions — ${l.name}`} loading="lazy" class="h-48 w-full object-cover" />
              : <iframe src={l.map} title={`Map — Hopewell Health Solutions, ${l.name}`} class="h-48 w-full border-0 grayscale-[0.15]" loading="lazy" referrerpolicy="no-referrer-when-downgrade"></iframe>}
            <div class="flex flex-1 flex-col p-6">
              <h3 class="font-display text-xl text-ink leading-tight">{l.name}</h3>
              <p class="mt-1.5 flex items-start gap-2 text-sm text-muted"><Icon name="pin" class="h-4 w-4 mt-0.5 shrink-0 text-azul" />{l.street}, {l.city}, CT {l.zip}</p>
              <p class="mt-3 text-sm text-ink leading-relaxed flex-1">{l.blurb}</p>
              <div class="mt-5 flex flex-wrap gap-3">
                <a href={`/location/${l.slug}/`} class="inline-flex items-center gap-1.5 rounded-lg bg-azul px-5 py-2.5 text-sm font-semibold text-white hover:bg-azul-dark transition">View office <Icon name="arrow" class="h-4 w-4" /></a>
                <a href="tel:8607351448" class="inline-flex items-center gap-1.5 rounded-lg border border-azul px-5 py-2.5 text-sm font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-4 w-4" />Call</a>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- AREAS SERVED -->
  <section class="bg-white">
    <div class="mx-auto max-w-5xl px-5 py-16 text-center">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Communities we serve</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Serving towns across Connecticut</h2>
      <p class="mt-3 text-muted max-w-2xl mx-auto">From Hartford County to the shoreline, clients travel to our offices from dozens of nearby communities — and telehealth reaches every corner of the state.</p>
      <div class="mt-8 flex flex-wrap justify-center gap-2">
        {allAreas.map((a) => <span class="rounded-full bg-crema border border-line px-4 py-2 text-sm font-semibold text-ink">{a}</span>)}
      </div>
    </div>
  </section>

  <!-- TELEHEALTH -->
  <section class="bg-crema">
    <div class="mx-auto max-w-5xl px-5 py-16 grid md:grid-cols-[auto_1fr] gap-8 items-center">
      <span class="grid h-20 w-20 place-items-center rounded-2xl bg-azul-light text-azul mx-auto md:mx-0"><Icon name="compass" class="h-10 w-10" /></span>
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care wherever you are</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Telehealth across Connecticut</h2>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">Can’t make it to an office, or prefer to meet from home? Our secure video telehealth brings the same clinicians and the same quality of care to anywhere in Connecticut. It’s ideal for busy schedules, transportation challenges, or simply the comfort of your own space — and you can move between in-person and virtual visits whenever it suits your life. Call <a href="tel:8607351448" class="text-azul font-semibold">(860) 735-1448</a> to set up your first appointment.</p>
      </div>
    </div>
  </section>

  <!-- WHY CHOOSE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Why families choose Hopewell</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">The same trusted care at every location</h2>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-4 gap-5">
        {why.map((w) => (
          <div class="rounded-2xl border border-line bg-crema p-6">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul"><Icon name={w.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug">{w.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed">{w.d}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Clients describe feeling genuinely heard · As featured on Eyewitness News 3</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Most major PPO plans accepted</h2>
        <p class="mt-3 text-muted max-w-xl">We’re in-network with most major PPO plans (we don’t accept Medicaid / HUSKY). Our team verifies your benefits at no cost — at every one of our locations — before you commit to anything.</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <ServicesGrid bg="crema" eyebrow="What we offer" heading="Services & programs across our offices" />

  <!-- FAQ -->
  <section class="bg-white">
    <div class="mx-auto max-w-3xl px-5 py-16">
      <h2 class="font-display text-3xl text-ink text-center">Locations — common questions</h2>
      <div class="mt-8 space-y-3">
        {faqs.map(([q, a]) => (
          <details class="group rounded-xl bg-white border border-azul/30 p-5 open:border-azul open:bg-azul-light/30 hover:border-azul transition">
            <summary class="flex justify-between items-center cursor-pointer font-display text-lg text-ink list-none">{q}<span class="text-azul text-xl group-open:rotate-45 transition">+</span></summary>
            <p class="mt-3 text-ink leading-relaxed">{a}</p>
          </details>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">Find the right office for you</h2>
      <p class="mt-4 text-white/85 text-lg">Reach out to Hopewell Health Solutions today — confidentially, with no pressure — and we’ll help you choose the location nearest you, or set up a telehealth visit.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">Verify Your Insurance</a>
        <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
        <a href="mailto:hhs4help@gmail.com" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition">Email Us</a>
      </div>
      <p class="mt-6 text-xs text-white/60">Not a substitute for emergency care. If you’re in crisis, call or text 988, or call 911.</p>
    </div>
  </section>

  <Footer />
</Base>
