---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import MediaStrip from "../../components/MediaStrip.astro";

const canonical = "https://www.hopewellhealthsolutions.com/about-us/";

const stats = [
  ["14", "Years serving Central Connecticut", "calendar"],
  ["50+", "Clinicians on our team", "users"],
  ["6", "Connecticut locations", "pin"],
  ["50,000+", "Lives helped", "heart"],
];
const offer = [
  { t: "Therapy that works", d: "DBT, CBT, play therapy, solution-focused therapy, the Gottman Method for couples, and trauma-informed care.", href: "/programs/counseling/", icon: "brain" },
  { t: "Therapeutic & mind-body treatments", d: "Accelerated Resolution Therapy (ART), mindfulness, yoga therapy, and other wellness-based methods.", href: "/treatment-methods/therapeutic-treatments/", icon: "heart" },
  { t: "EMDR & eye-movement therapy", d: "Evidence-based trauma therapy that helps the mind heal what words can’t reach.", href: "/treatment-methods/emdr/", icon: "refresh" },
  { t: "Medication management", d: "Personalized psychiatric medication plans that help clients flourish — for ages 4 and up.", href: "/programs/medication-management/", icon: "pill" },
  { t: "Intensive Outpatient Program", d: "Structured group and individual support several days a week, without putting life on hold.", href: "/programs/intensive-outpatient-program/", icon: "calendar" },
  { t: "Spravato® & neuropsych testing", d: "Spravato® for treatment-resistant depression, plus comprehensive neuropsychological testing.", href: "/treatment-methods/spravato/", icon: "sparkles" },
];
const team = [
  ["Kristine A. Schlichting, PhD","Founder & Director","/Assets/Team%20Members/kristine-a-schlichting-phd.webp","/provider/kristine-a-schlichting-ph-d/"],
  ["Teesha Huertas, LCSW","Clinic Director","/Assets/Team%20Members/teesha-huertas-lcsw.webp","/provider/teesha-huertas-lcsw/"],
  ["Katrin Moskowitz, DNP","Psychiatric NP","/Assets/Team%20Members/katrin-moskowitz-dnp-pmhnp-bc-fnp.webp","/provider/katrin-moskowitz-dnp-pmhnp-bc-fnp/"],
  ["Eric Schwartz, PsyD","Psychologist","/Assets/Team%20Members/eric-schwarz-psyd-abpp.webp","/provider/eric-schwartz-psy-d-abpp/"],
  ["Laura Miller, PhD","Neuropsychologist","/Assets/Team%20Members/laura-miller-phd.webp","/provider/laura-miller-ph-d/"],
  ["Tracy Sibley, PMHNP-BC","Psychiatric NP","/Assets/Team%20Members/tracy-sibley-pmhnp-bc-aprn.webp","/provider/tracy-sibley-pmhnp-bc-aprn/"],
];
const C = "/Assets/credibility/";
const trustMarks = [
  ["The Joint Commission — Accredited", C + "joint-commission.webp"],
  ["Better Business Bureau Accredited", C + "bbb.png"],
  ["Psychology Today Verified", C + "psychology-today.png"],
  ["Recovery.com Verified Provider", C + "recovery-verified.png"],
];
const reviews = [
  { n: "Julie Stevens", t: "2 months ago", q: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "Jake Sted", t: "2 months ago", q: "The therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day. Hopewell made a huge difference in my life." },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
---

<Base title="About Hopewell Health Solutions | Mental Health & Psychiatry in CT" description="Hopewell Health Solutions is a superior mental health & psychiatry practice in Glastonbury, Westbrook & West Hartford, CT — board-certified specialists, a multidisciplinary approach, and care for ages 4 and up. Therapy first, medication second, transformation third." canonical={canonical}>
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center">
      <nav class="text-xs text-muted mb-5"><a href="/" class="hover:text-azul">Home</a> / <span class="text-ink">About Us</span></nav>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Mental Health &amp; Psychiatry · Glastonbury, Westbrook &amp; West Hartford, CT</p>
      <h1 class="mt-3 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">About Hopewell Health Solutions</h1>
      <div class="mx-auto mt-5 h-px w-16 bg-gold"></div>
      <p class="mt-5 text-lg text-muted">A superior mental health practice helping clients across Connecticut become the best version of themselves — in person and by telehealth.</p>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WELCOME / MISSION -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-start">
      <img src="/Assets/full%20team%20happy.webp" alt="The Hopewell Health Solutions team in Connecticut" loading="lazy" class="rounded-3xl w-full h-72 lg:h-[28rem] object-cover lg:sticky lg:top-24" />
      <div class="space-y-4 text-ink leading-relaxed text-[17px]">
        <p>Welcome to Hopewell Health Solutions, a superior mental health practice with locations in Glastonbury and West Hartford, Connecticut. Our board-certified specialists take an innovative, multi-disciplinary approach to mental health treatments for clients aged 4 and older in a compassionate, safe environment, whether in person or via telehealth.</p>
        <p>Our mental health experts provide practical solutions, empowerment, and instruction. We’re committed to achieving outstanding client results. Our mission at Hopewell Health Solutions is to help clients become the best version of themselves by providing exceptional, effective treatments and cutting-edge medications that transform lives.</p>
        <p>We offer dialectical behavioral therapy (DBT), cognitive-behavioral therapy (CBT), play therapy, solution-focused therapy, trauma treatments, counseling, and mind-body therapies. Additional mental health solutions include accelerated resolution therapy (ART), eye-movement therapies, the Gottman Method for couples, and other therapeutic treatments. We provide mindfulness therapy, yoga therapy, and numerous other wellness-based methods to ease depression, anxiety, and other mental health concerns.</p>
        <p>Our skilled staff creates personalized psychiatric medication management plans that help clients flourish and empower them to make lifestyle changes and live their best lives. We offer an intensive outpatient program, neuropsychological testing, and Spravato® for treatment-resistant depression.</p>
        <div class="rounded-2xl bg-crema border border-line p-6">
          <p class="font-display text-xl sm:text-2xl text-azul leading-snug">Therapy first. Medication second. Transformation third.</p>
          <p class="mt-3 text-muted text-[16px]">Our mantra guides a diverse team that collaborates to provide five-star treatment plans — giving clients the confidence, clarity, and conviction to create the life they long for and deserve.</p>
        </div>
      </div>
    </div>
  </section>

  <!-- STATS -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="grid grid-cols-2 lg:grid-cols-4 gap-y-12">
        {stats.map(([n, l, icon], i) => (
          <div class={`text-center px-4 ${i > 0 ? "lg:border-l lg:border-white/15" : ""}`}>
            <span class="grid h-12 w-12 mx-auto place-items-center rounded-xl bg-gold-light/15 text-gold-light"><Icon name={icon} class="h-6 w-6" /></span>
            <p class="mt-4 font-display text-5xl sm:text-6xl text-gold-light leading-none">{n}</p>
            <p class="mt-3 text-sm font-semibold text-white/85 leading-snug">{l}</p>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- WHAT WE OFFER -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A multidisciplinary approach</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">What we offer</h2>
      <p class="mt-3 text-muted max-w-2xl">From talk therapy to advanced treatments, everything is coordinated by one team — and tailored to each client.</p>
      <div class="mt-9 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {offer.map((c) => (
          <a href={c.href} class="group rounded-2xl bg-crema border border-line p-6 hover:border-azul hover:shadow-lg transition flex flex-col">
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul group-hover:bg-azul group-hover:text-white transition"><Icon name={c.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink group-hover:text-azul transition leading-snug">{c.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{c.d}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul">Learn more <Icon name="arrow" class="h-4 w-4" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- TEAM TEASER -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">A diverse, board-certified team</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">The people behind the care</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">50+ licensed clinicians — psychologists, psychiatric nurse practitioners, social workers, and trauma specialists — collaborating on every plan.</p>
      </div>
      <div class="mt-10 grid grid-cols-2 sm:grid-cols-3 lg:grid-cols-6 gap-5 max-w-5xl mx-auto">
        {team.map(([name, role, img, href]) => (
          <a href={href} class="group text-center">
            <img src={img} alt={name} loading="lazy" class="w-full aspect-square object-cover object-top rounded-2xl border border-line bg-white group-hover:border-azul transition" />
            <p class="mt-2 font-display text-sm text-ink leading-tight group-hover:text-azul transition">{name}</p>
            <p class="text-xs text-muted">{role}</p>
          </a>
        ))}
      </div>
      <div class="text-center mt-8"><a href="/about-us/team/" class="rounded-lg bg-azul px-7 py-3.5 font-semibold text-white hover:bg-azul-dark transition">Meet our full team →</a></div>
    </div>
  </section>

  <!-- ACCREDITATIONS -->
  <section class="bg-white border-t border-line">
    <div class="mx-auto max-w-6xl px-5 py-12">
      <p class="text-center text-xs font-semibold uppercase tracking-[0.15em] text-muted">Accredited, verified &amp; trusted</p>
      <div class="mt-7 grid grid-cols-2 sm:grid-cols-4 gap-8 items-center justify-items-center">
        {trustMarks.map(([alt, src]) => <img src={src} alt={alt} loading="lazy" class="h-14 w-auto max-w-[160px] object-contain" />)}
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Clients describe feeling genuinely heard · As featured on Eyewitness News 3</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">Ready to Discover Your Path to Healing?</h2>
      <p class="mt-4 text-white/85 text-lg">Schedule an in-person or virtual mental health evaluation today — call our office or get in touch with our experts, confidentially and with no pressure.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="/admissions/" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">Get in touch</a>
        <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
      </div>
      <p class="mt-6 text-xs text-white/60">Not a substitute for emergency care. If you’re in crisis, call or text 988, or call 911.</p>
    </div>
  </section>

  <Footer />
</Base>
