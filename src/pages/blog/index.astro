---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import { urlFor, getBlogList } from "../../lib/sanity";

const canonical = "https://www.hopewellhealthsolutions.com/blog/";
const fmt = (iso) =>
  iso ? new Date(iso).toLocaleDateString("en-US", { year: "numeric", month: "long", day: "numeric", timeZone: "UTC" }) : "";

// Newest first (the query already orders by publishedAt desc). No pagination.
const sorted = await getBlogList();
const [featured, ...rest] = sorted;

// Category chips (client-side filter — no pagination, no page loads)
const categories = Array.from(new Set(sorted.map((p) => p.category).filter(Boolean))).sort();
---

<Base title="Mental Health Blog & Resources | Hopewell Health Solutions" description="Evidence-based articles on mental health, treatment, and recovery — written and clinically reviewed by the licensed clinicians at Hopewell Health Solutions in Connecticut." canonical={canonical}>
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center">
      <nav class="text-xs text-muted mb-5"><a href="/" class="hover:text-azul">Home</a> / <span class="text-ink">Blog</span></nav>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Resources</p>
      <h1 class="mt-3 font-display text-4xl sm:text-5xl text-ink">The Hopewell Blog</h1>
      <div class="mx-auto mt-5 h-px w-16 bg-gold"></div>
      <p class="mt-5 text-lg text-muted">Practical, evidence-based guidance on mental health, treatment, and recovery — written and clinically reviewed by our Connecticut team.</p>
    </div>
  </section>

  {featured && (
    <!-- FEATURED (latest) -->
    <section class="bg-white">
      <div class="mx-auto max-w-6xl px-5 pt-14">
        <a href={`/post/${featured.slug}/`} class="group grid gap-6 md:grid-cols-2 items-center rounded-3xl border border-line overflow-hidden hover:border-azul hover:shadow-lg transition">
          <div class="aspect-[16/10] md:aspect-auto md:h-full overflow-hidden bg-azul-light">
            {featured.mainImage && <img src={urlFor(featured.mainImage).width(900).height(560).fit("crop").url()} alt="" loading="lazy" class="h-full w-full object-cover group-hover:scale-[1.02] transition-transform duration-300" />}
          </div>
          <div class="p-7 md:p-10">
            <span class="inline-flex items-center gap-1.5 rounded-full bg-azul-light px-3 py-1 text-xs font-semibold text-azul"><Icon name="clipboard" class="h-3.5 w-3.5" />{featured.category}</span>
            <h2 class="mt-4 font-display text-2xl sm:text-3xl text-ink leading-snug group-hover:text-azul transition">{featured.title}</h2>
            <p class="mt-3 text-muted leading-relaxed">{featured.excerpt}</p>
            <p class="mt-5 text-sm text-muted">{featured.authorName} · {fmt(featured.publishedAt)}</p>
            <span class="mt-5 inline-flex items-center gap-1 text-sm font-semibold text-azul">Read article <Icon name="arrow" class="h-4 w-4" /></span>
          </div>
        </a>
      </div>
    </section>
  )}

  <!-- CATEGORY FILTER + GRID -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-14">
      <!-- chips -->
      <div class="flex flex-wrap gap-2" role="group" aria-label="Filter by category">
        <button type="button" data-filter="all" class="filter-chip is-active rounded-full border border-line px-4 py-1.5 text-sm font-semibold text-ink transition">All</button>
        {categories.map((c) => (
          <button type="button" data-filter={c} class="filter-chip rounded-full border border-line px-4 py-1.5 text-sm font-semibold text-ink transition">{c}</button>
        ))}
      </div>

      <!-- grid: every post, no pagination -->
      <div id="postGrid" class="mt-8 grid gap-6 sm:grid-cols-2 lg:grid-cols-3">
        {rest.map((p) => (
          <a href={`/post/${p.slug}/`} data-category={p.category} class="post-card group flex flex-col overflow-hidden rounded-2xl border border-line bg-white hover:border-azul hover:shadow-lg transition">
            <div class="aspect-[16/10] overflow-hidden bg-azul-light">
              {p.mainImage && <img src={urlFor(p.mainImage).width(640).height(400).fit("crop").url()} alt="" loading="lazy" class="h-full w-full object-cover group-hover:scale-[1.03] transition-transform duration-300" />}
            </div>
            <div class="flex flex-1 flex-col p-5">
              <span class="text-xs font-semibold uppercase tracking-wide text-azul">{p.category}</span>
              <h3 class="mt-2 font-display text-lg text-ink leading-snug group-hover:text-azul transition">{p.title}</h3>
              <p class="mt-2 text-sm text-muted leading-relaxed line-clamp-3 flex-1">{p.excerpt}</p>
              <p class="mt-4 text-xs text-muted">{p.authorName} · {fmt(p.publishedAt)}</p>
            </div>
          </a>
        ))}
      </div>

      <p id="emptyState" class="mt-10 hidden text-center text-muted">No posts in this category yet.</p>
      <p class="mt-10 text-center text-sm text-muted">{sorted.length} {sorted.length === 1 ? "article" : "articles"} · more on the way</p>
    </div>
  </section>

  <Footer />

  <style>
    .filter-chip.is-active { background: var(--color-azul); color: #fff; border-color: var(--color-azul); }
    .filter-chip:not(.is-active):hover { background: var(--color-azul-light); }
  </style>

  <script>
    const chips = document.querySelectorAll(".filter-chip");
    const cards = document.querySelectorAll(".post-card");
    const empty = document.getElementById("emptyState");
    chips.forEach((chip) => {
      chip.addEventListener("click", () => {
        const f = chip.getAttribute("data-filter");
        chips.forEach((c) => c.classList.toggle("is-active", c === chip));
        let shown = 0;
        cards.forEach((card) => {
          const match = f === "all" || card.getAttribute("data-category") === f;
          card.classList.toggle("hidden", !match);
          if (match) shown++;
        });
        empty?.classList.toggle("hidden", shown > 0);
      });
    });
  </script>
</Base>
