---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";
import ServicesGrid from "../../components/ServicesGrid.astro";

const canonical = "https://www.hopewellhealthsolutions.com/what-we-treat/depression";

const heroUsps = [
  { icon: "shield", t: "Board-certified psychologists & psychiatric prescribers" },
  { icon: "brain", t: "Therapy, medication management, TMS & Spravato® under one roof" },
  { icon: "heart", t: "Help for treatment-resistant depression — when nothing has worked" },
  { icon: "compass", t: "In person (Glastonbury & West Hartford) or telehealth" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const signs = [
  { t: "Persistent sadness, emptiness, or low mood", icon: "cloud" },
  { t: "Loss of interest or pleasure in things you used to enjoy", icon: "swap" },
  { t: "Sleeping too much or too little", icon: "calendar" },
  { t: "Fatigue or low energy nearly every day", icon: "refresh" },
  { t: "Trouble concentrating, remembering, or making decisions", icon: "brain" },
  { t: "Changes in appetite or weight", icon: "alert" },
  { t: "Feelings of worthlessness, guilt, or hopelessness", icon: "heart" },
];
const seekHelp = [
  { t: "Low mood has lasted more than two weeks", icon: "calendar" },
  { t: "Depression is affecting work, school, or relationships", icon: "alert" },
  { t: "You’ve lost interest in things that used to matter", icon: "cloud" },
  { t: "Sleep, appetite, or energy have noticeably changed", icon: "refresh" },
  { t: "Therapy or medication alone hasn’t been enough", icon: "swap" },
  { t: "You’re having thoughts that life isn’t worth living", icon: "heart" },
];
const toneMap = { azul: "bg-azul-light text-azul", gold: "bg-gold-light text-gold", sage: "bg-sage-light text-sage" };
const approach = [
  { icon: "pill", tone: "azul", t: "Medication management", d: "Thoughtful psychiatric prescribing from our board-certified providers — finding the right medication, at the right dose, with careful follow-up and adjustments over time.", href: "/programs/medication-management/" },
  { icon: "brain", tone: "gold", t: "Therapy that works", d: "Evidence-based talk therapy — including CBT and DBT — to shift the thoughts and patterns that keep depression in place, and to build skills that last.", href: "/programs/counseling/" },
  { icon: "bolt", tone: "sage", t: "TMS for treatment-resistant depression", d: "When medication and therapy haven’t been enough, FDA-cleared TMS uses gentle magnetic pulses to reactivate the brain — drug-free, with no downtime.", href: "/treatment-methods/tms/" },
  { icon: "sparkles", tone: "azul", t: "Spravato® (esketamine)", d: "For depression that hasn’t responded to other treatments, Spravato is administered and monitored right in our offices, often with rapid relief.", href: "/treatment-methods/spravato/" },
  { icon: "calendar", tone: "gold", t: "Intensive Outpatient Program", d: "When weekly sessions aren’t enough, our IOP adds several days a week of structured group and individual support — without putting your life on hold.", href: "/programs/intensive-outpatient-program/" },
  { icon: "heart", tone: "sage", t: "Whole-person care", d: "We treat depression alongside anxiety, trauma, or chronic stress — never in isolation — with a plan built around you and your goals.", href: null },
];
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Julie Stevens", t: "2 months ago", q: "From the moment I walked in, the staff made me feel welcome and cared for. The providers are professional, compassionate, and truly take the time to listen. Highly recommend this practice to anyone looking for thoughtful, personalized care!" },
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "Jake Sted", t: "2 months ago", q: "The therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day. Hopewell made a huge difference in my life." },
  { n: "Cynthia Askew", t: "6 months ago", q: "Rosa Kleinberg is a consummate professional — prepared and on top of her game. She asks the right questions and listens with care and understanding, committed to finding the right balance for a healthy, quality life." },
  { n: "stacey miller", t: "3 months ago", q: "They put me on the schedule as a new patient within the same week of calling, which never happens, and made sure my insurance was accepted. The provider and staff were very professional and kind." },
  { n: "Joana Yoo", t: "10 months ago", q: "Christopher P. was extremely accommodating and took the time to meet with us without making us feel rushed. His calm and respectful demeanor made it easy to open up, and we felt heard and understood. Highly recommended." },
];
const locations = [
  ["Downtown Glastonbury", "300 Hebron Ave, Suite 203, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.352088935695!2d-72.6014876!3d41.7129207!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f086f393%3A0xca25306a43f52c40!2sHopewell%20Health%20Solutions-%20Glastonbury!5e0!3m2!1sen!2sus!4v1781754310129!5m2!1sen!2sus"],
  ["Glastonbury", "33 Pratt St, Glastonbury, CT 06033", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2978.0462929427076!2d-72.6158734!3d41.7195199!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e65229f7540001%3A0x207d1c58279c2917!2sKristine%20Schlichting!5e0!3m2!1sen!2sus!4v1781754351066!5m2!1sen!2sus"],
  ["South Glastonbury", "1420 Main St, Suite 124, Glastonbury, CT 06073", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d11918.711576046591!2d-72.60043998441421!3d41.68429942600149!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e651e2650fffff%3A0x2f4e4d624c5aadc9!2s1420%20Main%20St%20Suit%20124%2C%20Glastonbury%2C%20CT%2006033!5e0!3m2!1sen!2sus!4v1781754695365!5m2!1sen!2sus"],
  ["West Hartford", "1216 Farmington Ave, Suite 301, West Hartford, CT 06107", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5952.7389464474345!2d-72.7643461!3d41.7556912!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e7ac50c26c2c71%3A0x794a9d4447f2f815!2s1216%20Farmington%20Ave%20%23301%2C%20West%20Hartford%2C%20CT%2006107!5e0!3m2!1sen!2sus!4v1781754415819!5m2!1sen!2sus"],
  ["East Hampton", "151 E. High St, East Hampton, CT 06424", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d2983.7824223633115!2d-72.49079189999999!3d41.595589499999996!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e64575a93599c7%3A0x4db6adc86935149a!2sHopewell%20Health%20Solutions%20-%20East%20Hampton!5e0!3m2!1sen!2sus!4v1781754448028!5m2!1sen!2sus"],
  ["Westbrook", "70 Essex Road, Westbrook, CT 06498", "https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d5995.9718215263765!2d-72.4473502!3d41.2874111!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x89e62415b9edbbf3%3A0x388064d34123e66b!2s70%20Essex%20Rd%2C%20Westbrook%2C%20CT%2006498!5e0!3m2!1sen!2sus!4v1781754474034!5m2!1sen!2sus"],
];
const faqs = [
  ["What is depression?", "Depression — also called major depressive disorder — is a common but serious mood disorder that affects how you feel, think, and handle daily life. It’s more than feeling sad or going through a rough patch: it’s a persistent low mood and loss of interest that lasts for weeks or longer, and it often affects sleep, appetite, energy, and concentration as well as mood. Depression is a real medical condition rooted in brain chemistry, genetics, and life experience — not a weakness or something a person can simply 'snap out of' — and it is highly treatable."],
  ["What are the signs of depression?", "Common signs include persistent sadness or low mood; loss of interest or pleasure in activities once enjoyed; sleeping too much or too little; fatigue or low energy; trouble concentrating, remembering, or making decisions; changes in appetite or weight; and feelings of worthlessness, guilt, or hopelessness. Some people also experience physical symptoms like aches or digestive issues, or thoughts that life isn’t worth living. If symptoms last more than two weeks or interfere with daily life, it’s worth reaching out for an evaluation."],
  ["How is depression treated?", "Depression is treated with a combination of approaches tailored to the individual. At Hopewell Health Solutions, that often includes evidence-based therapy (such as CBT and DBT), psychiatric medication management, and — when weekly support isn’t enough — a structured Intensive Outpatient Program. For depression that hasn’t responded to medication or therapy, we also offer advanced, FDA-cleared options like TMS and Spravato®. Most people improve significantly with the right combination and consistent care."],
  ["What is treatment-resistant depression?", "Treatment-resistant depression refers to depression that hasn’t improved enough after trying one or more standard treatments, such as antidepressants or therapy. It does not mean depression is untreatable — it means a different approach is needed. Options like TMS (a drug-free magnetic stimulation therapy) and Spravato® (esketamine, given and monitored in-office) are designed specifically for these situations and can bring relief when earlier treatments fell short."],
  ["When should I seek help for depression?", "Reach out when low mood has lasted more than two weeks, when depression is affecting your work, school, sleep, or relationships, or when therapy or medication alone hasn’t been enough. You don’t need to wait until things feel unbearable — earlier support makes recovery easier. If you are having thoughts of harming yourself or that life isn’t worth living, call or text 988 right away, or call 911."],
];
const faqSchema = {
  "@context": "https://schema.org",
  "@type": "FAQPage",
  mainEntity: faqs.map(([q, a]) => ({ "@type": "Question", name: q, acceptedAnswer: { "@type": "Answer", text: a } })),
};
---

<Base title="Depression Treatment in CT | Hopewell Health Solutions" description="Depression treatment at Hopewell Health Solutions in Glastonbury & West Hartford, CT — therapy, medication management, TMS & Spravato® for lasting relief, including treatment-resistant depression. In person & telehealth." canonical={canonical}>
  <Header />
  <script type="application/ld+json" set:html={JSON.stringify(faqSchema)} />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 pt-8 pb-16">
      <nav class="text-xs text-muted mb-6"><a href="/" class="hover:text-azul">Home</a> / <a href="/what-we-treat/" class="hover:text-azul">What We Treat</a> / <span class="text-ink">Depression</span></nav>
      <div class="grid lg:grid-cols-[1fr_390px] gap-12 items-start">
        <div>
          <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Depression Treatment · Glastonbury &amp; West Hartford, CT · In person &amp; telehealth</p>
          <h1 class="mt-4 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Depression Treatment in Connecticut</h1>
          <p class="mt-3 font-display text-xl text-azul italic">You don’t have to feel this way forever — relief is possible.</p>
          <div class="mt-5 h-px w-16 bg-gold"></div>
          <div class="mt-5 flex items-center gap-2.5 text-sm">
            <span class="text-yellow-400 text-base leading-none">★★★★★</span>
            <span class="font-semibold text-ink">4.8</span>
            <span class="text-muted">· 368 Google reviews</span>
          </div>
          <ul class="mt-6 space-y-3">
            {heroUsps.map((u) => (
              <li class="flex gap-3 text-ink"><span class="grid h-7 w-7 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={u.icon} class="h-4 w-4" /></span><span class="leading-snug pt-0.5">{u.t}</span></li>
            ))}
          </ul>
          <div class="mt-8">
            <a href="tel:8609460447" class="inline-flex items-center gap-2.5 rounded-lg border border-azul px-8 py-4 text-lg font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-5 w-5" />(860) 946-0447</a>
          </div>
          <p class="mt-6 text-xs text-muted">Medically reviewed by Kristine Schlichting, PhD</p>
        </div>
        <div id="verify" class="lg:sticky lg:top-28 scroll-mt-28"><LeadForm heading="Take the first step" sub="Free, confidential. We’ll verify your benefits and help you find the right care for depression." /></div>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- WHAT IS (image left / text right) -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-2 gap-10 lg:gap-14 items-center">
      <img src="/Assets/girl%20thinking%20worried.webp" alt="Finding relief from depression at Hopewell Health Solutions, Connecticut" loading="lazy" class="rounded-2xl w-full h-72 lg:h-96 object-cover" />
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">More than a rough patch</p>
        <h2 class="mt-3 font-display text-3xl sm:text-4xl text-ink">What is depression?</h2>
        <div class="mt-4 h-px w-16 bg-azul/40"></div>
        <p class="mt-5 text-ink leading-relaxed text-[17px]">Depression — also called major depressive disorder — is a common but serious mood disorder that changes how you feel, think, and handle daily life. It’s more than sadness or a passing low: it’s a persistent heaviness and loss of interest that can last for weeks, months, or longer, often showing up in the body as well as the mind — in your sleep, energy, appetite, and concentration.</p>
        <p class="mt-4 text-ink leading-relaxed text-[17px]">Depression is not a weakness, and it’s not something you can simply will away. It’s a real medical condition shaped by brain chemistry, genetics, life experience, and stress — and it is highly treatable. The board-certified team at Hopewell Health Solutions treats depression with therapy, medication management, and advanced options like TMS and Spravato® — meeting you where you are and building a plan around your life.</p>
      </div>
    </div>
  </section>

  <!-- SIGNS -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Know what to look for</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Signs of depression</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">Depression looks different for everyone, but common signs that last two weeks or more include:</p>
      </div>
      <div class="mt-10 flex flex-wrap justify-center gap-4">
        {signs.map((s) => (
          <div class="flex items-center gap-3 rounded-xl bg-white border border-line p-5">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={s.icon} class="h-5 w-5" /></span>
            <span class="text-sm font-semibold text-ink leading-snug">{s.t}</span>
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- OUR APPROACH -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">What depression treatment looks like here</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Our approach to depression treatment</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">There’s no single right path. We combine therapy, medication, and advanced options — tailored to you — and adjust as you heal, including care for depression that hasn’t responded to treatment before.</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-5">
        {approach.map((a) => (
          <div class="rounded-2xl border border-line bg-crema p-6 flex flex-col">
            <span class={`grid h-12 w-12 place-items-center rounded-xl ${toneMap[a.tone]}`}><Icon name={a.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink leading-snug">{a.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{a.d}</p>
            {a.href && <a href={a.href} class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul hover:gap-2 transition-all">Learn more <Icon name="arrow" class="h-4 w-4" /></a>}
          </div>
        ))}
      </div>
    </div>
  </section>

  <!-- QUOTE BAND -->
  <section class="relative">
    <img src="/Assets/team%20together%202.webp" alt="" aria-hidden="true" class="absolute inset-0 h-full w-full object-cover" />
    <div class="absolute inset-0 bg-ink/80"></div>
    <div class="relative mx-auto max-w-3xl px-5 py-20 text-center">
      <p class="font-display text-2xl sm:text-3xl text-white italic leading-snug">“Depression is treatable. With the right care, the heaviness lifts — and life can feel like yours again.”</p>
    </div>
  </section>

  <!-- WHEN TO SEEK HELP -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">It may be time for support</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">When to seek depression treatment</h2>
        <p class="mt-3 text-muted max-w-2xl mx-auto">You don’t need to wait until things feel unbearable. Consider reaching out when:</p>
      </div>
      <div class="mt-10 grid sm:grid-cols-2 lg:grid-cols-3 gap-4">
        {seekHelp.map((s) => (
          <div class="flex items-start gap-3 rounded-xl bg-white border border-line p-5">
            <span class="grid h-9 w-9 shrink-0 place-items-center rounded-lg bg-azul-light text-azul"><Icon name={s.icon} class="h-5 w-5" /></span>
            <span class="text-sm font-semibold text-ink leading-snug pt-1.5">{s.t}</span>
          </div>
        ))}
      </div>
      <p class="mt-8 text-center text-ink max-w-2xl mx-auto leading-relaxed">If any of these feel familiar, reach out to the team at Hopewell Health Solutions. <strong>Earlier support makes recovery easier.</strong></p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-azul px-7 py-3.5 font-semibold text-white hover:bg-azul-dark transition">Request an appointment</a>
        <a href="tel:8609460447" class="inline-flex items-center gap-2 rounded-lg border border-azul px-7 py-3.5 font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-4 w-4" />(860) 946-0447</a>
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Clients describe feeling genuinely heard · As featured on Eyewitness News 3</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Most major PPO plans accepted</h2>
        <p class="mt-3 text-muted max-w-xl">We’re in-network with most major PPO plans (we don’t accept Medicaid / HUSKY). Our team verifies your benefits at no cost — before you commit to anything.</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <!-- LOCATIONS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Care across Connecticut</p>
