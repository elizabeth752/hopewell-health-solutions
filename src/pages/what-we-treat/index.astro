---
import Base from "../../layouts/Base.astro";
import Header from "../../components/Header.astro";
import Footer from "../../components/Footer.astro";
import Icon from "../../components/Icon.astro";
import LeadForm from "../../components/LeadForm.astro";
import MediaStrip from "../../components/MediaStrip.astro";

const canonical = "https://www.hopewellhealthsolutions.com/what-we-treat/";

const mentalHealth = [
  { t: "Depression", d: "More than sadness — therapy, medication, TMS & Spravato® for lasting relief.", href: "/what-we-treat/depression/", icon: "cloud" },
  { t: "Anxiety", d: "CBT, exposure therapy & skills for panic, social anxiety, GAD and more.", href: "/what-we-treat/anxiety/", icon: "alert" },
  { t: "Trauma & PTSD", d: "EMDR, ART & CPT, plus Women’s Trauma and First Responder programs.", href: "/what-we-treat/trauma-ptsd/", icon: "heart" },
  { t: "ADHD", d: "Comprehensive testing and treatment for children, teens & adults.", href: "/what-we-treat/adhd/", icon: "bolt" },
  { t: "OCD", d: "ERP therapy, medication, and TMS — FDA-cleared for OCD.", href: "/what-we-treat/ocd/", icon: "refresh" },
  { t: "Bipolar Disorder", d: "Expert medication management and therapy for lasting stability.", href: "/what-we-treat/bipolar/", icon: "swap" },
  { t: "Co-Occurring Disorders", d: "Integrated, dual-diagnosis care — mental health and substance use together.", href: "/what-we-treat/co-occurring/", icon: "link" },
];
const substanceUse = [
  { t: "Substance Use Disorder", d: "Medical, psychological & therapeutic care for lasting recovery.", href: "/what-we-treat/substance-use-disorder/", icon: "pill" },
  { t: "Alcohol Dependence", d: "Compassionate treatment for alcohol dependence — from stabilization to recovery.", href: "/what-we-treat/alcohol/", icon: "swap" },
  { t: "Drug Dependence", d: "Evidence-based care for drug dependence and the roots beneath it.", href: "/what-we-treat/drug/", icon: "bolt" },
  { t: "Prescription Drug Dependence", d: "Specialized treatment for prescription drug dependence.", href: "/what-we-treat/prescription-drugs/", icon: "clipboard" },
];
const googleG = '<svg viewBox="0 0 48 48" xmlns="http://www.w3.org/2000/svg"><path fill="#4285F4" d="M45.12 24.5c0-1.56-.14-3.06-.4-4.5H24v8.51h11.84c-.51 2.75-2.06 5.08-4.39 6.64v5.52h7.11c4.16-3.83 6.56-9.47 6.56-16.17z"/><path fill="#34A853" d="M24 46c5.94 0 10.92-1.97 14.56-5.33l-7.11-5.52c-1.97 1.32-4.49 2.1-7.45 2.1-5.73 0-10.58-3.87-12.31-9.07H4.34v5.7C7.96 41.07 15.4 46 24 46z"/><path fill="#FBBC05" d="M11.69 28.18C11.25 26.86 11 25.45 11 24s.25-2.86.69-4.18v-5.7H4.34A21.99 21.99 0 0 0 2 24c0 3.55.85 6.91 2.34 9.88l7.35-5.7z"/><path fill="#EA4335" d="M24 10.75c3.23 0 6.13 1.11 8.41 3.29l6.31-6.31C34.91 4.18 29.93 2 24 2 15.4 2 7.96 6.93 4.34 14.12l7.35 5.7c1.73-5.2 6.58-9.07 12.31-9.07z"/></svg>';
const insurers = [
  ["Aetna","/Assets/Insurance/AETNA.webp"],["Anthem","/Assets/Insurance/Anthem.webp"],
  ["Blue Cross Blue Shield","/Assets/Insurance/BCBS.webp"],["Cigna","/Assets/Insurance/CIGNA.webp"],
  ["Magellan","/Assets/Insurance/Magellan%20Health.webp"],["Optum","/Assets/Insurance/Optum.webp"],
  ["TRICARE","/Assets/Insurance/TRICARE.webp"],["UMR","/Assets/Insurance/URM.webp"],
  ["UnitedHealthcare","/Assets/Insurance/UnitedHealthcare.webp"],["VA Community Care","/Assets/Insurance/VA%20Community%20Care.webp"],
  ["ConnectiCare","/Assets/ConnnectiCare.webp"],["Harvard Pilgrim","/Assets/Harvard%20Pilgrim.webp"],
];
const reviews = [
  { n: "Emily Ross", t: "8 months ago", q: "This is the best therapy place I have ever been to. All the clinicians are amazing and actually care about you. Now I’m doing individual therapy and med management — I highly recommend this place." },
  { n: "Jake Sted", t: "2 months ago", q: "The therapists genuinely took the time to understand each person’s needs. It helped me develop real tools I use every day. Hopewell made a huge difference in my life." },
];

const Card = "group rounded-2xl bg-white border border-line p-6 hover:border-azul hover:shadow-lg transition flex flex-col";
---

<Base title="Conditions We Treat in CT | Hopewell Health Solutions" description="The mental health and substance use conditions treated at Hopewell Health Solutions in Connecticut — depression, anxiety, trauma & PTSD, ADHD, OCD, bipolar, co-occurring & more. In person & telehealth." canonical={canonical}>
  <Header />

  <!-- HERO -->
  <section class="bg-crema">
    <div class="mx-auto max-w-4xl px-5 py-16 text-center">
      <nav class="text-xs text-muted mb-5"><a href="/" class="hover:text-azul">Home</a> / <span class="text-ink">What We Treat</span></nav>
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">For ages 4 and up</p>
      <h1 class="mt-3 font-display text-4xl sm:text-5xl text-ink leading-[1.08]">Conditions We Treat in Connecticut</h1>
      <div class="mx-auto mt-5 h-px w-16 bg-gold"></div>
      <p class="mt-5 text-lg text-muted">From depression and anxiety to trauma, ADHD, and substance use, the board-certified team at Hopewell Health Solutions treats the full range of mental health and co-occurring conditions — for children, teens, and adults — in person across Connecticut and by telehealth.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-azul px-7 py-3.5 font-semibold text-white hover:bg-azul-dark transition">Verify Your Insurance →</a>
        <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg border border-azul px-7 py-3.5 font-semibold text-azul hover:bg-azul-light transition"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
      </div>
    </div>
  </section>

  <MediaStrip bg="white" heading="Our clinicians, featured across Connecticut" />

  <!-- MENTAL HEALTH -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Mental health</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Mental health conditions</h2>
      <p class="mt-3 text-muted max-w-2xl">Evidence-based, compassionate care — therapy, medication management, and advanced options like TMS and Spravato® — tailored to each person.</p>
      <div class="mt-9 grid gap-5 sm:grid-cols-2 lg:grid-cols-3">
        {mentalHealth.map((c) => (
          <a href={c.href} class={Card}>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul group-hover:bg-azul group-hover:text-white transition"><Icon name={c.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-xl text-ink group-hover:text-azul transition">{c.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{c.d}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul">Learn more <Icon name="arrow" class="h-4 w-4" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- SUBSTANCE USE -->
  <section class="bg-crema">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <p class="text-xs font-semibold uppercase tracking-[0.15em] text-azul">Substance use & recovery</p>
      <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Substance use conditions</h2>
      <p class="mt-3 text-muted max-w-2xl">Integrated, dual-diagnosis care that treats substance use alongside the mental health conditions that so often go with it.</p>
      <div class="mt-9 grid gap-5 sm:grid-cols-2 lg:grid-cols-4">
        {substanceUse.map((c) => (
          <a href={c.href} class={Card}>
            <span class="grid h-12 w-12 place-items-center rounded-xl bg-azul-light text-azul group-hover:bg-azul group-hover:text-white transition"><Icon name={c.icon} class="h-6 w-6" /></span>
            <h3 class="mt-4 font-display text-lg text-ink group-hover:text-azul transition leading-snug">{c.t}</h3>
            <p class="mt-2 text-sm text-muted leading-relaxed flex-1">{c.d}</p>
            <span class="mt-4 inline-flex items-center gap-1 text-sm font-semibold text-azul">Learn more <Icon name="arrow" class="h-4 w-4" /></span>
          </a>
        ))}
      </div>
    </div>
  </section>

  <!-- REVIEWS -->
  <section class="bg-white">
    <div class="mx-auto max-w-6xl px-5 py-16">
      <div class="text-center">
        <div class="inline-flex items-center gap-3 rounded-full bg-white border border-line px-5 py-2.5 shadow-sm">
          <span class="h-6 w-6 inline-block" set:html={googleG} />
          <span class="font-display text-2xl text-ink leading-none">4.8</span>
          <span class="text-yellow-400 text-lg leading-none">★★★★★</span>
          <span class="text-sm text-muted">368 Google reviews</span>
        </div>
        <p class="mt-3 text-muted">Clients describe feeling genuinely heard · As featured on Eyewitness News 3</p>
      </div>
      <div class="mt-10 grid md:grid-cols-3 gap-6">
        {reviews.map((r) => (
          <figure class="rounded-2xl bg-white border border-line p-7 shadow-sm flex flex-col">
            <div class="flex items-center justify-between">
              <span class="text-yellow-400 text-lg">★★★★★</span>
              <span class="h-5 w-5 inline-block opacity-90" set:html={googleG} />
            </div>
            <blockquote class="mt-4 text-ink leading-relaxed text-[15px] flex-1">“{r.q}”</blockquote>
            <figcaption class="mt-5 flex items-center gap-3 border-t border-line pt-4">
              <span class="grid h-10 w-10 place-items-center rounded-full bg-azul-light text-azul font-semibold">{r.n.charAt(0).toUpperCase()}</span>
              <span><span class="block text-sm font-semibold text-ink">{r.n}</span><span class="block text-xs text-muted">{r.t}</span></span>
            </figcaption>
          </figure>
        ))}
      </div>
    </div>
  </section>

  <!-- INSURANCE -->
  <section class="bg-crema">
    <div id="verify" class="mx-auto max-w-6xl px-5 py-16 grid lg:grid-cols-[1.1fr_0.9fr] gap-10 lg:gap-14 items-start scroll-mt-28">
      <div>
        <p class="text-xs font-semibold uppercase tracking-[0.15em] text-gold">Insurance accepted</p>
        <h2 class="mt-2 font-display text-3xl sm:text-4xl text-ink">Most major PPO plans accepted</h2>
        <p class="mt-3 text-muted max-w-xl">We’re in-network with most major PPO plans (we don’t accept Medicaid / HUSKY). Our team verifies your benefits at no cost — before you commit to anything.</p>
        <div class="mt-8 grid grid-cols-2 sm:grid-cols-3 gap-4">
          {insurers.map(([name, img]) => (
            <div class="rounded-xl bg-white border border-line p-4 flex items-center justify-center h-20"><img src={img} alt={name} loading="lazy" class="max-h-12 max-w-[85%] object-contain" /></div>
          ))}
        </div>
        <p class="mt-4 text-sm text-muted text-center sm:text-left">+ most major PPOs</p>
      </div>
      <div class="lg:sticky lg:top-28"><LeadForm heading="Check your coverage" sub="Free, confidential. Takes 2 minutes — we’ll call you back with a full benefits breakdown." /></div>
    </div>
  </section>

  <!-- CTA -->
  <section class="bg-azul text-white">
    <div class="mx-auto max-w-3xl px-5 py-16 text-center">
      <h2 class="font-display text-3xl sm:text-4xl text-white">Not sure where to start?</h2>
      <p class="mt-4 text-white/85 text-lg">You don’t need a diagnosis to reach out. Tell us what’s going on, and our Connecticut team will help you find the right care — confidentially, with no pressure.</p>
      <div class="mt-7 flex flex-wrap justify-center gap-3">
        <a href="#verify" class="rounded-lg bg-white px-7 py-3.5 font-semibold text-azul hover:bg-crema transition">Verify Your Insurance</a>
        <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg border border-white/60 px-7 py-3.5 font-semibold text-white hover:bg-white/10 transition"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
      </div>
      <p class="mt-6 text-xs text-white/60">Not a substitute for emergency care. If you’re in crisis, call or text 988, or call 911.</p>
    </div>
  </section>

  <Footer />
</Base>
