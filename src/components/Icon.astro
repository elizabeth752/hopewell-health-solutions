---
// Inline SVG icons (stroke = currentColor). Usage: <Icon name="brain" class="h-6 w-6" />
const { name, class: cls = "h-6 w-6" } = Astro.props;
const P = {
  brain: '<path d="M9.5 3A2.5 2.5 0 0 0 7 5.5v.5a3 3 0 0 0-1.5 5.6A3 3 0 0 0 7 17v.5A2.5 2.5 0 0 0 9.5 20 2.5 2.5 0 0 0 12 17.5V5.5A2.5 2.5 0 0 0 9.5 3Z"/><path d="M14.5 3A2.5 2.5 0 0 1 17 5.5v.5a3 3 0 0 1 1.5 5.6A3 3 0 0 1 17 17v.5a2.5 2.5 0 0 1-5 0"/>',
  dna: '<path d="M5 4c0 4 14 6 14 16M19 4C19 8 5 10 5 20"/><path d="M7 6h10M7.5 9h9M8 18h8M8.5 15h7"/>',
  users: '<circle cx="9" cy="8" r="3"/><path d="M3.5 20a5.5 5.5 0 0 1 11 0"/><path d="M16 5.2a3 3 0 0 1 0 5.6M20.5 20a5.5 5.5 0 0 0-4-5.3"/>',
  sparkles: '<path d="M12 3l1.8 4.7L18.5 9.5 13.8 11.3 12 16l-1.8-4.7L5.5 9.5l4.7-1.8Z"/><path d="M18 15l.8 2 2 .8-2 .8-.8 2-.8-2-2-.8 2-.8Z"/>',
  heart: '<path d="M12 20s-7-4.3-9.3-8.5C1.2 8.3 2.7 5 6 5c2 0 3.3 1.2 4 2.4C10.7 6.2 12 5 14 5c3.3 0 4.8 3.3 3.3 6.5C19 15.7 12 20 12 20Z"/>',
  shield: '<path d="M12 3l7 3v5c0 4.5-3 8-7 10-4-2-7-5.5-7-10V6Z"/><path d="m9 12 2 2 4-4"/>',
  bolt: '<path d="M13 2 4 14h6l-1 8 9-12h-6Z"/>',
  cloud: '<path d="M7 18a4 4 0 0 1 0-8 5 5 0 0 1 9.6-1.3A3.5 3.5 0 0 1 17 18Z"/><path d="M9 21l-1 1M13 21l-1 1M17 21l-1 1"/>',
  refresh: '<path d="M21 12a9 9 0 1 1-2.6-6.3"/><path d="M21 4v5h-5"/>',
  pill: '<rect x="3" y="8" width="18" height="8" rx="4" transform="rotate(-45 12 12)"/><path d="M9 9l6 6"/>',
  link: '<path d="M10 13a4 4 0 0 0 5.7.3l2.6-2.6a4 4 0 0 0-5.6-5.6L11.5 6.3"/><path d="M14 11a4 4 0 0 0-5.7-.3L5.7 13.3a4 4 0 0 0 5.6 5.6L12.5 17.7"/>',
  alert: '<circle cx="12" cy="12" r="9"/><path d="M12 8v5M12 16h.01"/>',
  swap: '<path d="M7 4 3 8l4 4"/><path d="M3 8h13a4 4 0 0 1 0 8h-1"/><path d="M17 20l4-4-4-4"/>',
  phone: '<path d="M5 3h3.5l1.5 4.5-2 1.5a12 12 0 0 0 5.5 5.5l1.5-2 4.5 1.5V19a2 2 0 0 1-2.2 2A16 16 0 0 1 4 6.2 2 2 0 0 1 5 3Z"/>',
  clipboard: '<rect x="6" y="4" width="12" height="17" rx="2"/><path d="M9 4a1 1 0 0 1 1-1h4a1 1 0 0 1 1 1v1H9Z"/><path d="M9 11h6M9 15h4"/>',
  pin: '<path d="M12 21s-6-5-6-10a6 6 0 0 1 12 0c0 5-6 10-6 10Z"/><circle cx="12" cy="11" r="2.2"/>',
  compass: '<circle cx="12" cy="12" r="9"/><path d="m15.5 8.5-2 5-5 2 2-5Z"/>',
  star: '<path d="M12 3.5l2.6 5.6 6 .6-4.5 4 1.3 5.9L12 16.9 6.6 19.6 7.9 13.7l-4.5-4 6-.6Z"/>',
  arrow: '<path d="M5 12h14M13 6l6 6-6 6"/>',
  calendar: '<rect x="4" y="5" width="16" height="16" rx="2"/><path d="M4 9h16M8 3v4M16 3v4"/>',
  sun: '<circle cx="12" cy="12" r="4"/><path d="M12 2v2M12 20v2M2 12h2M20 12h2M5 5l1.5 1.5M17.5 17.5 19 19M19 5l-1.5 1.5M6.5 17.5 5 19"/>',
};
const fillIcons = ["star", "sparkles", "bolt"];
const d = P[name] || P.heart;
---
<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 24 24" class={cls}
  fill={fillIcons.includes(name) ? "currentColor" : "none"} stroke="currentColor"
  stroke-width="1.75" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" set:html={d} />
