  facebook: '<svg viewBox="0 0 24 24" fill="currentColor" class="h-3 w-3"><path d="M13.5 21v-8h2.7l.4-3.1h-3.1V7.9c0-.9.25-1.5 1.55-1.5h1.65V3.6c-.8-.1-1.6-.15-2.4-.15-2.4 0-4.05 1.45-4.05 4.15v2.3H7.5V13h2.75v8h3.25Z"/></svg>',
  x: '<svg viewBox="0 0 24 24" fill="currentColor" class="h-[11px] w-[11px]"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24h-6.66l-5.214-6.817L4.99 21.75H1.68l7.73-8.835L1.254 2.25H8.08l4.713 6.231 5.45-6.231Zm-1.161 17.52h1.833L7.084 4.126H5.117L17.083 19.77Z"/></svg>',
  linkedin: '<svg viewBox="0 0 24 24" fill="currentColor" class="h-3 w-3"><path d="M4.98 3.5C4.98 4.6 4.1 5.5 3 5.5S1 4.6 1 3.5 1.9 1.5 3 1.5s1.98.9 1.98 2ZM1.25 8.25h3.5V22h-3.5V8.25ZM8 8.25h3.35v1.88h.05c.47-.88 1.6-1.8 3.3-1.8 3.53 0 4.18 2.32 4.18 5.34V22h-3.5v-5.7c0-1.36-.02-3.1-1.9-3.1-1.9 0-2.18 1.48-2.18 3v5.8H8V8.25Z"/></svg>',
  tiktok: '<svg viewBox="0 0 24 24" fill="currentColor" class="h-3 w-3"><path d="M16.6 5.82a4.28 4.28 0 0 1-1.05-2.82h-3.2v12.7a2.59 2.59 0 0 1-2.58 2.48 2.59 2.59 0 0 1 0-5.18c.27 0 .52.04.76.12v-3.3a5.86 5.86 0 0 0-.76-.05 5.83 5.83 0 1 0 5.83 5.83V9.01a7.45 7.45 0 0 0 4.37 1.4V7.2a4.28 4.28 0 0 1-3.04-1.38Z"/></svg>',
  pinterest: '<svg viewBox="0 0 24 24" fill="currentColor" class="h-3 w-3"><path d="M12 2C6.48 2 2 6.48 2 12c0 4.24 2.64 7.86 6.36 9.32-.09-.79-.17-2 .03-2.86.18-.78 1.18-4.97 1.18-4.97s-.3-.6-.3-1.49c0-1.4.81-2.44 1.82-2.44.86 0 1.27.64 1.27 1.41 0 .86-.55 2.15-.83 3.34-.24 1 .5 1.81 1.48 1.81 1.78 0 3.15-1.88 3.15-4.58 0-2.4-1.72-4.07-4.18-4.07-2.85 0-4.52 2.13-4.52 4.34 0 .86.33 1.78.74 2.28.08.1.09.19.07.29l-.28 1.14c-.04.18-.15.22-.34.13-1.25-.58-2.03-2.4-2.03-3.87 0-3.15 2.29-6.04 6.6-6.04 3.46 0 6.16 2.47 6.16 5.77 0 3.44-2.17 6.21-5.18 6.21-1.01 0-1.96-.53-2.29-1.15l-.62 2.37c-.22.86-.83 1.94-1.24 2.6.94.29 1.92.44 2.95.44 5.52 0 10-4.48 10-10S17.52 2 12 2Z"/></svg>',
  bluesky: '<svg viewBox="0 0 24 24" fill="currentColor" class="h-3 w-3"><path d="M6.34 4.13c2.18 1.64 4.52 4.96 5.66 6.75 1.14-1.79 3.48-5.11 5.66-6.75 1.57-1.18 4.12-2.1 4.12.81 0 .58-.33 4.89-.53 5.59-.68 2.43-3.16 3.05-5.36 2.68 3.85.65 4.83 2.82 2.72 4.99-4.01 4.12-5.76-1.03-6.21-2.35-.08-.24-.12-.36-.12-.26 0-.1-.04.02-.12.26-.45 1.32-2.2 6.47-6.21 2.35-2.11-2.17-1.13-4.34 2.72-4.99-2.2.37-4.68-.25-5.36-2.68-.2-.7-.53-5.01-.53-5.59 0-2.91 2.55-1.99 4.12-.81Z"/></svg>',
