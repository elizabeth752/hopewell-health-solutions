const socials = [
  { label: "Instagram", href: "https://www.instagram.com/hopewellhealthsolutions/", svg: ICONS.instagram },
  { label: "Facebook", href: "https://www.facebook.com/hopewellhealth/", svg: ICONS.facebook },
  { label: "X (Twitter)", href: "https://x.com/hopewellHealthS", svg: ICONS.x },
  { label: "LinkedIn", href: "https://www.linkedin.com/company/hopewell-health-solutions-llc/", svg: ICONS.linkedin },
  { label: "TikTok", href: "https://www.tiktok.com/@hopewellhs", svg: ICONS.tiktok },
  { label: "Pinterest", href: "https://co.pinterest.com/hopewellhs/", svg: ICONS.pinterest },
  { label: "Bluesky", href: "https://bsky.app/profile/hopewellhs.bsky.social", svg: ICONS.bluesky },
];
---
<header class="sticky top-0 z-40 bg-white/95 backdrop-blur border-b border-line">
  <!-- top bar -->
  <div class="bg-ink text-white text-xs">
    <div class="mx-auto max-w-6xl px-5 py-1.5 flex items-center justify-between gap-4">
      <span class="tracking-wide">Empower · Change · Live Well</span>
      <div class="flex items-center gap-2">
        <span class="hidden sm:inline text-white/55 mr-1">Follow us</span>
        {socials.map((s) => (
          <a href={s.href} target="_blank" rel="noopener" aria-label={s.label} title={s.label} class="grid h-6 w-6 place-items-center rounded-full border border-white/40 text-white hover:bg-white hover:text-ink hover:border-white transition"><Fragment set:html={s.svg} /></a>
        ))}
      </div>
    </div>
  </div>

  <!-- main nav -->
  <div class="mx-auto max-w-6xl px-5">
    <div class="flex items-center justify-between py-3.5 gap-4">
      <a href="/" class="shrink-0" aria-label="Hopewell Health Solutions — home">
        <img src="/Assets/logo/hopewell-hhs-logo.svg" alt="Hopewell Health Solutions" width="640" height="380" class="h-12 sm:h-14 w-auto" />
      </a>

      <!-- desktop nav -->
      <nav class="hidden lg:flex items-center gap-x-5">
        {menu.map((m) => (
          <div class="relative group">
            <a href={m.href} class="flex items-center gap-1 text-sm font-semibold text-ink hover:text-azul transition py-2">
              {m.label}<Icon name="arrow" class="h-3 w-3 rotate-90 opacity-60 transition group-hover:translate-y-0.5" />
            </a>
            <div class={`invisible opacity-0 translate-y-1 group-hover:visible group-hover:opacity-100 group-hover:translate-y-0 group-focus-within:visible group-focus-within:opacity-100 transition duration-150 absolute ${m.align === "right" ? "right-0" : "left-0"} top-full pt-3 z-50`}>
              <div class="w-64 rounded-2xl border border-line bg-white shadow-xl p-2">
                <ul>
                  {m.children.map((c) => (
                    <li><a href={c.href} class="block rounded-lg px-3 py-2 text-sm font-medium text-ink hover:bg-crema hover:text-azul transition">{c.label}</a></li>
                  ))}
                </ul>
              </div>
            </div>
          </div>
        ))}
      </nav>

      <div class="flex items-center gap-2 shrink-0">
        <a href="tel:8607351448" class="hidden xl:inline-flex items-center gap-2 rounded-lg bg-azul-bright px-5 py-2.5 text-sm font-semibold text-white shadow-sm hover:bg-azul transition"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
        <!-- mobile toggle -->
        <button id="mobileToggle" class="lg:hidden grid h-10 w-10 place-items-center rounded-lg border border-line text-ink" aria-label="Open menu" aria-expanded="false">
          <svg class="h-5 w-5" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round"><line x1="3" y1="6" x2="21" y2="6"/><line x1="3" y1="12" x2="21" y2="12"/><line x1="3" y1="18" x2="21" y2="18"/></svg>
        </button>
      </div>
    </div>
  </div>

  <!-- mobile panel -->
  <div id="mobilePanel" class="hidden lg:hidden border-t border-line bg-white max-h-[80vh] overflow-y-auto">
    <div class="mx-auto max-w-6xl px-5 py-5 space-y-5">
      {menu.map((m) => (
        <div>
          <a href={m.href} class="block text-[11px] font-semibold uppercase tracking-[0.14em] text-gold mb-2">{m.label}</a>
          <ul class="space-y-0.5">
            {m.children.map((c) => <li><a href={c.href} class="block py-1.5 text-sm font-semibold text-ink">{c.label}</a></li>)}
          </ul>
        </div>
      ))}
      <a href="tel:8607351448" class="inline-flex items-center gap-2 rounded-lg bg-azul-bright px-5 py-3 text-sm font-semibold text-white"><Icon name="phone" class="h-4 w-4" />(860) 735-1448</a>
    </div>
  </div>
</header>

<script>
  const btn = document.getElementById("mobileToggle");
  const panel = document.getElementById("mobilePanel");
  btn?.addEventListener("click", () => {
    const open = panel?.classList.toggle("hidden") === false;
    btn.setAttribute("aria-expanded", String(open));
  });
</script>
