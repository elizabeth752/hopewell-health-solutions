---
// Renders one page's content document: working-notes (SEO scaffolding) above a
// continuous Google-Doc-style page below. Used inside each Content Studio panel.
import SeoCard from "./SeoCard.astro";

const { label, title, intro, meta, seo, keywords, decisions, sections } = Astro.props;
---

<div class="rounded-xl bg-white shadow-lg border border-line">
  <div class="border-b border-line px-14 py-4 flex items-center justify-between">
    <span class="text-sm text-muted">{label}</span>
    <span class="rounded-full bg-azul-light text-azul text-xs font-semibold px-2.5 py-0.5">Draft v1</span>
  </div>

  <div class="px-14 py-12">
    <h2 class="font-display text-4xl text-ink">{title}</h2>
    {intro && <p class="mt-3 text-lg text-muted max-w-4xl" set:html={intro} />}

    <!-- Working notes / SEO scaffolding -->
    <div class="mt-6"><SeoCard meta={meta} /></div>

    {seo && (
      <div class="mt-5 rounded-lg bg-azul-light border border-line p-6 max-w-4xl">
        <p class="text-sm font-semibold text-ink">📈 SEO context</p>
        <p class="mt-1 text-sm text-ink">{seo}</p>
      </div>
    )}

    {keywords && keywords.length > 0 && (
      <div class="mt-5 rounded-lg border border-line bg-white p-6 max-w-4xl">
        <p class="text-sm font-semibold text-ink">🛡️ Keywords this page must keep ranking for</p>
        <div class="mt-3 grid gap-x-6 gap-y-1.5 sm:grid-cols-2">
          {keywords.map((k) => (
            <div class="flex items-center justify-between gap-3 border-b border-line py-1">
              <span class="text-sm text-ink truncate">{k[0]}</span>
              <span class="shrink-0 text-xs text-muted font-mono">#{k[1]} · {k[2]}/mo</span>
            </div>
          ))}
        </div>
      </div>
    )}

    {decisions && decisions.length > 0 && (
      <div class="mt-5 rounded-lg border border-amber-300 bg-amber-50 p-6 max-w-4xl">
        <p class="font-semibold text-amber-900">Decisions & open items</p>
        <ul class="mt-2 space-y-1.5">
          {decisions.map((f) => <li class="text-sm text-amber-900 flex gap-2"><span class="font-bold">•</span><span set:html={f} /></li>)}
        </ul>
      </div>
    )}

    <div class="mt-8 flex items-center gap-3">
      <span class="text-xs font-semibold uppercase tracking-wide text-muted">Page draft</span>
      <span class="h-px flex-1 bg-line"></span>
    </div>

    <!-- The page as one continuous document -->
    <div class="mt-5 mx-auto max-w-[800px] rounded-xl bg-white shadow-lg border border-line px-10 sm:px-16 py-16">
      {sections.map((s, i) => (
        <div class={i === 0 ? "" : "mt-12"}>
          {s.eyebrow && <p class="text-xs font-semibold uppercase tracking-wide text-azul mb-3">{s.eyebrow}</p>}
          {i === 0 ? (
            <h1 class="font-display text-4xl sm:text-5xl text-ink leading-tight">{s.headline}</h1>
          ) : (
            <h2 class="font-display text-2xl sm:text-3xl text-ink leading-tight">{s.headline}</h2>
          )}
          {s.copy && s.copy.map((p) => <p class="mt-4 text-ink leading-relaxed text-[17px]">{p}</p>)}
          {i === 0 && s.body ? (
            <p class="mt-4 text-sm text-muted">{s.body.join("  ·  ")}</p>
          ) : (
            s.body && (
              <ul class="mt-4 space-y-2 list-disc pl-5 marker:text-azul">
                {s.body.map((b) => <li class="text-ink leading-relaxed text-[17px]">{b}</li>)}
              </ul>
            )
          )}
          {s.copyAfter && s.copyAfter.map((p) => <p class="mt-4 text-ink leading-relaxed text-[17px]">{p}</p>)}
          {s.faq && (
            <div class="mt-5 space-y-5">
              {s.faq.map((f) => (
                <div>
                  <h3 class="font-display text-lg text-ink">{f.q}</h3>
                  <p class="mt-1 text-ink leading-relaxed text-[17px]">{f.a}</p>
                </div>
              ))}
            </div>
          )}
          {s.ctas && (
            <div class="mt-6 flex flex-wrap gap-2">
              {s.ctas.map((c, idx) => (
                <span class={`rounded-lg px-5 py-2.5 text-sm font-semibold ${idx === 0 ? "bg-azul text-white" : "border border-azul text-azul"}`}>{c}</span>
              ))}
            </div>
          )}
          {s.form && <p class="mt-3 text-xs text-muted italic">[ {s.form} ]</p>}
        </div>
      ))}
    </div>
  </div>
</div>
