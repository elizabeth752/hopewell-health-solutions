---
const locations = [
  ["Glastonbury", "300 Hebron Ave", "/location/glastonbury-ct/"],
  ["South Glastonbury", "1420 Main St", "/location/glastonbury-ct-3/"],
  ["Glastonbury", "33 Pratt St", "/location/glastonbury-ct-2/"],
  ["West Hartford", "1216 Farmington Ave", "/location/west-hartford-ct/"],
  ["East Hampton", "151 E. High St", "/location/east-hampton-ct/"],
  ["Westbrook", "70 Essex Rd", "/location/westbrook-ct/"],
];
const cols = [
  { h: "Programs", links: ["Intensive Outpatient (IOP)", "Partial Hospitalization (PHP)", "Medication Management", "Outpatient Therapy"] },
  { h: "What We Treat", links: ["Depression", "Anxiety", "Trauma & PTSD", "Substance Use", "ADHD"] },
  { h: "Treatments", links: ["TMS", "Spravato®", "EMDR", "GeneSight®"] },
];
---
<footer class="bg-ink text-white/80">
  <div class="mx-auto max-w-6xl px-5 py-14">
    <div class="grid gap-10 md:grid-cols-4">
      <div>
        <a href="/" class="inline-block mb-4" aria-label="Hopewell Health Solutions — home">
          <img src="/Assets/logo/hopewell-hhs-logo-white.svg" alt="Hopewell Health Solutions" width="640" height="380" class="h-20 w-auto" />
        </a>
        <p class="text-sm leading-relaxed">Connecticut’s intensive programs center for mental wellness &amp; psychiatry. There is hope to heal.</p>
        <a href="tel:8609460447" class="mt-4 inline-block font-display text-2xl text-white">(860) 946-0447</a>
        <p class="text-xs mt-3">Joint Commission accredited · 4.8★ · Since 2013</p>
      </div>
      {cols.map((c) => (
        <div>
          <h4 class="text-white text-sm font-semibold uppercase tracking-wide mb-3">{c.h}</h4>
          <ul class="space-y-2 text-sm">
            {c.links.map((l) => <li><a href="#" class="hover:text-white transition">{l}</a></li>)}
          </ul>
        </div>
      ))}
    </div>
    <div class="mt-12 border-t border-white/15 pt-8">
      <h4 class="text-white text-sm font-semibold uppercase tracking-wide mb-4">Our Connecticut Locations</h4>
      <div class="grid gap-3 sm:grid-cols-2 lg:grid-cols-3 text-sm">
        {locations.map(([city, addr, href]) => (
          <a href={href} class="flex gap-2 hover:text-white transition"><span class="text-azul-light">●</span><span><span class="text-white">{city}</span> — {addr}</span></a>
        ))}
      </div>
    </div>
    <div class="mt-10 flex flex-col sm:flex-row items-center justify-between gap-4 text-xs text-white/60">
      <span>© 2026 Hopewell Health Solutions and Psychiatry, Inc. All rights reserved.</span>
      <span class="flex gap-4"><a href="#" class="hover:text-white">Privacy</a><a href="#" class="hover:text-white">Terms</a><a href="#" class="hover:text-white">Accessibility</a></span>
    </div>
  </div>
</footer>
